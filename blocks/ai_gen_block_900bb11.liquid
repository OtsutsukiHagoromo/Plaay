{% doc %}
  @prompt
    a section that is just white space that can be used to give space/padding above any section should have option to suggest height/padding of it, also option to set background color
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-spacer-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    height: {{ block.settings.spacing_desktop }}px;
    background-color: {{ block.settings.background_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-spacer-{{ ai_gen_id }} {
      height: {{ block.settings.spacing_mobile }}px;
    }
  }
{% endstyle %}

<spacer-block-{{ ai_gen_id }}
  class="ai-spacer-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
</spacer-block-{{ ai_gen_id }}>

<script>
  (function() {
    class SpacerBlock{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }

    customElements.define('spacer-block-{{ ai_gen_id }}', SpacerBlock{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Spacer",
  "settings": [
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "spacing_desktop",
      "label": "Desktop height",
      "min": 10,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 50
    },
    {
      "type": "range",
      "id": "spacing_mobile",
      "label": "Mobile height",
      "min": 10,
      "max": 150,
      "step": 10,
      "unit": "px",
      "default": 30
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Spacer"
    }
  ]
}
{% endschema %}
