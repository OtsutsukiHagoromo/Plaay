    }
    .product-tile-slides-{{ ai_gen_id }}.cols-desktop-large-3 {
      grid-template-columns: repeat(3, 1fr);
    }
    .product-tile-slides-{{ ai_gen_id }}.cols-desktop-large-4 {
      grid-template-columns: repeat(4, 1fr);
