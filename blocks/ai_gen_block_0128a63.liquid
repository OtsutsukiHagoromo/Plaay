      font-size: 3rem;
    }
  }

  .product-tile-description-{{ ai_gen_id }} {
    text-align: center;
    color: #1e3a8a;
    margin: 0 auto;
    max-width: 48rem;
    padding: 0.5rem 0;
    font-size: 0.875rem;
    width: 100%;
    order: 1;
  }

  @media (min-width: 768px) {
    .product-tile-description-{{ ai_gen_id }} {
      font-size: 1rem;
    }
  }

  @media (min-width: 1024px) {
    .product-tile-description-{{ ai_gen_id }} {
      font-size: 1.125rem;
    }
  }

  .product-tile-see-all-{{ ai_gen_id }} {
    display: block;
    text-transform: uppercase;
    text-decoration: underline;
    font-size: 1.25rem;
    text-underline-offset: 2px;
    font-weight: 700;
    margin-top: 1rem;
    text-align: center;
    transition: all 0.2s;
    color: #1e3a8a;
  }

  .product-tile-see-all-{{ ai_gen_id }}:hover {
    text-decoration: none;
  }

  .product-tile-arrows-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    margin-top: 0.75rem;
  }

  @media (min-width: 768px) {
    .product-tile-arrows-{{ ai_gen_id }} {
      margin-top: 0;
      margin-left: 2.5rem;
      width: auto;
    }
  }

  .product-tile-arrows-{{ ai_gen_id }}.hide-mobile {
    display: none;
  }

  @media (min-width: 768px) {
    .product-tile-arrows-{{ ai_gen_id }}.hide-mobile.show-desktop {
      display: flex;
    }
  }

  @media (min-width: 768px) {
    .product-tile-arrows-{{ ai_gen_id }}.hide-desktop {
      display: none;
    }
  }

  .product-tile-arrow-{{ ai_gen_id }} {
    font-size: 0;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  .product-tile-arrow-left-{{ ai_gen_id }} {
    margin-right: 1.25rem;
  }

  .product-tile-arrow-right-{{ ai_gen_id }} {
    margin-left: 1.25rem;
  }

  .product-tile-arrow-icon-{{ ai_gen_id }} {
    display: flex;
    height: 1.5rem;
    width: 1.5rem;
    color: #1e3a8a;
    opacity: 0.3;
    transition: all 0.2s;
  }

  .product-tile-arrow-{{ ai_gen_id }}:hover .product-tile-arrow-icon-{{ ai_gen_id }} {
    opacity: 1;
  }

  .product-tile-arrow-left-{{ ai_gen_id }} .product-tile-arrow-icon-{{ ai_gen_id }} {
    transform: rotate(180deg);
  }

  .product-tile-track-{{ ai_gen_id }} {
    overflow: hidden;
  }

  .product-tile-slides-{{ ai_gen_id }} {
    display: flex;
    padding: 1.25rem 0;
    gap: 1rem;
