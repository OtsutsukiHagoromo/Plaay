    .product-tile-container-{{ ai_gen_id }} {
      padding-top: 2rem;
      padding-bottom: 2rem;
    }
  }

  .product-tile-container-{{ ai_gen_id }}.extra-top-padding {
    padding-top: 2.5rem;
  }

  @media (min-width: 768px) {
    .product-tile-container-{{ ai_gen_id }}.extra-top-padding {
      padding-top: 4.5rem;
    }
  }

  .product-tile-container-{{ ai_gen_id }}.extra-bottom-padding {
    padding-bottom: 2.5rem;
  }

  @media (min-width: 768px) {
    .product-tile-container-{{ ai_gen_id }}.extra-bottom-padding {
      padding-bottom: 4.5rem;
    }
  }

  .product-tile-wrapper-{{ ai_gen_id }} {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .product-tile-header-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 2.5rem;
  }

  @media (min-width: 768px) {
    .product-tile-header-{{ ai_gen_id }} {
      flex-direction: row;
      justify-content: center;
      flex-wrap: wrap;
      margin-bottom: 2.5rem;
    }
  }

  .product-tile-title-{{ ai_gen_id }} {
    text-align: center;
    color: #1e3a8a;
    margin-right: 1rem;
    margin-bottom: 1.75rem;
    font-size: 2.25rem;
    text-transform: uppercase;
  }

  @media (min-width: 768px) {
    .product-tile-title-{{ ai_gen_id }} {
