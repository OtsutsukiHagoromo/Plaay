{% endstyle %}

<product-tile-{{ ai_gen_id }} class="product-tile-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div
    class="product-tile-container-{{ ai_gen_id }} {% if extra_top_padding %} extra-top-padding {% endif %} {% if extra_bottom_padding %} extra-bottom-padding {% endif %}"
  >
    <div class="product-tile-wrapper-{{ ai_gen_id }}">
      <div class="product-tile-header-{{ ai_gen_id }}">
        {% if title != blank %}
          <h2 class="product-tile-title-{{ ai_gen_id }}">{{ title }}</h2>
        {% endif %}

        {% if description != blank %}
          <p class="product-tile-description-{{ ai_gen_id }}">{{ description }}</p>
        {% endif %}

        {% if see_all_link != blank %}
          <a href="{{ see_all_link }}" class="product-tile-see-all-{{ ai_gen_id }}">
            {% if see_all_link_text != blank %}
              {{ see_all_link_text }}
            {% else %}
              See All
            {% endif %}
          </a>
        {% endif %}

        <div class="product-tile-arrows-{{ ai_gen_id }} {% if hide_arrows_mobile %} hide-mobile {% unless hide_arrows_desktop %} show-desktop {% endunless %} {% endif %} {% if hide_arrows_desktop %} hide-desktop {% endif %}">
          <button class="product-tile-arrow-{{ ai_gen_id }} product-tile-arrow-left-{{ ai_gen_id }}" data-direction="prev" aria-label="Previous slide">
            <span class="product-tile-arrow-icon-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" width="40" height="40" focusable="false"><path d="m15.5 0.932-4.3 4.38 14.5 14.6-14.5 14.5 4.3 4.4 14.6-14.6 4.4-4.3-4.4-4.4-14.6-14.6z"></path></svg>
            </span>
          </button>
          <button class="product-tile-arrow-{{ ai_gen_id }} product-tile-arrow-right-{{ ai_gen_id }}" data-direction="next" aria-label="Next slide">
            <span class="product-tile-arrow-icon-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" width="40" height="40" focusable="false"><path d="m15.5 0.932-4.3 4.38 14.5 14.6-14.5 14.5 4.3 4.4 14.6-14.6 4.4-4.3-4.4-4.4-14.6-14.6z"></path></svg>
            </span>
          </button>
        </div>
      </div>

      <div class="product-tile-track-{{ ai_gen_id }}">
        <ul
          class="product-tile-slides-{{ ai_gen_id }} {% if mobile_grid_enabled %} mobile-grid cols-{{ mobile_grid_columns }} gap-{{ mobile_grid_gap }} {% endif %} cols-tablet-{{ column_size_tablet }} cols-desktop-{{ column_size_desktop }} cols-desktop-large-{{ column_size_desktop_large }} cols-desktop-xl-{{ column_size_desktop_extra_large }}"
        >
          {% liquid
            assign products_to_show = blank
            
            if products_featured_in_this_article != blank and products_featured_in_this_article.size > 0
              assign products_to_show = products_featured_in_this_article
            elsif collection != blank
              assign products_to_show = collection.products
            endif
          %}

          {% if products_to_show != blank and products_to_show.size > 0 %}
            {% for product in products_to_show limit: limit %}
              <li class="product-tile-slide-{{ ai_gen_id }}">
                <a href="{{ product.url }}" class="product-tile-card-{{ ai_gen_id }}">
                  <div class="product-tile-image-wrapper-{{ ai_gen_id }}">
                    {% if product.featured_image %}
                      <img
                        src="{{ product.featured_image | image_url: width: 600 }}"
                        alt="{{ product.featured_image.alt | escape }}"
                        class="product-tile-image-{{ ai_gen_id }}"
                        loading="lazy"
                        width="600"
                        height="600"
                      >
                    {% else %}
                      {{ 'product-1' | placeholder_svg_tag }}
                    {% endif %}
                  </div>
                  <div class="product-tile-info-{{ ai_gen_id }}">
                    <h3 class="product-tile-product-title-{{ ai_gen_id }}">{{ product.title }}</h3>
                    <div class="product-tile-price-{{ ai_gen_id }}">{{ product.price | money }}</div>
                  </div>
                </a>
              </li>
            {% endfor %}
          {% else %}
            <li class="product-tile-slide-{{ ai_gen_id }}" style="flex: 0 0 100%;">
              <div class="product-tile-empty-{{ ai_gen_id }}">
                Next, select a collection or add products
              </div>
            </li>
          {% endif %}
        </ul>
      </div>
    </div>
  </div>
</product-tile-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductTile{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
      }

      connectedCallback() {
        this.track = this.querySelector('.product-tile-slides-{{ ai_gen_id }}');
        this.slides = this.querySelectorAll('.product-tile-slide-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('[data-direction="prev"]');
        this.nextButton = this.querySelector('[data-direction="next"]');

        if (this.prevButton && this.nextButton) {
          this.prevButton.addEventListener('click', () => this.navigate('prev'));
          this.nextButton.addEventListener('click', () => this.navigate('next'));
        }

        if (window.innerWidth < 768 && !this.track.classList.contains('mobile-grid')) {
          this.enableTouchScroll();
        }
      }

      navigate(direction) {
        if (direction === 'prev') {
          this.currentIndex = Math.max(0, this.currentIndex - 1);
        } else {
          this.currentIndex = Math.min(this.slides.length - 1, this.currentIndex + 1);
        }

        if (this.slides[this.currentIndex]) {
          this.slides[this.currentIndex].scrollIntoView({
            behavior: 'smooth',
            block: 'nearest',
            inline: 'start'
          });
        }
      }

      enableTouchScroll() {
        let isDown = false;
        let startX;
        let scrollLeft;

        this.track.addEventListener('mousedown', (e) => {
          isDown = true;
          startX = e.pageX - this.track.offsetLeft;
          scrollLeft = this.track.scrollLeft;
        });

        this.track.addEventListener('mouseleave', () => {
          isDown = false;
        });

        this.track.addEventListener('mouseup', () => {
          isDown = false;
        });

        this.track.addEventListener('mousemove', (e) => {
          if (!isDown) return;
          e.preventDefault();
          const x = e.pageX - this.track.offsetLeft;
          const walk = (x - startX) * 2;
          this.track.scrollLeft = scrollLeft - walk;
        });
      }
    }

    customElements.define('product-tile-{{ ai_gen_id }}', ProductTile{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Featured products",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "limit",
      "label": "Product limit",
      "min": 2,
      "max": 20,
      "step": 1,
      "default": 8
    },
    {
      "type": "header",
      "content": "See all link"
    },
    {
      "type": "text",
      "id": "see_all_link_text",
      "label": "Link text",
      "default": "See All"
    },
    {
      "type": "url",
      "id": "see_all_link",
      "label": "Link URL"
    },
    {
      "type": "header",
      "content": "Layout"
    },
