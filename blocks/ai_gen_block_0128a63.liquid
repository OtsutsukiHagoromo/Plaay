    scroll-snap-type: none;
  }

  .product-tile-slides-{{ ai_gen_id }}.mobile-grid.cols-1 {
    grid-template-columns: repeat(1, 1fr);
  }

  .product-tile-slides-{{ ai_gen_id }}.mobile-grid.cols-2 {
    grid-template-columns: repeat(2, 1fr);
  }

  .product-tile-slides-{{ ai_gen_id }}.mobile-grid.gap-small {
    gap: 0.5rem;
  }

  .product-tile-slides-{{ ai_gen_id }}.mobile-grid.gap-medium {
    gap: 1rem;
  }

  .product-tile-slides-{{ ai_gen_id }}.mobile-grid.gap-large {
    gap: 1.5rem;
  }

