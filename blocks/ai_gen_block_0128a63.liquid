{% doc %}
  @prompt
    generate this exactly 
    here is the code
    {% liquid
      assign title = section.settings.title
      assign description = section.settings.description
      assign background_color = section.settings.background_color
    
      assign column_size_desktop_extra_large = section.settings.column_size_desktop_extra_large
      assign column_size_desktop_large = section.settings.column_size_desktop_large
      assign column_size_desktop = section.settings.column_size_desktop
      assign column_size_tablet = section.settings.column_size_tablet
    
      assign mobile_grid_enabled = section.settings.mobile_grid_enabled
      assign mobile_grid_columns = section.settings.mobile_grid_columns
      assign mobile_grid_gap = section.settings.mobile_grid_gap
    
      assign see_all_link_text = section.settings.see_all_link_text
      assign see_all_link = section.settings.see_all_link
    
      assign extra_bottom_padding = section.settings.extra_bottom_padding
      assign extra_top_padding = section.settings.extra_top_padding
      assign hide_arrows_desktop = section.settings.hide_arrows_desktop
      assign hide_arrows_mobile = section.settings.hide_arrows_mobile
      assign hide_bullets = section.settings.hide_bullets
    
      assign collection = section.settings.collection
      assign limit = section.settings.limit
    
      assign products_featured_in_this_article = article.metafields.arena.product_featured_in_this_article
    %}
    
    <product-tile data-module="product-tile">
      <div
        data-product-slider
        id="featured-products-{{ section.id }}"
        class="py-6 | md:py-8 {% if extra_top_padding %} pt-10 md:pt-18 {% endif %} {% if extra_bottom_padding %} pb-10 md:pb-18 {% endif %}"
        data-section-id="{{ section.id }}"
        style="background-color: {{ background_color }};"
      >
        <div class="container">
          <div id="featured_products_slider-{{ section.id }}" class="glide featured-main" data-mobile-grid="{{ mobile_grid_enabled }}">
            <div class="view-all-flex glide__arrow-container w-auto block flex-col justify-center {% if description != blank %} flex-wrap {% endif %} | md:pb-10 {% if article %} md:flex-col {% else %} md:flex-row {% endif %}">
              {% if title != blank %}
                <h2 class="text-center text-dark-blue mr-4 mb-7 | md:mb-0 {% if article %} text-lg md:text-2xl {% else %} text-4xl md:text-9xl uppercase {% endif %}">{{ title }}</h2>
              {% endif %}
    
              {% if description != blank %}
                <p class="text-center text-dark-blue mx-auto max-w-3xl py-2 text-sm | md:flex-100 md:order-1 md:text-base | lg:text-lg">{{ description }}</p>
              {% endif %}
    
              {% if see_all_link != blank %}
                <a href="{{ see_all_link }}" class="custom-view-aall block uppercase underline text-xl underline-offset-2 font-walsheim-bold mt-4 text-center transition-all duration-200 text-dark-blue | hover:no-underline">
                  {% if see_all_link_text != blank %}
                    {{ see_all_link_text }}
                  {% else %}
                    {{ 'action.see_all' | t }}
                  {% endif %}
                </a>
              {% endif %}
            </div>
    
            <div class="glide__arrows flex items-center justify-center w-full mt-3 {% if hide_arrows_mobile %} hidden {% unless hide_arrows_desktop %} md:block {% endunless %} {% endif %} | {% if hide_arrows_desktop %} md:hidden {% endif %} md:mb-0 md:mt-0 {% unless article %} md:ml-10 {% endunless %} md:w-auto" data-glide-el="controls">
              <button data-glide-dir="<" class="glide__arrow glide__arrow--left text-0 mr-5 group">
                slide left
                <span class="flex h-6 w-6 transform rotate-180 text-dark-blue opacity-30 transition-all duration-200 | group-hover:opacity-100">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" width="40" height="40" focusable="false"><path d="m15.5 0.932-4.3 4.38 14.5 14.6-14.5 14.5 4.3 4.4 14.6-14.6 4.4-4.3-4.4-4.4-14.6-14.6z"></path></svg>
                </span>
              </button>
              <button data-glide-dir=">" class="glide__arrow glide__arrow--right text-0 ml-5 group">
                slide right
                <span class="flex h-6 w-6 text-dark-blue opacity-30 transition-all duration-200 | group-hover:opacity-100">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" width="40" height="40" focusable="false"><path d="m15.5 0.932-4.3 4.38 14.5 14.6-14.5 14.5 4.3 4.4 14.6-14.6 4.4-4.3-4.4-4.4-14.6-14.6z"></path></svg>
                </span>
              </button>
            </div>
    
            <div class="glide__track" data-glide-el="track">
              <ul
                class="glide__slides py-5 pb-5 featured-slides-{{ section.id }}"
                data-mobile-grid-columns="{{ mobile_grid_columns }}"
                data-mobile-grid-gap="{{ mobile_grid_gap }}"
              >
                {% comment %}
                  Priority:
                  1) article metafield products (if present)
                  2) selected collection products
                {% endcomment %}
    
                {% if products_featured_in_this_article != blank and products_featured_in_this_article.size > 0 %}
        
{% enddoc %}
{% liquid
  assign ai_gen_id = block.id | replace: '_', '' | downcase
  assign title = block.settings.title
  assign description = block.settings.description
  assign background_color = block.settings.background_color

  assign column_size_desktop_extra_large = block.settings.column_size_desktop_extra_large
  assign column_size_desktop_large = block.settings.column_size_desktop_large
  assign column_size_desktop = block.settings.column_size_desktop
  assign column_size_tablet = block.settings.column_size_tablet

  assign mobile_grid_enabled = block.settings.mobile_grid_enabled
  assign mobile_grid_columns = block.settings.mobile_grid_columns
  assign mobile_grid_gap = block.settings.mobile_grid_gap

  assign see_all_link_text = block.settings.see_all_link_text
  assign see_all_link = block.settings.see_all_link

  assign extra_bottom_padding = block.settings.extra_bottom_padding
  assign extra_top_padding = block.settings.extra_top_padding
  assign hide_arrows_desktop = block.settings.hide_arrows_desktop
  assign hide_arrows_mobile = block.settings.hide_arrows_mobile
  assign hide_bullets = block.settings.hide_bullets

  assign collection = block.settings.collection
  assign limit = block.settings.limit

  assign products_featured_in_this_article = article.metafields.arena.product_featured_in_this_article
%}

{% style %}
  .product-tile-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .product-tile-container-{{ ai_gen_id }} {
