{% doc %}
  @prompt
    A custom HTML section
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-custom-html-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-custom-html-content-{{ ai_gen_id }} {
    width: 100%;
  }

  .ai-custom-html-empty-state-{{ ai_gen_id }} {
    padding: 40px 20px;
    text-align: center;
    background-color: #f4f4f4;
    border-radius: 8px;
    color: #666;
  }

  .ai-custom-html-empty-state-{{ ai_gen_id }} svg {
    width: 60px;
    height: 60px;
    margin-bottom: 16px;
    opacity: 0.5;
  }

  .ai-custom-html-empty-state-{{ ai_gen_id }} h3 {
    margin: 0 0 8px;
    font-size: 18px;
    color: #333;
  }

  .ai-custom-html-empty-state-{{ ai_gen_id }} p {
    margin: 0;
    font-size: 14px;
  }

  @media screen and (max-width: 749px) {
    .ai-custom-html-{{ ai_gen_id }} {
      width: 100%;
      padding: {{ block.settings.padding | times: 0.7 }}px;
    }
  }
{% endstyle %}

<div class="ai-custom-html-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.custom_html != blank %}
    <div class="ai-custom-html-content-{{ ai_gen_id }}">
      {{ block.settings.custom_html }}
    </div>
  {% else %}
    <div class="ai-custom-html-empty-state-{{ ai_gen_id }}">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="16 18 22 12 16 6"></polyline>
        <polyline points="8 6 2 12 8 18"></polyline>
      </svg>
      <h3>Custom HTML block</h3>
      <p>Add your custom HTML code in the block settings</p>
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Custom HTML",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "html",
      "id": "custom_html",
      "label": "HTML code"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Custom HTML"
    }
  ]
}
{% endschema %}
