{% doc %}
  @prompt
    a headline & sub headline column with option to set padding as well along with text alighnment and other size options
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-headline-column-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    padding-left: {{ block.settings.padding_left }}px;
    padding-right: {{ block.settings.padding_right }}px;
    background-color: {{ block.settings.background_color }};
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-headline-column__heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.spacing_between }}px 0;
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    color: {{ block.settings.heading_color }};
    line-height: {{ block.settings.heading_line_height }};
  }

  .ai-headline-column__subheading-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.subheading_size }}px;
    font-weight: {{ block.settings.subheading_weight }};
    color: {{ block.settings.subheading_color }};
    line-height: {{ block.settings.subheading_line_height }};
  }

  @media screen and (max-width: 749px) {
    .ai-headline-column-{{ ai_gen_id }} {
      padding-top: {{ block.settings.padding_top | times: 0.7 | round }}px;
      padding-bottom: {{ block.settings.padding_bottom | times: 0.7 | round }}px;
      padding-left: {{ block.settings.padding_left | times: 0.7 | round }}px;
      padding-right: {{ block.settings.padding_right | times: 0.7 | round }}px;
    }

    .ai-headline-column__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 | round }}px;
    }

    .ai-headline-column__subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.7 | round }}px;
    }
  }
{% endstyle %}

<headline-column-{{ ai_gen_id }}
  class="ai-headline-column-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.heading != blank %}
    <h2 class="ai-headline-column__heading-{{ ai_gen_id }}">
      {{ block.settings.heading }}
    </h2>
  {% endif %}

  {% if block.settings.subheading != blank %}
    <div class="ai-headline-column__subheading-{{ ai_gen_id }}">
      {{ block.settings.subheading }}
    </div>
  {% endif %}
</headline-column-{{ ai_gen_id }}>

<script>
  (function() {
    class HeadlineColumn{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }

    customElements.define('headline-column-{{ ai_gen_id }}', HeadlineColumn{{ ai_gen_id }});
  })();
</script>

{% schema %}
