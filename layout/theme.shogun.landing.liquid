{% comment %}
Auto-generated by Shogun.
This file can be re-written at any time.
{% endcomment %}

<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  
<head>
  
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">

    <link
      rel="preconnect"
      href="https://cdn.shopify.com"
      crossorigin>
    <link rel="dns-prefetch" href="https://www.bugherd.com">
    <link
      rel="preload"
      href="{{ 'bundle.theme.css' | asset_url }}"
      as="style">
    <link
      rel="preload"
      href="{{ 'bundle.theme.js' | asset_url }}"
      as="script">

    {%- if template -%}
      {%- capture file_name -%}bundle.{{- template | remove: 'customers/' -}}.js{%- endcapture -%}
      <link
        rel="preload"
        href="{{- file_name | asset_url -}}"
        as="script">
    {%- endif -%}

    {% if settings.favicon %}
      <link
        rel="shortcut icon"
        href="{{- settings.favicon | img_url: '32x32' -}}"
        type="image/png">
    {% endif %}

    <title>{{ page_title | escape }}</title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {{ 'bundle.theme.css' | asset_url | stylesheet_tag }}
    {% render 'head.fonts' %}

    {%- if template -%}
      {%- capture file_name -%}bundle.{{- template | remove: 'customers/' -}}.css{%- endcapture -%}
      {{ file_name | asset_url | stylesheet_tag }}
    {% endif %}

    {{ content_for_header }}

    {%- capture file -%}
      {{ 'site.webmanifest.json' | asset_url }}
    {%- endcapture -%}

    {%- liquid
      assign is_dev_theme = false

      if theme.name contains 'Development'
        assign is_dev_theme = true
      endif

      assign assets_path = file | split: 'site.webmanifest.json' | first

      if is_dev_theme
        assign assets_path = '/assets/'
      endif
    -%}

    <script>
      window.__webpack_public_path__ = "{{ assets_path }}"

      window.theme = {
        isDevTheme: {{ is_dev_theme }},
        customer: {
          isLoggedIn:{% if customer %}true
          {% else %}
            false
          {% endif %},
          id: {{ customer.id | default: 'null' }}
        },
        moneyFormat: {{ shop.money_format | json }}
        {% if template contains 'account' %},
          allCountryOptionTags : {{ all_country_option_tags | json }}
        {% endif %}
      }

      window.routes = {
        cart_add_url: '{{ routes.cart_add_url }}',
        cart_change_url: '{{ routes.cart_change_url }}',
        cart_update_url: '{{ routes.cart_update_url }}',
        cart_url: '{{ routes.cart_url }}'
      };
    </script>
  {% render 'delivery_coder' %} 

  {% render 'shogun-head' %}
</head>


  
<body class="template-{{ template }}">
  
  
  {{ content_for_layout }}
  
  <script defer src="{{ 'bundle.theme.js' | asset_url }}"></script>
  {%- if template -%}
    {%- capture file_name -%}bundle.{{- template | remove: 'customers/' -}}.js{%- endcapture -%}
    <script defer src="{{ file_name | asset_url }}"></script>
  {%- endif -%}
<script defer src="{{ 'glide.static.min.js' | asset_url }}"></script>
  {% unless request.design_mode %}
    <script>
      (function() {
        function loadScript(src) {
          var script = document.createElement('script');
          script.src = src;
          script.async = true;
          document.head.appendChild(script);
        }

        function loadWhenIdle(callback) {
          if ('requestIdleCallback' in window) {
            window.requestIdleCallback(callback, { timeout: 2000 });
          } else {
            setTimeout(callback, 1500);
          }
        }

        window.addEventListener('load', function() {
          loadWhenIdle(function() {
            loadScript('https://www.bugherd.com/sidebarv2.js?apikey=vunxekqg5ov0xe3ajrxzrw');
          });
        }, { once: true });
      })();
    </script>
  {% endunless %}
  <style type="text/css">
    body, html {
      width: 100% !important;
      background: white !important;
    }
  </style>
  
</body>

</html>
