{% comment %} REBUY SMART CART DISABLED {% endcomment %}
<script>
  document.addEventListener('rebuy:smartcart.ready', function() {
    try { Rebuy.SmartCart.destroy(); } catch(e) {}
    document.body.classList.remove('smart-cart--enabled');
  });

  // Wait for bundle.theme.js to finish, then re-attach cart button
  window.addEventListener('load', function() {
    setTimeout(function() {
      var cartBtn = document.querySelector('.header__icon--cart');
      if (!cartBtn) return;

      // Clone to strip any Rebuy listeners
      var newBtn = cartBtn.cloneNode(true);
      cartBtn.parentNode.replaceChild(newBtn, cartBtn);

      newBtn.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopImmediatePropagation();
        var sd = document.querySelector('site-drawers');
        if (sd) {
          sd.activeDrawer = 'cart';
          console.log('Cart opened via site-drawers');
        }
      }, true);

      console.log('Cart button listener attached');
    }, 1000);
  });
</script>
