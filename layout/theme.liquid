      <script>
        var headerCartButton = document.querySelector('.header__icon--cart');
        if (headerCartButton) headerCartButton.addEventListener('click', function() {
          var sd = document.querySelector('site-drawers');
          /* If the Drawers custom-element has been upgraded, use its API */
          if (sd && sd.activeDrawer !== undefined) {
            sd.activeDrawer = 'cart';
            return;
          }
          /* Fallback: toggle classes directly so the cart opens regardless of bundle timing */
          var cd = document.querySelector('cart-drawer');
          if (!cd) return;
          cd.classList.add('active');
          document.body.classList.add('overflow-hidden');
          if (sd) {
            var ov = sd.querySelector('[data-overlay]');
            if (ov) {
              ov.classList.add('active');
              ov.addEventListener('click', function() {
                cd.classList.remove('active');
                document.body.classList.remove('overflow-hidden');
                ov.classList.remove('active');
              }, { once: true });
            }
          }
        });
      </script>

