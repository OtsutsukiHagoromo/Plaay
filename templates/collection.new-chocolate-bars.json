/*
 * New Chocolate Bars launch collection template.
 * Stopmotion hero + colour-coded flavour tiles + product grid.
 */
{
  "sections": {
    "nlb_hero": {
      "type": "nlb-collection-hero",
      "settings": {
        "eyebrow": "New Launch · Available Now",
        "heading": "Clean Chocolate Bars. Just Dropped.",
        "subheading": "Seven new bars. 70% dark and creamy milk chocolate. 100% clean ingredients, zero refined sugar.",
        "button_label": "Shop the launch",
        "button_link": "#shopify-section-main",
        "fps": 10,
        "media_left": false,
        "background_color": "#021D49"
      }
    },
    "nlb_tiles": {
      "type": "nlb-flavour-tiles",
      "settings": {
        "heading": "Pick Your Flavour",
        "product_limit": 8,
        "background_color": "#FAF7F2"
      }
    },
    "main": {
      "type": "featured_products",
      "name": "Featured products",
      "settings": {
        "title": "Shop The New Bars",
        "description": "",
        "background_color": "#ffffff",
        "product_source": "collection",
        "featured_collection": "new-chocolate-bars",
        "collection_product_limit": 12,
        "extra_top_padding": true,
        "extra_bottom_padding": true,
        "column_size_desktop_extra_large": 4,
        "column_size_desktop_large": 4,
        "column_size_desktop": 4,
        "column_size_tablet": 3,
        "column_size_mobile": 1.2,
        "column_size_mobile_small": 1.2,
        "autoplay": 0,
        "see_all_link": "shopify://collections/new-chocolate-bars",
        "see_all_link_text": "Shop all new bars",
        "hide_arrows_desktop": false,
        "hide_arrows_mobile": false,
        "hide_bullets": true,
        "compact_mobile_grid": false,
        "hide_atc_on_tiles": false
      }
    },
    "nlb_cred": {
      "type": "nlb-credentials",
      "blocks": {
        "c1": { "type": "cred", "settings": { "value": "0g", "label": "Refined Sugar" } },
        "c2": { "type": "cred", "settings": { "value": "100%", "label": "Clean Ingredients" } },
        "c3": { "type": "cred", "settings": { "value": "Halal", "label": "Certified" } },
        "c4": { "type": "cred", "settings": { "value": "UAE", "label": "Made Local" } }
      },
      "block_order": ["c1", "c2", "c3", "c4"],
      "settings": {
        "heading": "Why Plaay Bars",
        "background_color": "#021D49",
        "text_color": "#ffffff"
      }
    },
    "plaay_recently_viewed": {
      "type": "plaay-recently-viewed",
      "settings": {
        "heading": "Previously viewed",
        "max_products": 6
      }
    }
  },
  "order": [
    "nlb_hero",
    "nlb_tiles",
    "main",
    "nlb_cred",
    "plaay_recently_viewed"
  ]
}
