type":"richtext","blocks":{"heading_AGyEP9":{"type":"heading","settings":{"heading":"LOVE AT FIRST BITE","color":"#ffffff","font_size_desktop":64,"font_size_mobile":40,"spacing_top_desktop":10,"spacing_bottom_desktop":10,"spacing_top_mobile":10,"spacing_bottom_mobile":10}}},"block_order":["heading_AGyEP9"],"name":"RichText","settings":{"bkg_color":"#021d49","full_width":true,"enable_style":false,"spacing_top_desktop":0,"spacing_bottom_desktop":0,"spacing_top_mobile":0,"spacing_bottom_mobile":0}},"review_gif_video_ncQhHx":{"type":"review_gif_video","blocks":{"image_fBXgHA":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/first-bite-1.gif","height":280,"review_text":"<p>This is literally the best! Has single-handedly eliminated my chocolate and doughnut cravings!!<\/p>","review_heading":"Yoga Instructor, Dubai","slider_bg_color":"rgba(0,0,0,0)","star_rating":5}},"image_ddGtem":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/firstbite5.gif","height":280,"review_text":"<p>Honestly, this is my no-brainer snack for crazy days. Tastes amazing, & keeps me going! <\/p>","review_heading":"Always-on CEO","slider_bg_color":"rgba(0,0,0,0)","star_rating":5}},"image_8LWUTT":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/first-bite-6.gif","height":280,"review_text":"<p>Favorite flavour hands down will be the peanut butter truffle! It just melts in your mouth!<\/p>","review_heading":"Creative Designer, Abu Dhabi","slider_bg_color":"rgba(0,0,0,0)","star_rating":5}},"image_qPrjNW":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/ezgif-3-8df9b851d4_a81fae6c-c3c9-4bfa-a352-c82a89a3a291.gif","height":280,"review_text":"<p>100% Hooked! Perfect snack after my runs—always hits the spot!<\/p>","review_heading":"Recreational Runner","slider_bg_color":"rgba(0,0,0,0)","star_rating":5}}},"block_order":["image_fBXgHA","image_ddGtem","image_8LWUTT","image_qPrjNW"],"settings":{"heading":"","text":"","per_view_desktop_large":4,"per_view_desktop":4,"per_view_tablet":3,"per_view_mobile":2,"autoplay_speed":0,"desktop_vertical_padding":13,"mobile_vertical_padding":5,"enable_style":false,"spacing_top_desktop":0,"spacing_bottom_desktop":0,"spacing_top_mobile":0,"spacing_bottom_mobile":0}},"product_faqs_TVU9wg":{"type":"product_faqs","blocks":{"faq_HhczM8":{"type":"faq","settings":{"title":"Why Plaay?","answer":"<p>Because chocolate shouldn’t be a trade-off. Most chocolates are loaded with refined sugar, cheap fillers, and ingredients that leave you bloated, sluggish, or guilty afterwards. We built Plaay to change that. Every product we make is 100% clean — that means:· No refined sugar (we use coconut sugar that’s gentler on your body).· No preservatives, artificial emulsifiers, or shady additives.· No soy, no gluten, no artificial sweeteners.· Only real, good-for-you ingredients your body actually knows how to process. The result? Chocolate that tastes as indulgent as your classics, but without the crash, the guilt, or the compromise.<\/p>"}},"faq_LED8q6":{"type":"faq","disabled":true,"settings":{"title":"","answer":"<p>Your answer here<\/p>"}},"faq_Q3RLeN":{"type":"faq","disabled":true,"settings":{"title":"Do you offer discounts?","answer":"<p>New here? Snack smarter. Get 25% off on your first order with code LETSPLAAY25.<\/p>"}},"faq_QbBBgf":{"type":"faq","disabled":true,"settings":{"title":"Do I need to set up an account? ","answer":"<p>You do not need to set up an account at Plaay. However, you will enjoy a lot of additional benefits if you register with us such as:  reviewing your purchase history, previewing our new products and receiving emails about our latest updates\/offers, saving your details such as your delivery address and payment details for a more convenient experience when you place your next order, tracking the status of your order and other requests.<\/p>"}},"faq_3reEfQ":{"type":"faq","settings":{"title":"Where are Plaay products made? ","answer":"<p>All our products are made in our own newly-established facilities in the UAE. <\/p>"}},"faq_8B8GFK":{"type":"faq","settings":{"title":"What dark chocolate does Plaay use?","answer":"<p>We make our in-house blend of 70% dark chocolate made with coconut nectar, cacao butter and sunflower lecithin.<\/p>"}},"faq_YfBmxR":{"type":"faq","settings":{"title":"What is the shelf-life of Plaay products? ","answer":"<p>The shelf-life of all Plaay products is 12 months. <br\/>The shelf life for limited edition products may vary.<\/p>"}},"faq_eMjRpx":{"type":"faq","settings":{"title":"Do Plaay products contain refined sugar?","answer":"<p>Not an ounce. We only use coconut nectar and dates. No refined sugar what so ever.<\/p>"}},"faq_qRyjCW":{"type":"faq","settings":{"title":"How should I store the chocolate truffles and bars? ","answer":"<p>Plaay products should be kept refrigerated to avoid melting and temperature fluctuations. Note: They are best consumed at Room Temperature.<\/p>"}},"faq_zwYX8T":{"type":"faq","disabled":true,"settings":{"title":"How can I track my order? ","answer":"<p>You will receive an order confirmation email containing your order reference number and other important details. You may call or email our customer support team and provide these details, so we can give you an update regarding your order. <\/p>"}},"faq_hR4rAU":{"type":"faq","disabled":true,"settings":{"title":"How do you ship your products? ","answer":"<p>We have our local logistics partners with temperature-controlled vehicles to make sure that your order arrives in perfect condition.<\/p>"}},"faq_QWRfR8":{"type":"faq","disabled":true,"settings":{"title":"Where are the packages shipped from? ","answer":"<p>All our products are shipped from our distribution center which is located in Business Bay & DIP Dubai, United Arab Emirates.<\/p>"}},"faq_6GKTFV":{"type":"faq","disabled":true,"settings":{"title":"Can I place an order through a phone call?  ","answer":"<p>All orders must be placed on our website. If you encounter technical issues while placing an order online, you may reach out to our customer support team for an assistance.<\/p>"}},"faq_a6n7ac":{"type":"faq","disabled":true,"settings":{"title":"Which payment methods does Plaay accept? ","answer":"<p>We accept online payments using MasterCard, Visa, and Apple Pay.<\/p>"}},"faq_7zm8VW":{"type":"faq","disabled":true,"settings":{"title":"How much does Plaay charge for the shipping?","answer":"<p>Shipping is free for all orders over AED 75. For smaller orders, we charge a delivery fee of AED 15.<\/p>"}},"faq_6htBaW":{"type":"faq","disabled":true,"settings":{"title":"Which countries does Plaay delivery service cover? ","answer":"<p>We currently deliver across UAE. We are also available in KSA via third-party online platforms. As for the rest of the world? Not yet… but we’re on our way!<\/p>"}},"faq_4pQmLx":{"type":"faq","disabled":true,"settings":{"title":"Can I add a message to my order and send it as a gift?  ","answer":"<p>Yes, you may inform us regarding this before placing your order or immediately after placing it. You may also write the message on the \"Delivery Instructions\" option upon checkout. Please note that the order will be sent with our regular packaging as we do not have gift wrappers at the moment. <\/p>"}},"faq_EHPTHL":{"type":"faq","disabled":true,"settings":{"title":"Can I put multiple delivery addresses for a single order? ","answer":"<p>You will need to place your order individually for each delivery address.<\/p>"}},"faq_6Ppy6U":{"type":"faq","disabled":true,"settings":{"title":"Is there a possibility that my order will not be fulfilled or will not be delivered on time? ","answer":"<p>We always make sure that all orders are processed and delivered on time. Delays happen very rarely, and if it does, we will certainly notify you at once and assist you should you require any modifications. <\/p>"}},"faq_PCkFKw":{"type":"faq","disabled":true,"settings":{"title":"Who can I contact if I encounter a technical issue while placing an order or if I have a query? ","answer":"<p>Should you require any assistance or you have any queries, please feel free to reach out to our customer support team at +971-56-996-9522 or send an email to hello@shopplaay.com (Monday - Saturday 9:00 AM till 5:00 PM, excluding holidays). <\/p>"}},"faq_b7chWw":{"type":"faq","disabled":true,"settings":{"title":"What should I do if the payment has been deducted from my card but there is no confirmation email? ","answer":"<p>Please share your name and registered email address with us to confirm your order and payment.<\/p>"}}},"block_order":["faq_HhczM8","faq_LED8q6","faq_Q3RLeN","faq_QbBBgf","faq_3reEfQ","faq_8B8GFK","faq_YfBmxR","faq_eMjRpx","faq_qRyjCW","faq_zwYX8T","faq_hR4rAU","faq_QWRfR8","faq_6GKTFV","faq_a6n7ac","faq_7zm8VW","faq_6htBaW","faq_4pQmLx","faq_EHPTHL","faq_6Ppy6U","faq_PCkFKw","faq_b7chWw"],"name":"Product FAQs","settings":{"title":"FAQs","background_color":"#f9c61d"}},"blocks_CfwrFk":{"type":"_blocks","blocks":{"ai_gen_block_9cfa683_DFcPGi":{"type":"ai_gen_block_9cfa683","settings":{"custom_html":"<style>\n.faq-ext{\nbackground:#F9C61D;\npadding:32px 0 40px;\ntext-align:center\n}\n.faq-ext a{\nfont-size:24px;\nfont-weight:600;\ncolor:#081D48;\ntext-decoration:underline\n}\n.faq-ext a:hover{opacity:.8}\n<\/style>\n\n<div class=\"faq-ext\">\n  <a href=\"https:\/\/shopplaay.com\/pages\/faqs\">Explore All FAQs →<\/a>\n<\/div>","desktop_width_percent":100,"padding":0,"background_color":"#ffffff","border_radius":0},"blocks":{}}},"block_order":["ai_gen_block_9cfa683_DFcPGi"],"custom_css":[],"settings":{}},"featured_products_XUGdAQ":{"type":"featured_products","blocks":{"product_KDJFDK":{"type":"product","settings":{"product":"pistachio-truffles-60g-1"}},"product_mmXJhU":{"type":"product","settings":{"product":"triple-chocolate-truffles-60g-1"}},"product_TmkFm3":{"type":"product","settings":{"product":"almond-brownie-truffles-60g-2"}},"product_Ky4Cmm":{"type":"product","settings":{"product":"peanut-butter-truff