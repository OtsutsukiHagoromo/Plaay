<div
  class="scrolling-content"
  style="background:{{ section.settings.background }}; padding-top:{{ section.settings.padding_top }}; padding-bottom:{{ section.settings.padding_bottom }}"
>
  <div
    class="section-{{ section.id }}-padding isolate{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
    {% if settings.animations_reveal_on_scroll %}
      data-cascade
    {% endif %}
  >
    <div class="scrolling-content-inner-row">
      <div class="scrolling-content-inner-col">
        <div class="scrolling-content-main-par-block">
          {% for block in section.blocks %}
            <div class="scrolling-content-main-block">
              {% if block.settings.image %}
                <div class="scrolling-content-icon-text">
                  {% if block.settings.image %}
                    <div class="scrolling-content-block-icon">
                      <img src="{{ block.settings.image | img_url:'master' }}">
                    </div>
                  {% endif %}
                  {% if block.settings.title != blank %}
                    <div class="scrolling-content-block-heading">
                      <p>{{ block.settings.title }}</p>
                    </div>
                  {% endif %}
                </div>
              {% endif %}
              {% if block.settings['image-2'] %}
