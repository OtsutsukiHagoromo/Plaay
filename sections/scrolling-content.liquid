<style>
  .scrolling-content-inner-row {
    width: 100%;
  }
  .scrolling-content-inner-col {
    width: 100%;
    overflow: hidden;
    padding: 10px 0;
    position: relative;
  }
  .scrolling-content-main-par-block {
    width: 100%;
    display: flex;
    align-items: stretch;
    height: auto;
    gap: 50px;
    white-space: nowrap;
    animation: scroll-left 12s linear infinite;
  }

  .scrolling-content-main-par-block:hover {
    animation-play-state: paused;
  }
  .scrolling-content-icon-text {
    min-width: fit-content;
    display: flex;
    align-items: center;
    gap: 50px;
  }
  .scrolling-content-main-block {
    min-width: fit-content;
    display: inline-block !important;
    font-size: 1.2rem;
    font-weight: bold;
    display: flex !important;
    gap: 50px;
  }
  .scrolling-content-block-icon img {
    width: 60px;
    height: 60px;
    border-radius: 100%;
  }
  .scrolling-content-block-heading p {
    font-size: 17px;
    color: #F9C61D;
    margin: 0;
    line-height: normal;
    font-weight: 400;
  }
  @keyframes scroll-left {
    0% {
      transform: translateX(-50%);
    }
    100% {
      transform: translateX(0%);
    }
  }
  @media screen and (max-width:768px){
    .scrolling-content-icon-text {
      gap: 20px;
    }
    .scrolling-content-main-block {
      gap: 30px;
    }
  }
</style>
{% schema %}
{
  "name": "Scrolling content",
  "class": "section",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color",
      "id": "background",
      "label": "Background",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "name": "Slide",
      "type": "slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Heading"
        },
        {
          "type": "image_picker",
          "id": "image-2",
          "label": "Image 2"
        },
        {
          "type": "text",
          "id": "title-2",
          "label": "Heading 2"
        },
        {
          "type": "image_picker",
          "id": "image-3",
          "label": "Image 3"
        },
        {
          "type": "text",
          "id": "title-3",
          "label": "Heading 3"
        },
        {
          "type": "image_picker",
          "id": "image-4",
          "label": "Image 4"
        },
        {
          "type": "text",
          "id": "title-4",
          "label": "Heading 4"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Scrolling content"
    }
  ]
}
{% endschema %}
