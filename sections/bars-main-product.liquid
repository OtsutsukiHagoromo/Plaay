<script>
(function() {
  function initStickyBars() {
    var inlineAtc = document.querySelector('.product_page_atc');
    var desktopBar = document.getElementById('plaay-sticky-atc');
    var mobileBar  = document.getElementById('plaay-sticky-mobile');
    if (!inlineAtc) return;

    var isMobile = function() { return window.innerWidth < 1024; };

    var baseStyle = 'position:fixed;bottom:0;left:0;right:0;z-index:9998;' +
                    'background:#fff;border-top:1px solid rgba(2,29,73,0.12);' +
                    'box-shadow:0 -4px 24px rgba(2,29,73,0.1);' +
                    'transition:transform 0.3s ease;transform:translateY(0);pointer-events:auto;';

    if (desktopBar) {
      desktopBar.setAttribute('style', baseStyle + 'padding:16px 0;display:none;');
    }
    if (mobileBar) {
      mobileBar.setAttribute('style', baseStyle + 'display:none;');
    }

    function showBar(bar) {
      if (!bar) return;
      bar.style.display = 'block';
      bar.style.transform = 'translateY(0)';
      bar.style.pointerEvents = 'auto';
    }
    function hideBar(bar) {
      if (!bar) return;
      bar.style.display = 'none';
      bar.style.transform = 'translateY(110%)';
      bar.style.pointerEvents = 'none';
    }

    function syncViewportBar() {
      if (isMobile()) {
        showBar(mobileBar);
        hideBar(desktopBar);
      } else {
        showBar(desktopBar);
        hideBar(mobileBar);
      }
    }
    syncViewportBar();
    window.addEventListener('resize', syncViewportBar);

    function getVisibleText(selector) {
      var nodes = document.querySelectorAll(selector);
      for (var i = 0; i < nodes.length; i++) {
        var text = (nodes[i].textContent || '').trim();
        if (!text) continue;
        var styles = window.getComputedStyle(nodes[i]);
        if (styles.display === 'none' || styles.visibility === 'hidden') continue;
        return text;
      }
      return '';
    }

    var getPriceEl = function() {
      return document.querySelector('.product_page_atc .product_discount_price') ||
             document.querySelector('.product_page_atc .product_price') ||
             document.querySelector('.product_discount_price') ||
             document.querySelector('.product_price');
    };
    var syncPrice = function() {
      var el = getPriceEl();
      var txt = el ? el.textContent.trim() : '';
      if (!txt) return;
      var dp  = desktopBar && desktopBar.querySelector('.plaay-sticky-price');
      var mp  = mobileBar  && mobileBar.querySelector('.plaay-sticky-mobile-price');
      if (dp) dp.textContent = txt;
      if (mp) mp.textContent = txt;
    };
    syncPrice();
    document.querySelectorAll('.product_discount_price,.product_price').forEach(function(el) {
      new MutationObserver(syncPrice).observe(el, { childList: true, subtree: true, characterData: true });
    });

    function setCompare(compareEl, text) {
      if (!compareEl) return;
      if (text) {
        compareEl.textContent = text;
        compareEl.style.display = '';
      } else {
        compareEl.style.display = 'none';
      }
    }

    function buildStickyFrequencyOptions() {
      var sourceButtons = Array.prototype.slice.call(document.querySelectorAll('.plaay-sub-freq__opt'));
      [desktopBar, mobileBar].forEach(function(bar) {
        if (!bar) return;
        var optionsWrap = bar.querySelector('.plaay-sticky-frequency-options');
        if (!optionsWrap) return;
        optionsWrap.innerHTML = '';
        sourceButtons.forEach(function(sourceBtn) {
          var optionBtn = document.createElement('button');
          optionBtn.type = 'button';
          optionBtn.className = 'plaay-sticky-frequency-option' + (sourceBtn.classList.contains('active') ? ' active' : '');
          optionBtn.textContent = sourceBtn.textContent.trim();
          optionBtn.addEventListener('click', function() {
            sourceBtn.click();
            buildStickyFrequencyOptions();
            setTimeout(syncPurchaseState, 0);
          });
          optionsWrap.appendChild(optionBtn);
        });
      });
    }

    function bindStickyFrequencyControls() {
      [desktopBar, mobileBar].forEach(function(bar) {
        if (!bar) return;
        var toggle = bar.querySelector('.plaay-sticky-frequency-toggle');
        var optionsWrap = bar.querySelector('.plaay-sticky-frequency-options');
        if (!toggle || !optionsWrap || toggle.dataset.bound === 'true') return;
        toggle.dataset.bound = 'true';
        toggle.addEventListener('click', function() {
          var isOpen = optionsWrap.style.display === 'flex';
          optionsWrap.style.display = isOpen ? 'none' : 'flex';
          toggle.textContent = isOpen ? 'Change' : 'Hide';
        });
      });
    }
    buildStickyFrequencyOptions();
    bindStickyFrequencyControls();

    function compactStickyBenefits(text) {
      return (text || '')
        .replace(/Free Shipping/ig, 'Free shipping')
        .replace(/15%\s*Off\s*Regular\s*Price/ig, '15% off')
        .replace(/Skip\s*Cancel\s*Anytime/ig, 'Skip anytime')
        .replace(/\s*·\s*/g, ' · ')
        .replace(/\s+/g, ' ')
        .trim();
    }

    function syncPurchaseState() {
      var subWrap = document.querySelector('.plaay-sub-wrap');
      var isSubscription = !!document.querySelector('#plaay-tab-subscribe.plaay-sub-tab--active');
      var oneTimeText = (document.querySelector('.plaay-sub-tab__price') || {}).textContent || '';
      var subscribeText = (document.querySelector('.plaay-sub-tab__disc-price') || {}).textContent || '';
      var activePlan = document.querySelector('.plaay-sub-freq__opt.active');
      var currentPrice = (isSubscription ? subscribeText : oneTimeText).trim();
      var planLabel = isSubscription && activePlan ? ('Delivery every ' + activePlan.textContent.trim()) : '';
      var benefitLabel = isSubscription && subWrap ? compactStickyBenefits((subWrap.getAttribute('data-sticky-benefits') || '').trim()) : '';
      var modeText = isSubscription ? 'Subscribe & Save' : 'One-Time Purchase';
      var submitLabel = isSubscription ? 'Subscribe now' : '{{ "product.add_to_cart.add_to_bag" | t }}';
      var compareText = '';

      if (!currentPrice) {
        currentPrice = getVisibleText('.product_discount_price');
      }
      if (!currentPrice) {
        currentPrice = (desktopBar && desktopBar.querySelector('.plaay-sticky-price') ? desktopBar.querySelector('.plaay-sticky-price').textContent : '').trim();
      }

      if (isSubscription && oneTimeText.trim() && oneTimeText.trim() !== currentPrice) {
        compareText = oneTimeText.trim();
      } else {
        compareText = getVisibleText('.product_price, .discount_price_exists');
      }

      [desktopBar, mobileBar].forEach(function(bar) {
        if (!bar) return;
        var modeEl = bar.querySelector('.plaay-sticky-mode');
        var planRowEl = bar.querySelector('.plaay-sticky-plan-row');
        var planEl = bar.querySelector('.plaay-sticky-plan');
        var benefitsEl = bar.querySelector('.plaay-sticky-benefits');
        var frequencyToggle = bar.querySelector('.plaay-sticky-frequency-toggle');
        var frequencyOptions = bar.querySelector('.plaay-sticky-frequency-options');
        var priceEl = bar.querySelector('.plaay-sticky-price, .plaay-sticky-mobile-price');
        var compareEl = bar.querySelector('.plaay-sticky-compare');
        var submitEl = bar.querySelector('.plaay-sticky-submit, .plaay-mobile-submit');

        if (modeEl) modeEl.textContent = modeText;
        if (planRowEl) {
          planRowEl.style.display = planLabel ? 'flex' : 'none';
        }
        if (planEl) {
          if (planLabel) {
            planEl.textContent = planLabel;
          } else {
            planEl.textContent = '';
          }
        }
        if (frequencyOptions && !planLabel) {
          frequencyOptions.style.display = 'none';
        }
        if (frequencyToggle) {
          frequencyToggle.textContent = 'Change';
          frequencyToggle.style.display = planLabel ? '' : 'none';
        }
        if (benefitsEl) {
          if (benefitLabel) {
            benefitsEl.textContent = benefitLabel;
            benefitsEl.style.display = '';
          } else {
            benefitsEl.textContent = '';
            benefitsEl.style.display = 'none';
          }
        }
        if (priceEl && currentPrice) priceEl.textContent = currentPrice;
        setCompare(compareEl, compareText);
        if (submitEl && currentPrice) submitEl.textContent = currentPrice + ' | ' + submitLabel;
      });
      buildStickyFrequencyOptions();
    }
    syncPurchaseState();
    document.addEventListener('plaay:purchase-state-changed', syncPurchaseState);
    document.addEventListener('plaay:variant-changed', function() {
      syncPrice();
      syncPurchaseState();
    });
    document.querySelectorAll('#plaay-tab-onetime, #plaay-tab-subscribe, [data-quick-add-selling-plan]').forEach(function(trigger) {
      trigger.addEventListener('click', function() {
        setTimeout(syncPurchaseState, 0);
      });
    });

    var qty = parseInt((document.querySelector('quick-add input[name="quantity"],input[name="quantity"]') || {}).value, 10) || 1;
    var qtyDisplay = desktopBar && desktopBar.querySelector('.plaay-sticky-qty');
    var inlineQtyInput = document.querySelector('quick-add input[name="quantity"],input[name="quantity"]');
    var mobileQtyDisplay = mobileBar && mobileBar.querySelector('.plaay-mobile-qty');

    function renderQty() {
      if (qtyDisplay) qtyDisplay.textContent = qty;
      if (mobileQtyDisplay) mobileQtyDisplay.textContent = qty;
      if (inlineQtyInput) inlineQtyInput.value = qty;
    }
    renderQty();

    if (desktopBar) {
      desktopBar.querySelector('.plaay-sticky-minus').addEventListener('click', function() {
        if (qty > 1) { qty--; renderQty(); }
      });
      desktopBar.querySelector('.plaay-sticky-plus').addEventListener('click', function() {
        qty++; renderQty();
      });
      desktopBar.querySelector('.plaay-sticky-submit').addEventListener('click', function() {
        renderQty();
        inlineAtc.click();
      });
    }

    if (mobileBar) {
      mobileBar.querySelector('.plaay-mobile-minus').addEventListener('click', function() {
        if (qty > 1) { qty--; renderQty(); }
      });
      mobileBar.querySelector('.plaay-mobile-plus').addEventListener('click', function() {
        qty++; renderQty();
      });
      mobileBar.querySelector('.plaay-mobile-submit').addEventListener('click', function() {
        renderQty();
        inlineAtc.click();
      });
    }

    var mobileVariantEl = mobileBar && mobileBar.querySelector('.plaay-sticky-mobile-variant');
    if (mobileVariantEl) {
      var variantSel = document.querySelector('select#productSelect,select[name="id"]');
      if (variantSel) {
        variantSel.addEventListener('change', function() {
          var opt = variantSel.options[variantSel.selectedIndex];
          if (opt) mobileVariantEl.textContent = opt.text.split(' - ')[0].trim();
        });
      }
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initStickyBars);
  } else {
    initStickyBars();
  }
})();
</script>

{% if product_images_size > 1 %}
  <script type="module">
    document.addEventListener("DOMContentLoaded", () => {
      const productGallerySlider = new Glide("#product-gallery-{{ section.id }}", {
        type: 'carousel',
        perView: 1,
        startAt: 0,
        focusAt: 'center'
      });
      const productGalleryThumbnailsSlider = new Glide("#product-gallery-thumbnails-{{ section.id }}", {
        type: 'carousel',
        perView: 4,
        startAt: 0
      });
      productGallerySlider.mount({ });
      productGalleryThumbnailsSlider.mount({ });

      productGallerySlider.on("run", (e) => {
        productGalleryThumbnailsSlider.go(e.direction);
      });
      productGalleryThumbnailsSlider.on("run", (e) => {
        productGallerySlider.go(e.direction);
      });
      document.querySelectorAll('.thumbnail_slide').forEach(el => {
        el.addEventListener('click', (e) => {
          productGallerySlider.go('=' + `${e.target.dataset.index}`);
          productGalleryThumbnailsSlider.go('=' + `${e.target.dataset.index}`);
        });
      });
    });
  </script>
{% endif %}

