{% liquid
  assign background_color = section.settings.background_color
  assign show_description = section.settings.show_description
  assign show_exact_ingredients = section.settings.show_exact_ingredients

  assign exact_ingredients = product.metafields.arena.exact_ingredients
  assign subtitle_text = product.metafields.arena.subtitle_text

  assign bar_calories = product.metafields.arena.calories
  assign bar_protein  = product.metafields.arena.protein
  assign bar_carbs    = product.metafields.arena.carbs
  assign bar_fats     = product.metafields.arena.fats

  assign allergens = product.metafields.arena.allergens

  assign product_images_size = product.images | size
%}

{% style %}
  /* ─── Thumbnail active state ─── */
  #product-gallery-thumbnails-{{ section.id }} .glide__slide--active img {
    border: 2px solid #FFF;
  }

  /* ─── Nutritional Highlights Strip ─── */
  .bars-nutrition-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: 16px 0 4px;
  }
  .bars-nutrition-tile {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    flex: 1 1 calc(25% - 10px);
    min-width: 72px;
    background: #fff;
    border-radius: 14px;
    padding: 12px 8px 10px;
    border: 1.5px solid rgba(2,29,73,0.10);
  }
  .bars-nutrition-icon-circle {
    width: 44px;
    height: 44px;
    background: #F9C61D;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 8px;
    flex-shrink: 0;
  }
  .bars-nutrition-icon-circle svg {
    width: 22px;
    height: 22px;
    fill: #021D49;
  }
  .bars-nutrition-value {
    font-family: var(--font-walsheim-black, 'GT Walsheim', sans-serif);
    font-weight: 900;
    font-size: 17px;
    color: #021D49;
    line-height: 1.1;
  }
  .bars-nutrition-label {
    font-family: var(--font-walsheim-regular, 'GT Walsheim', sans-serif);
    font-size: 11px;
    color: #021D49;
    opacity: 0.65;
    margin-top: 2px;
    text-align: center;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }
  @media (max-width: 480px) {
    .bars-nutrition-tile { flex: 1 1 calc(50% - 10px); }
  }

  /* ─── Weight / Size Pill Variants ─── */
  .bars-weight-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 6px 0 4px;
  }
  .bars-weight-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 8px 18px;
    border-radius: 999px;
    border: 1.5px solid #021D49;
    background: transparent;
    color: #021D49;
    font-family: var(--font-walsheim-bold, 'GT Walsheim', sans-serif);
    font-size: 14px;
    cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
    line-height: 1;
  }
  .bars-weight-pill:hover {
    background: #F9C61D;
    border-color: #F9C61D;
    color: #021D49;
  }
  .bars-weight-pill.is-selected {
    background: #F9C61D;
    border-color: #F9C61D;
    color: #021D49;
  }
  .bars-weight-pill.is-unavailable {
    opacity: 0.38;
    cursor: default;
    pointer-events: none;
  }
  .bars-weight-pills-label {
    font-family: var(--font-walsheim-bold, 'GT Walsheim', sans-serif);
    font-size: 13px;
    color: #021D49;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 6px;
  }

  /* ─── Allergen Banner ─── */
  .bars-allergen-banner {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    background: #021D49;
    color: #fff;
    border-radius: 10px;
    padding: 12px 16px;
    margin-top: 14px;
    margin-bottom: 4px;
  }
  .bars-allergen-icon {
    font-size: 18px;
    line-height: 1.3;
    flex-shrink: 0;
  }
  .bars-allergen-text {
    font-family: var(--font-walsheim-regular, 'GT Walsheim', sans-serif);
    font-size: 13px;
    line-height: 1.5;
    color: #fff;
  }
  .bars-allergen-text strong {
    font-family: var(--font-walsheim-bold, 'GT Walsheim', sans-serif);
    display: block;
    margin-bottom: 2px;
    font-size: 13px;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  /* ─── Offer Callout Block ─── */
  .product-block-offer-callout {
    display: flex;
    align-items: center;
    justify-content: center;
    max-width: 600px;
    margin: 15px auto;
    height: 62px;
    background: #FECE55;
    border-top: 2px solid #404040;
    border-bottom: 2px solid #404040;
    position: relative;
    font-family: inherit;
  }
  .product-block-offer-callout .larg {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 0 15px;
    flex: 1;
    height: 100%;
  }
  .product-block-offer-callout .lightning svg {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }
  .product-block-offer-callout .bloc p,
  .product-block-offer-callout .bloc h6 {
    margin: 0;
    line-height: 1.3;
    color: #404040;
  }
  .product-block-offer-callout .bloc p {
    font-weight: bold;
    font-size: 1.1em;
  }
  .product-block-offer-callout .bloc h6 {
    font-size: 0.9em;
    font-weight: normal;
  }
  .product-block-offer-callout .oc-copy {
    font-weight: bold;
  }
  .product-block-offer-callout .clip-left {
    position: absolute;
    left: -15px;
  }
  .product-block-offer-callout .clip-right {
    position: absolute;
    right: -15px;
  }
  @media (max-width: 768px) {
    .product-block-offer-callout {
      max-width: 90%;
      height: 62px;
      margin: 10px auto;
    }
    .product-block-offer-callout .larg { gap: 8px; padding: 0 10px; justify-content: center; }
    .product-block-offer-callout .bloc p { font-size: 1em; }
    .product-block-offer-callout .bloc h6 { font-size: 0.8em; }
    .product-block-offer-callout .lightning svg { width: 18px; height: 18px; }
  }
  @media (max-width: 480px) {
    .product-block-offer-callout {
      height: 62px;
      flex-wrap: wrap;
      padding: 4px 0;
    }
    .product-block-offer-callout .larg {
      flex-direction: column;
      text-align: center;
      gap: 1px;
      justify-content: center;
    }
    .product-block-offer-callout .clip-left { position: absolute; left: -15px; }
    .product-block-offer-callout .clip-right { position: absolute; right: -15px; }
    .product-block-offer-callout .bloc p { font-size: 0.9em; }
    .product-block-offer-callout .bloc h6 { font-size: 0.75em; }
  }
{% endstyle %}

<quantity-adjuster data-module="quantity-adjuster">
  <div class="hidden"></div>
</quantity-adjuster>
<quick-add data-module="quick-add"></quick-add>

<div style="background-color: {{ background_color }};">
  <div class="container flex flex-col py-14 | md:pb-16 md:pt-44 | lg:flex-row">

    {% comment %} ── Main product gallery ── {% endcomment %}
    <div class="w-full relative | lg:w-[55%]">
      {%- render 'plaay-badge', product: product -%}
      <div {% if product_images_size > 1 %} class="glide" {% endif %} id="product-gallery-{{ section.id }}">
        {% if product_images_size > 1 %}
          <div class="glide__arrows z-10 flex items-center justify-center w-full | lg:mb-0 lg:mt-0 lg:ml-10 lg:w-auto" data-glide-el="controls">
            <button data-glide-dir="<" class="glide__arrow glide__arrow--left text-0 group absolute z-1 left-0 top-1/2 transform -translate-y-1/2 mr-5 | lg:-left-8">
              slide left
              <span class="flex h-6 w-6 transform rotate-180 text-dark-blue transition-all duration-200 | group-hover:opacity-100">
                {% render 'icon-slider-arrow' %}
              </span>
            </button>
            <button data-glide-dir=">" class="glide__arrow glide__arrow--right text-0 group absolute right-0 z-1 top-1/2 transform -translate-y-1/2 ml-5 | lg:-right-8">
              slide right
              <span class="flex h-6 w-6 text-dark-blue transition-all duration-200 | group-hover:opacity-100">
                {% render 'icon-slider-arrow' %}
              </span>
            </button>
          </div>
        {% endif %}
        <div {% if product_images_size > 1 %} class="glide__track w-full max-w-[800px] mx-auto" data-glide-el="track" {% endif %}>
          <ul {% if product_images_size > 1 %} class="glide__slides" {% endif %}>
            {% for image in product.images %}
              <li {% if product_images_size > 1 %} class="glide__slide px-8 | md:px-0" {% endif %} data-index="{{ forloop.index0 }}">
                {% render 'img', type: 'img', img: image, eager: true, class: 'object-contain h-[420px] mx-auto lg:w-full lg:h-[600px] xl:object-cover', height: 420, width: 550, forloop_data: forloop.index %}
              </li>
            {% endfor %}
          </ul>
        </div>
        {% if product_images_size > 1 %}
          <div class="glide__bullets flex items-center justify-center my-5 | md:hidden" data-glide-el="controls[nav]">
            {% for image in product.images %}
              <button class="glide__bullet h-4 w-4 bg-dark-blue opacity-50 rounded-full transition-all duration-200 {% unless forloop.first %} ml-3 {% endunless %}" data-glide-dir="={{ forloop.index0 }}"></button>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      {% comment %} ── Thumbnail slider ── {% endcomment %}
      {% if product_images_size > 1 %}
        <div class="glide mt-2 max-w-md mx-auto hidden | md:block" id="product-gallery-thumbnails-{{ section.id }}">
          <div class="glide__arrows z-10 flex items-center justify-center w-full mt-8 mb-14 | md:mb-0 md:mt-0 md:ml-10 md:w-auto" data-glide-el="controls">
            <button data-glide-dir="<" class="glide__arrow glide__arrow--left text-0 group absolute -left-16 top-1/2 transform -translate-y-1/2 mr-5 | lg:-left-8">
              slide left
              <span class="flex h-6 w-6 transform rotate-180 text-dark-blue opacity-30 transition-all duration-200 | group-hover:opacity-100">
                {% render 'icon-slider-arrow' %}
              </span>
            </button>
            <button data-glide-dir=">" class="glide__arrow glide__arrow--right text-0 group absolute -right-16 top-1/2 transform -translate-y-1/2 ml-5 | lg:-right-8">
              slide right
              <span class="flex h-6 w-6 text-dark-blue opacity-30 transition-all duration-200 | group-hover:opacity-100">
                {% render 'icon-slider-arrow' %}
              </span>
            </button>
          </div>
          <div class="glide__track max-w-[380px] mx-auto" data-glide-el="track">
            <ul class="glide__slides">
              {% for image in product.images %}
                <li class="glide__slide thumbnail_slide">
                  <div class="block h-20 w-20 border-0.5 border-opacity-20 border-black">
                    {% render 'img', type: 'img', img: image, eager: true, class: 'object-contain mx-auto h-full cursor-pointer w-full', forloop_data: forloop.index0 %}
                  </div>
                </li>
              {% endfor %}
            </ul>
          </div>
        </div>
      {% endif %}
    </div>

    {% comment %} ── Product information column ── {% endcomment %}
    <div class="w-full mt-5 | lg:mt-0 lg:w-1/2 lg:flex lg:flex-col lg:justify-center lg:max-w-md lg:ml-10 | xl:ml-14 | 2xl:ml-20">

      {% comment %} Title row with badge + wishlist {% endcomment %}
      <div class="plaay-pdp-title-row">
        {%- render 'plaay-badge', product: product, inline: true -%}
        <h1 class="text-5xl leading-none uppercase text-dark-blue font-walsheim-bold pdp-title">{{ product.title }}</h1>
        {%- render 'plaay-wishlist-heart', product: product, style: 'pdp' -%}
      </div>

      {% comment %} ── Offer Callout Block ── {% endcomment %}
      {% for block in section.blocks %}
        {% if block.type == 'offer_callout' %}
          <div class="product-block-offer-callout" {{ block.shopify_attributes }}>
            <svg class="clip-left" width="27" height="62" viewBox="0 0 27 62" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M5 1H26V61H20H3L11.5 52L2 48.4C4.66667 46 9.9 41.2 9.5 41.2C9.1 41.2 5.33333 37.6 3.5 35.8L11 28L4.5 23.8L9.5 17.2L5 12.4L10.5 7.6L5 1Z" fill="#FECE55" stroke="#404040" stroke-width="2"></path>
              <rect x="24" y="2" width="6" height="58" fill="#FECE55"></rect>
            </svg>
            <div class="larg">
              <div class="bloc">
                <p><span class="oc-copy">{{ block.settings.coupon_text }}</span></p>
              </div>
            </div>
            <svg class="clip-right" width="27" height="62" viewBox="0 0 27 62" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M22 61H1L1 0.999996H7H24L15.5 10L25 13.6C22.3333 16 17.1 20.8 17.5 20.8C17.9 20.8 21.6667 24.4 23.5 26.2L16 34L22.5 38.2L17.5 44.8L22 49.6L16.5 54.4L22 61Z" fill="#FECE55" stroke="#404040" stroke-width="2"></path>
              <rect y="2" width="3" height="58" fill="#FECE55"></rect>
            </svg>
          </div>
        {% endif %}
      {% endfor %}

      {% if subtitle_text != blank %}
        <p class="my-3 text-sm text-dark-blue">{{ subtitle_text }}</p>
      {% endif %}

      {% render 'product-price', product: product %}

      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when '@app' -%}
            {% render block %}
        {% endcase %}
      {% endfor %}
      {%- render 'plaay-trust-badges', product: product, preset: 'bars-truffles-icons' -%}

      {% comment %} Discount text block {% endcomment %}
      <div class="main-discount-wrapper">
        {% for block in section.blocks %}
          {% if block.type == 'discount' and block.settings.show_discount_text %}
            <div class="disc-top-curve disc disc-main-text">
              {{ block.settings.discount_prefix }}
              <span style="color: {{ block.settings.highlight_color }};">
                {{ block.settings.discount_highlight }}
              </span>
            </div>
          {% endif %}
        {% endfor %}
      </div>


      {% comment %} ── BARS ENHANCEMENT 2: Weight / Size Pill Variant Selector ── {% endcomment %}
      {%- liquid
        assign weight_option_index = nil
        assign weight_option_name  = nil
        for option in product.options_with_values
          assign opt_lower = option.name | downcase
          if opt_lower == 'size' or opt_lower == 'weight' or opt_lower == 'bar size'
            assign weight_option_index = forloop.index0
            assign weight_option_name  = option.name
            break
          endif
        endfor
        assign first_weight_value = product.options_with_values[weight_option_index].values | first
        if first_weight_value != nil
          assign weight_looks_like_size = false
          for val in product.options_with_values[weight_option_index].values
            assign val_str = val | downcase
            if val_str contains 'g' or val_str contains 'kg' or val_str contains 'oz' or val_str contains 'ml'
              assign weight_looks_like_size = true
              break
            endif
          endfor
        endif
      -%}

      {% if weight_option_index != nil and weight_looks_like_size %}
        {% comment %} Render pill buttons for the weight/size option {% endcomment %}
        <div class="bars-weight-pills-wrap" style="margin-bottom: 10px;">
          <p class="bars-weight-pills-label">{{ weight_option_name }}</p>
          <div class="bars-weight-pills" id="bars-weight-pills-{{ section.id }}" data-option-index="{{ weight_option_index }}">
            {%- assign current_weight_value = product.selected_or_first_available_variant.options[weight_option_index] -%}
            {%- for opt_val in product.options_with_values[weight_option_index].values -%}
              {%- liquid
                assign pill_variant_available = false
                for variant in product.variants
                  if variant.options[weight_option_index] == opt_val
                    if variant.available
                      assign pill_variant_available = true
                    endif
                    break
                  endif
                endfor
              -%}
              <button
                type="button"
                class="bars-weight-pill{% if opt_val == current_weight_value %} is-selected{% endif %}{% unless pill_variant_available %} is-unavailable{% endunless %}"
                data-value="{{ opt_val | escape }}"
                aria-label="{{ weight_option_name }}: {{ opt_val }}"
                {% unless pill_variant_available %}aria-disabled="true"{% endunless %}>
                {{ opt_val }}
              </button>
            {%- endfor -%}
          </div>
        </div>
        <script>
        (function() {
          var pillsWrap = document.getElementById('bars-weight-pills-{{ section.id }}');
          if (!pillsWrap) return;
          var optIdx = parseInt(pillsWrap.dataset.optionIndex, 10);
          var pills  = pillsWrap.querySelectorAll('.bars-weight-pill');

          function getVariantSelect() {
            return document.querySelector('select#productSelect, select[name="id"], select.product-select');
          }
          function getSingleOptionSelects() {
            return document.querySelectorAll('.single-option-selector, .single_option_selector, [data-single-option-selector]');
          }

          pills.forEach(function(pill) {
            pill.addEventListener('click', function() {
              var val = pill.dataset.value;
              // Update active pill UI
              pills.forEach(function(p) { p.classList.remove('is-selected'); });
              pill.classList.add('is-selected');

              // Attempt to sync with Shopify variant selector (native or custom)
              var singleSelects = getSingleOptionSelects();
              if (singleSelects.length > 0 && singleSelects[optIdx]) {
                singleSelects[optIdx].value = val;
                singleSelects[optIdx].dispatchEvent(new Event('change', { bubbles: true }));
              } else {
                // Fallback: find matching variant in the main select by option value
                var mainSel = getVariantSelect();
                if (mainSel) {
                  for (var i = 0; i < mainSel.options.length; i++) {
                    var opt = mainSel.options[i];
                    if (opt.text.toLowerCase().indexOf(val.toLowerCase()) !== -1) {
                      mainSel.value = opt.value;
                      mainSel.dispatchEvent(new Event('change', { bubbles: true }));
                      break;
                    }
                  }
                }
              }
            });
          });

          // Keep pills in sync if variant changes externally (e.g. from another option)
          document.addEventListener('change', function(e) {
            if (e.target && e.target.matches('select#productSelect, select[name="id"], select.product-select')) {
              var selOpt = e.target.options[e.target.selectedIndex];
              if (!selOpt) return;
              var optText = selOpt.text;
              pills.forEach(function(p) {
                if (optText.toLowerCase().indexOf(p.dataset.value.toLowerCase()) !== -1) {
                  pills.forEach(function(pp) { pp.classList.remove('is-selected'); });
                  p.classList.add('is-selected');
                }
              });
            }
          });
        })();
        </script>
      {% endif %}
      {% comment %} ── END Weight Pill Variant Selector ── {% endcomment %}

      {% comment %} Flavour / other variant selector (dropdown, not weight/size) {% endcomment %}
      <div class="choose-flovor">
        {% render 'flavor-option', variant_selector_style: section.settings.variant_selector_style %}
      </div>

      {% render 'product.add-to-cart', product: product, show_subscribe: section.settings.enable_subscribe_push, hide_inline_atc: true, hide_inline_quantity: true %}
      {%- render 'plaay-delivery-promise' -%}

      {% comment %} ── PDP Info Tabs ── {% endcomment %}
      {%- liquid
        assign first_tab = 'shipping'
        if exact_ingredients != blank
          assign first_tab = 'ingredients'
        endif
        if product.description != blank
          assign first_tab = 'info'
        endif
        assign sid = section.id
      -%}
      <div class="plaay-pdp-tabs" id="plaay-pdp-tabs-{{ sid }}">

        <div class="plaay-pdp-tabs__nav" role="tablist" aria-label="Product details">
          {% if product.description != blank %}
            <button
              class="plaay-pdp-tabs__tab{% if first_tab == 'info' %} is-active{% endif %} font-walsheim-bold"
              role="tab"
              data-tab="info-{{ sid }}"
              aria-selected="{% if first_tab == 'info' %}true{% else %}false{% endif %}">
              {{ section.settings.tab_info_label | default: 'Product Info' }}
            </button>
          {% endif %}
          {% if exact_ingredients != blank %}
            <button
              class="plaay-pdp-tabs__tab{% if first_tab == 'ingredients' %} is-active{% endif %} font-walsheim-bold"
              role="tab"
              data-tab="ingredients-{{ sid }}"
              aria-selected="{% if first_tab == 'ingredients' %}true{% else %}false{% endif %}">
              {{ section.settings.tab_ingredients_label | default: 'Ingredients' }}
            </button>
          {% endif %}
          <button
            class="plaay-pdp-tabs__tab{% if first_tab == 'shipping' %} is-active{% endif %} font-walsheim-bold"
            role="tab"
            data-tab="shipping-{{ sid }}"
            aria-selected="{% if first_tab == 'shipping' %}true{% else %}false{% endif %}">
            {{ section.settings.tab_shipping_label | default: 'Shipping & Returns' }}
          </button>
        </div>

        {% if product.description != blank %}
          <div
            class="plaay-pdp-tabs__panel{% unless first_tab == 'info' %} is-hidden{% endunless %} rte font-walsheim text-dark-blue"
            data-panel="info-{{ sid }}"
            role="tabpanel">
            {{ product.description }}
          </div>
        {% endif %}

        {% if exact_ingredients != blank %}
          <div
            class="plaay-pdp-tabs__panel{% unless first_tab == 'ingredients' %} is-hidden{% endunless %} font-walsheim text-dark-blue"
            data-panel="ingredients-{{ sid }}"
            role="tabpanel">
            {{ exact_ingredients }}
          </div>
        {% endif %}

        <div
          class="plaay-pdp-tabs__panel{% unless first_tab == 'shipping' %} is-hidden{% endunless %} rte font-walsheim text-dark-blue"
          data-panel="shipping-{{ sid }}"
          role="tabpanel">
          {% if section.settings.shipping_returns_content != blank %}
            {{ section.settings.shipping_returns_content }}
          {% else %}
            <p><strong>Free delivery</strong> on all orders over AED 75.</p>
            <p>Delivery takes 1–2 business days across the UAE.</p>
            <p><strong>Returns:</strong> We accept returns within 7 days for unopened, undamaged items. Email hello@shopplaay.com to initiate.</p>
          {% endif %}
        </div>

      </div>

      <script>
      (function(){
        var wrap = document.getElementById('plaay-pdp-tabs-{{ sid }}');
        if (!wrap) return;
        var nav = wrap.querySelector('.plaay-pdp-tabs__nav');
        var tabs   = wrap.querySelectorAll('.plaay-pdp-tabs__tab');
        var panels = wrap.querySelectorAll('.plaay-pdp-tabs__panel');
        function focusActiveTab(tab) {
          if (!nav || !tab || typeof tab.scrollIntoView !== 'function') return;
          tab.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
        }
        tabs.forEach(function(tab) {
          tab.addEventListener('click', function() {
            tabs.forEach(function(t){ t.classList.remove('is-active'); t.setAttribute('aria-selected','false'); });
            panels.forEach(function(p){ p.classList.add('is-hidden'); });
            tab.classList.add('is-active');
            tab.setAttribute('aria-selected','true');
            var panel = wrap.querySelector('[data-panel="' + tab.dataset.tab + '"]');
            if (panel) panel.classList.remove('is-hidden');
            focusActiveTab(tab);
          });
        });
      })();
      </script>
      {% comment %} end PDP Info Tabs {% endcomment %}

      {% comment %} ── BARS ENHANCEMENT 3: Allergen Banner ── {% endcomment %}
      {% if allergens != blank %}
        <div class="bars-allergen-banner" role="note" aria-label="Allergen information">
          <span class="bars-allergen-icon">⚠️</span>
          <div class="bars-allergen-text">
            <strong>Allergen Info</strong>
            {{ allergens }}
          </div>
        </div>
      {% endif %}
      {% comment %} ── END Allergen Banner ── {% endcomment %}

    </div>
  </div>
</div>

