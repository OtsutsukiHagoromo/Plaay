{% liquid
  assign background_color = section.settings.background_color
  assign show_description = section.settings.show_description
  assign show_exact_ingredients = section.settings.show_exact_ingredients

  assign usp_images = product.metafields.custom.usp_image.value
  assign usp_text = product.metafields.arena.usp_text.value
  assign exact_ingredients = product.metafields.arena.exact_ingredients
  assign subtitle_text = product.metafields.arena.subtitle_text

  assign product_images_size = product.images | size

  assign gift_ready = product.metafields.arena.gift_ready | downcase
%}

{% style %}
  #product-gallery-thumbnails-{{ section.id }} .glide__slide--active img{
    border: 2px solid #FFF;
  }

  /* ── Gifting toggle ── */
  .plaay-gift-toggle-row {
    display: flex;
    align-items: center;
    margin: 16px 0;
  }
  .plaay-gift-toggle {
    display: flex;
    align-items: center;
    gap: 10px;
    cursor: pointer;
  }
  .plaay-gift-check {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
    pointer-events: none;
  }
  .plaay-gift-toggle__slider {
    display: inline-block;
    width: 44px;
    height: 24px;
    background: rgba(2,29,73,0.15);
    border-radius: 999px;
    position: relative;
    flex-shrink: 0;
    transition: background 0.22s ease;
  }
  .plaay-gift-toggle__slider::after {
    content: '';
    position: absolute;
    top: 3px;
    left: 3px;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: #fff;
    box-shadow: 0 1px 4px rgba(2,29,73,0.18);
    transition: transform 0.22s ease;
  }
  .plaay-gift-toggle.is-on .plaay-gift-toggle__slider {
    background: #021D49;
  }
  .plaay-gift-toggle.is-on .plaay-gift-toggle__slider::after {
    transform: translateX(20px);
  }
  .plaay-gift-toggle__label {
    font-size: 0.9rem;
    color: #021D49;
  }

  /* ── Gift message wrap ── */
  .plaay-gift-message-wrap {
    padding: 14px 16px;
    background: #f4f4f4;
    border-radius: 12px;
    margin-bottom: 16px;
  }
  .plaay-gift-message__label {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #021D49;
    margin-bottom: 6px;
    display: block;
  }
  .plaay-gift-message__textarea {
    width: 100%;
    border: 1.5px solid rgba(2,29,73,0.25);
    border-radius: 8px;
    padding: 10px 12px;
    resize: vertical;
    font-size: 0.85rem;
    box-sizing: border-box;
    font-family: inherit;
    background: #fff;
    color: #021D49;
    outline: none;
    transition: border-color 0.18s ease;
  }
  .plaay-gift-message__textarea:focus {
    border-color: #021D49;
  }
  .plaay-gift-message__occasion-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 12px;
    flex-wrap: wrap;
  }
  .plaay-gift-message__occasion-label {
    font-size: 0.78rem;
    color: #021D49;
    flex-shrink: 0;
  }
  .plaay-gift-occasion-pills {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .plaay-gift-occasion-pill {
    padding: 5px 14px;
    border-radius: 999px;
    border: 1.5px solid rgba(2,29,73,0.25);
    font-size: 0.72rem;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    transition: background 0.18s ease, border-color 0.18s ease, color 0.18s ease;
    background: transparent;
    color: #021D49;
    user-select: none;
  }
  .plaay-gift-occasion-pill.active {
    background: #F9C61D;
    border-color: #F9C61D;
    color: #021D49;
  }

  /* ── Unboxing bar ── */
  .plaay-unbox-bar {
    display: flex;
    align-items: center;
    gap: 10px;
    background: #021D49;
    color: #fff;
    padding: 10px 16px;
    border-radius: 10px;
    margin-top: 12px;
    margin-bottom: 12px;
  }
  .plaay-unbox-icon {
    font-size: 1.1rem;
    flex-shrink: 0;
  }
  .plaay-unbox-text {
    font-size: 0.8rem;
    line-height: 1.4;
  }
{% endstyle %}

<quantity-adjuster data-module="quantity-adjuster">
  <div class="hidden"></div>
</quantity-adjuster>
<quick-add data-module="quick-add"></quick-add>


<div style="background-color: {{ background_color }};">
  <div class="container flex flex-col py-14 | md:pb-16 md:pt-44 | lg:flex-row">
    {% comment %} main gallery {% endcomment %}
    <div class="w-full relative | lg:w-[55%]">
      {%- render 'plaay-badge', product: product -%}
      <div {% if product_images_size > 1 %} class="glide" {% endif %} id="product-gallery-{{ section.id }}">
        {% if product_images_size > 1 %}
          <div class="glide__arrows z-10 flex items-center justify-center w-full | lg:mb-0 lg:mt-0 lg:ml-10 lg:w-auto" data-glide-el="controls">
            <button data-glide-dir="<" class="glide__arrow glide__arrow--left text-0 group absolute z-1 left-0 top-1/2 transform -translate-y-1/2 mr-5 | lg:-left-8">
              slide left
              <span class="flex h-6 w-6 transform rotate-180 text-dark-blue transition-all duration-200 | group-hover:opacity-100">
                {% render 'icon-slider-arrow' %}
              </span>
            </button>
            <button data-glide-dir=">" class="glide__arrow glide__arrow--right text-0 group absolute right-0 z-1 top-1/2 transform -translate-y-1/2 ml-5 | lg:-right-8">
              slide right
              <span class="flex h-6 w-6 text-dark-blue transition-all duration-200 | group-hover:opacity-100">
                {% render 'icon-slider-arrow' %}
              </span>
            </button>
          </div>
        {% endif %}
        <div {% if product_images_size > 1 %} class="glide__track w-full max-w-[800px] mx-auto" data-glide-el="track" {% endif %}>
          <ul {% if product_images_size > 1 %} class="glide__slides" {% endif %}>
            {% for image in product.images %}
              <li {% if product_images_size > 1 %} class="glide__slide px-8 | md:px-0" {% endif %} data-index="{{ forloop.index0 }}">
                {% render 'img', type: 'img', img: image, eager: true, class: 'object-contain h-[420px] mx-auto lg:w-full lg:h-[600px] xl:object-cover', height: 420, width: 550, forloop_data: forloop.index %}
              </li>
            {% endfor %}
          </ul>
        </div>
        {% if product_images_size > 1 %}
          <div class="glide__bullets flex items-center justify-center my-5 | md:hidden" data-glide-el="controls[nav]">
            {% for image in product.images %}
              <button class="glide__bullet h-4 w-4 bg-dark-blue opacity-50 rounded-full transition-all duration-200 {% unless forloop.first %} ml-3 {% endunless %}" data-glide-dir="={{ forloop.index0 }}"></button>
            {% endfor %}
          </div>
        {% endif %}
      </div>
      {% comment %} thumbnail slider {% endcomment %}
      {% if product_images_size > 1 %}
        <div class="glide mt-2 max-w-md mx-auto hidden | md:block" id="product-gallery-thumbnails-{{ section.id }}">
          <div class="glide__arrows z-10 flex items-center justify-center w-full mt-8 mb-14 | md:mb-0 md:mt-0 md:ml-10 md:w-auto" data-glide-el="controls">
            <button data-glide-dir="<" class="glide__arrow glide__arrow--left text-0 group absolute -left-16 top-1/2 transform -translate-y-1/2 mr-5 | lg:-left-8 ">
              slide left
              <span class="flex h-6 w-6 transform rotate-180 text-dark-blue opacity-30 transition-all duration-200 | group-hover:opacity-100">
                {% render 'icon-slider-arrow' %}
              </span>
            </button>
            <button data-glide-dir=">" class="glide__arrow glide__arrow--right text-0 group absolute -right-16 top-1/2 transform -translate-y-1/2 ml-5 | lg:-right-8">
              slide right
              <span class="flex h-6 w-6 text-dark-blue opacity-30 transition-all duration-200 | group-hover:opacity-100">
                {% render 'icon-slider-arrow' %}
              </span>
            </button>
          </div>
          <div class="glide__track max-w-[380px] mx-auto" data-glide-el="track">
            <ul class="glide__slides">
              {% for image in product.images %}
                <li class="glide__slide thumbnail_slide">
                  <div class="block h-20 w-20 border-0.5 border-opacity-20 border-black">
                    {% render 'img', type: 'img', img: image, eager: true, class: 'object-contain mx-auto h-full cursor-pointer w-full', forloop_data: forloop.index0 %}
                  </div>
                </li>
              {% endfor %}
            </ul>
          </div>
        </div>
      {% endif %}
    </div>
    {% comment %} product information {% endcomment %}
    <div class="w-full mt-5 | lg:mt-0 lg:w-1/2 lg:flex lg:flex-col lg:justify-center lg:max-w-md lg:ml-10 | xl:ml-14 | 2xl:ml-20">
      {% comment %} title row {% endcomment %}
      <div class="plaay-pdp-title-row">
        {%- render 'plaay-badge', product: product, inline: true -%}
        <h1 class="text-5xl leading-none uppercase text-dark-blue font-walsheim-bold pdp-title"> {{ product.title }} </h1>
        {%- render 'plaay-wishlist-heart', product: product, style: 'pdp' -%}
      </div>

      <!-- Add Offer Callout Block Here -->
{% for block in section.blocks %}
  {% if block.type == 'offer_callout' %}
    <div class="product-block-offer-callout" {{ block.shopify_attributes }}>
      <svg class="clip-left" width="27" height="62" viewBox="0 0 27 62" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M5 1H26V61H20H3L11.5 52L2 48.4C4.66667 46 9.9 41.2 9.5 41.2C9.1 41.2 5.33333 37.6 3.5 35.8L11 28L4.5 23.8L9.5 17.2L5 12.4L10.5 7.6L5 1Z" fill="#FECE55" stroke="#404040" stroke-width="2"></path>
        <rect x="24" y="2" width="6" height="58" fill="#FECE55"></rect>
      </svg>
      <div class="larg">
        <div class="bloc">
          <p><span class="oc-copy">{{ block.settings.coupon_text }}</span></p>
        </div>
      </div>
      <svg class="clip-right" width="27" height="62" viewBox="0 0 27 62" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M22 61H1L1 0.999996H7H24L15.5 10L25 13.6C22.3333 16 17.1 20.8 17.5 20.8C17.9 20.8 21.6667 24.4 23.5 26.2L16 34L22.5 38.2L17.5 44.8L22 49.6L16.5 54.4L22 61Z" fill="#FECE55" stroke="#404040" stroke-width="2"></path>
        <rect y="2" width="3" height="58" fill="#FECE55"></rect>
      </svg>
    </div>
  {% endif %}
{% endfor %}

<style>
.product-block-offer-callout {
  display: flex;
  align-items: center;
  justify-content: center;
  max-width: 600px;
  margin: 15px auto;
  height: 62px;
  background: #FECE55;
  border-top: 2px solid #404040;
  border-bottom: 2px solid #404040;
  position: relative;
  font-family: inherit;
}
.product-block-offer-callout .larg {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 0 15px;
  flex: 1;
  height: 100%;
}
.product-block-offer-callout .bloc p,
.product-block-offer-callout .bloc h6 {
  margin: 0;
  line-height: 1.3;
  color: #404040;
}
.product-block-offer-callout .bloc p { font-weight: bold; font-size: 1.1em; }
.product-block-offer-callout .bloc h6 { font-size: 0.9em; font-weight: normal; }
.product-block-offer-callout .oc-copy { font-weight: bold; }
.product-block-offer-callout .clip-left  { position: absolute; left: -15px; }
.product-block-offer-callout .clip-right { position: absolute; right: -15px; }
@media (max-width: 768px) {
  .product-block-offer-callout { max-width: 90%; height: 62px; margin: 10px auto; }
  .product-block-offer-callout .larg { gap: 8px; padding: 0 10px; justify-content: center; }
  .product-block-offer-callout .bloc p { font-size: 1em; }
  .product-block-offer-callout .bloc h6 { font-size: 0.8em; }
}
@media (max-width: 480px) {
  .product-block-offer-callout { height: 62px; flex-wrap: wrap; padding: 4px 0; }
  .product-block-offer-callout .larg { flex-direction: column; text-align: center; gap: 1px; justify-content: center; }
  .product-block-offer-callout .clip-left  { position: absolute; left: -15px; }
  .product-block-offer-callout .clip-right { position: absolute; right: -15px; }
  .product-block-offer-callout .bloc p { font-size: 0.9em; }
  .product-block-offer-callout .bloc h6 { font-size: 0.75em; }
}
</style>
<!-- End Offer Callout Block Here -->

      {% if subtitle_text != blank %}
        <p class="my-3 text-sm text-dark-blue">{{ subtitle_text }}</p>
      {% endif %}

      {% render 'product-price', product: product %}
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when '@app' -%}
           {% render block %}
        {% endcase %}
      {% endfor %}

      <!-- product-discount-text.liquid START -->
      <div class="main-discount-wrapper">
        {% for block in section.blocks %}
          {% if block.type == 'discount' and block.settings.show_discount_text %}
            <div class="disc-top-curve disc disc-main-text">
              {{ block.settings.discount_prefix }}
              <span style="color: {{ block.settings.highlight_color }};">
                {{ block.settings.discount_highlight }}
              </span>
            </div>
          {% endif %}
        {% endfor %}
      </div>
      <!-- product-discount-text.liquid END -->

      {% comment %} usps / trust badges {% endcomment %}
      {% if usp_images != blank or usp_text != blank %}
        <div class="plaay-trust-strip mt-6 mb-2">
          {% for image in usp_images %}
            {% assign text = usp_text[forloop.index0] %}
            <div class="plaay-trust-item">
              <div class="plaay-trust-icon-wrap">
                {% render 'img', type: 'img', img: image, lazy: true, class: 'plaay-trust-icon' %}
              </div>
              <span class="plaay-trust-label">{{ text }}</span>
            </div>
          {% endfor %}
        </div>
      {% endif %}
      {%- render 'plaay-trust-badges', product: product -%}

      {% comment %} choose flavor {% endcomment %}
      <div class="choose-flovor">
        {% render 'flavor-option', variant_selector_style: section.settings.variant_selector_style %}
      </div>

      {% comment %} ── GIFTING ENHANCEMENT 1: "This is a gift" toggle + message ── {% endcomment %}
      <div class="plaay-gift-toggle-row">
        <label class="plaay-gift-toggle" id="plaay-gift-toggle-label">
          <input type="checkbox" id="plaay-gift-check" class="plaay-gift-check">
          <span class="plaay-gift-toggle__slider"></span>
          <span class="plaay-gift-toggle__label font-walsheim-bold">🎁 This is a gift</span>
        </label>
      </div>

      <div class="plaay-gift-message-wrap" id="plaay-gift-message-wrap" style="display:none">
        <label class="plaay-gift-message__label font-walsheim-bold" for="plaay-gift-msg">Gift Message (optional)</label>
        <textarea id="plaay-gift-msg" name="properties[Gift Message]" class="plaay-gift-message__textarea font-walsheim" placeholder="Write a personal note…" rows="3" maxlength="200"></textarea>
        <div class="plaay-gift-message__occasion-row">
          <span class="plaay-gift-message__occasion-label font-walsheim-bold">Occasion:</span>
          <div class="plaay-gift-occasion-pills" id="plaay-gift-occasion-pills">
            <!-- JS renders occasion pills -->
          </div>
          <input type="hidden" name="properties[Occasion]" id="plaay-gift-occasion-hidden" value="">
        </div>
      </div>
      {% comment %} ── END GIFTING ENHANCEMENT 1 ── {% endcomment %}

      {% render 'product.add-to-cart', product: product, show_subscribe: section.settings.enable_subscribe_push %}

      {%- render 'plaay-delivery-promise' -%}

      {% comment %} ── GIFTING ENHANCEMENT 2: Unboxing bar (shown when gift_ready metafield = true) ── {% endcomment %}
      {% if gift_ready == 'true' %}
        <div class="plaay-unbox-bar">
          <span class="plaay-unbox-icon">✨</span>
          <span class="plaay-unbox-text font-walsheim-bold">Premium unboxing experience — every order is gift-wrapped.</span>
        </div>
      {% endif %}
      {% comment %} ── END GIFTING ENHANCEMENT 2 ── {% endcomment %}

      {% comment %} ── PDP Info Tabs ── {% endcomment %}
      {%- liquid
        assign first_tab = 'shipping'
        if exact_ingredients != blank
          assign first_tab = 'ingredients'
        endif
        if product.description != blank
          assign first_tab = 'info'
        endif
        assign sid = section.id
      -%}
      <div class="plaay-pdp-tabs" id="plaay-pdp-tabs-{{ sid }}">

        {% comment %} Tab nav {% endcomment %}
        <div class="plaay-pdp-tabs__nav" role="tablist" aria-label="Product details">
          {% if product.description != blank %}
            <button
              class="plaay-pdp-tabs__tab{% if first_tab == 'info' %} is-active{% endif %} font-walsheim-bold"
              role="tab"
              data-tab="info-{{ sid }}"
              aria-selected="{% if first_tab == 'info' %}true{% else %}false{% endif %}">
              {{ section.settings.tab_info_label | default: 'Product Info' }}
            </button>
          {% endif %}
          {% if exact_ingredients != blank %}
            <button
              class="plaay-pdp-tabs__tab{% if first_tab == 'ingredients' %} is-active{% endif %} font-walsheim-bold"
              role="tab"
              data-tab="ingredients-{{ sid }}"
              aria-selected="{% if first_tab == 'ingredients' %}true{% else %}false{% endif %}">
              {{ section.settings.tab_ingredients_label | default: 'Ingredients' }}
            </button>
          {% endif %}
          <button
            class="plaay-pdp-tabs__tab{% if first_tab == 'shipping' %} is-active{% endif %} font-walsheim-bold"
            role="tab"
            data-tab="shipping-{{ sid }}"
            aria-selected="{% if first_tab == 'shipping' %}true{% else %}false{% endif %}">
            {{ section.settings.tab_shipping_label | default: 'Shipping & Returns' }}
          </button>
        </div>

        {% comment %} Tab panels {% endcomment %}
        {% if product.description != blank %}
          <div
            class="plaay-pdp-tabs__panel{% unless first_tab == 'info' %} is-hidden{% endunless %} rte font-walsheim text-dark-blue"
            data-panel="info-{{ sid }}"
            role="tabpanel">
            {{ product.description }}
          </div>
        {% endif %}

        {% if exact_ingredients != blank %}
          <div
            class="plaay-pdp-tabs__panel{% unless first_tab == 'ingredients' %} is-hidden{% endunless %} font-walsheim text-dark-blue"
            data-panel="ingredients-{{ sid }}"
            role="tabpanel">
            {{ exact_ingredients }}
          </div>
        {% endif %}

        <div
          class="plaay-pdp-tabs__panel{% unless first_tab == 'shipping' %} is-hidden{% endunless %} rte font-walsheim text-dark-blue"
          data-panel="shipping-{{ sid }}"
          role="tabpanel">
          {% if section.settings.shipping_returns_content != blank %}
            {{ section.settings.shipping_returns_content }}
          {% else %}
            <p><strong>Free delivery</strong> on all orders over AED 75.</p>
            <p>Same-day delivery in Dubai (order before 2 PM). 1–2 business days across the UAE.</p>
            <p><strong>Returns:</strong> We accept returns within 7 days for unopened, undamaged items. Email hello@shopplaay.com to initiate.</p>
          {% endif %}
        </div>

      </div>

      <script>
      (function(){
        var wrap = document.getElementById('plaay-pdp-tabs-{{ sid }}');
        if (!wrap) return;
        var tabs   = wrap.querySelectorAll('.plaay-pdp-tabs__tab');
        var panels = wrap.querySelectorAll('.plaay-pdp-tabs__panel');
        tabs.forEach(function(tab) {
          tab.addEventListener('click', function() {
            tabs.forEach(function(t){ t.classList.remove('is-active'); t.setAttribute('aria-selected','false'); });
            panels.forEach(function(p){ p.classList.add('is-hidden'); });
            tab.classList.add('is-active');
            tab.setAttribute('aria-selected','true');
            var panel = wrap.querySelector('[data-panel="' + tab.dataset.tab + '"]');
            if (panel) panel.classList.remove('is-hidden');
          });
        });
      })();
      </script>
      {% comment %} end PDP Info Tabs {% endcomment %}

    </div>
  </div>
</div>

{% comment %} ── Gifting JS (scoped IIFE) ── {% endcomment %}
<script>
(function () {
  var OCCASIONS = [
    'Birthday',
    'Anniversary',
    'Eid',
    'Thank You',
    'Just Because',
    'Congratulations'
  ];

  function initGiftingUI() {
    var checkbox      = document.getElementById('plaay-gift-check');
    var toggleLabel   = document.getElementById('plaay-gift-toggle-label');
    var messageWrap   = document.getElementById('plaay-gift-message-wrap');
    var pillsContainer = document.getElementById('plaay-gift-occasion-pills');
    var hiddenOccasion = document.getElementById('plaay-gift-occasion-hidden');
    var textarea      = document.getElementById('plaay-gift-msg');

    if (!checkbox || !messageWrap || !pillsContainer) return;

    // ── Build occasion pills ──
    OCCASIONS.forEach(function (occasion) {
      var pill = document.createElement('span');
      pill.className = 'plaay-gift-occasion-pill font-walsheim-bold';
      pill.textContent = occasion;
      pill.setAttribute('role', 'button');
      pill.setAttribute('tabindex', '0');
      pill.addEventListener('click', function () {
        pillsContainer.querySelectorAll('.plaay-gift-occasion-pill').forEach(function (p) {
          p.classList.remove('active');
        });
        pill.classList.add('active');
        if (hiddenOccasion) hiddenOccasion.value = occasion;
      });
      pill.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); pill.click(); }
      });
      pillsContainer.appendChild(pill);
    });

    // ── Toggle show/hide ──
    function syncUI() {
      var isChecked = checkbox.checked;
      if (isChecked) {
        messageWrap.style.display = 'block';
        toggleLabel.classList.add('is-on');
      } else {
        messageWrap.style.display = 'none';
        toggleLabel.classList.remove('is-on');
        // Clear hidden inputs so they are not submitted when unchecked
        if (hiddenOccasion) hiddenOccasion.value = '';
        if (textarea) textarea.value = '';
        // Remove active state from all pills
        pillsContainer.querySelectorAll('.plaay-gift-occasion-pill').forEach(function (p) {
          p.classList.remove('active');
        });
      }
    }

    checkbox.addEventListener('change', syncUI);
    syncUI(); // run once on init
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initGiftingUI);
  } else {
    initGiftingUI();
  }
})();
</script>

{%- assign sticky_variant = product.selected_or_first_available_variant -%}

{% comment %} ── Mobile sticky ATC (shown on mobile when inline button scrolls out) ── {% endcomment %}
<div id="plaay-sticky-mobile" class="plaay-sticky-mobile" aria-hidden="true">
  <div style="padding:10px 16px 14px">
    {% comment %} Row 1 — thumbnail + price + qty {% endcomment %}
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:10px">
      {%- if product.featured_image -%}
        <img
          src="{{ product.featured_image | image_url: width: 80 }}"
          alt="{{ product.title | escape }}"
          width="52" height="52"
          class="plaay-sticky-thumb"
          loading="eager">
      {%- endif -%}
      <div style="flex:1;display:flex;align-items:center;justify-content:space-between;min-width:0">
        <div style="display:flex;flex-direction:column;gap:1px">
          {%- if sticky_variant.compare_at_price > sticky_variant.price -%}
            <span class="plaay-sticky-compare font-walsheim-regular text-dark-blue" style="font-size:11px;text-decoration:line-through;opacity:0.45;line-height:1">{{ sticky_variant.compare_at_price | money }}</span>
          {%- else -%}
            <span class="plaay-sticky-compare font-walsheim-regular text-dark-blue" style="font-size:11px;text-decoration:line-through;opacity:0.45;line-height:1;display:none">{{ sticky_variant.compare_at_price | money }}</span>
          {%- endif -%}
          <span class="plaay-sticky-mobile-price font-walsheim-bold text-dark-blue" style="font-size:20px;line-height:1">{{ sticky_variant.price | money }}</span>
        </div>
        <div style="display:flex;align-items:center;border:1.5px solid #021D49;border-radius:10px;overflow:hidden;height:38px">
          <button type="button" class="plaay-mobile-minus font-walsheim-bold text-dark-blue" style="padding:0 13px;height:100%;font-size:20px;line-height:1;background:transparent;border:none;cursor:pointer">−</button>
          <span class="plaay-mobile-qty font-walsheim-bold text-dark-blue" style="padding:0 10px;font-size:14px;border-left:1px solid rgba(2,29,73,0.2);border-right:1px solid rgba(2,29,73,0.2);height:100%;display:flex;align-items:center;min-width:36px;justify-content:center">1</span>
          <button type="button" class="plaay-mobile-plus font-walsheim-bold text-dark-blue" style="padding:0 13px;height:100%;font-size:20px;line-height:1;background:transparent;border:none;cursor:pointer">+</button>
        </div>
      </div>
    </div>
    {% comment %} Row 2 — full-width ATC button {% endcomment %}
    <button type="button" class="btn blue font-walsheim-bold uppercase plaay-mobile-submit" style="width:100%;padding:15px;font-size:14px;letter-spacing:0.05em">
      {{ 'product.add_to_cart.add_to_bag' | t }}
    </button>
  </div>
</div>

{% comment %} ── Desktop sticky ATC bar ── {% endcomment %}
<div id="plaay-sticky-atc" class="plaay-sticky-atc" aria-hidden="true">
  <div class="container flex items-center justify-between">
    <p class="font-walsheim-black uppercase text-dark-blue leading-tight truncate flex-1 hidden xl:block" style="font-size:13px;margin-right:2rem">{{ product.title }}</p>
    <div style="display:flex;align-items:center;gap:20px;margin-left:auto;flex-shrink:0">
      {% comment %} Price block — always render both spans, JS shows/hides compare {% endcomment %}
      <div style="display:flex;flex-direction:column;align-items:flex-end;gap:3px">
        <span class="plaay-sticky-compare font-walsheim-regular text-dark-blue" style="font-size:11px;text-decoration:line-through;opacity:0.5;line-height:1;{% unless sticky_variant.compare_at_price > sticky_variant.price %}display:none{% endunless %}">{{ sticky_variant.compare_at_price | money }}</span>
        <span class="plaay-sticky-price font-walsheim-bold text-dark-blue" style="font-size:20px;line-height:1">{{ sticky_variant.price | money }}</span>
      </div>
      {% comment %} Quantity selector {% endcomment %}
      <div class="plaay-sticky-qty-wrap" style="display:flex;align-items:center;border:1.5px solid #021D49;border-radius:10px;overflow:hidden;height:44px">
        <button type="button" class="plaay-sticky-minus font-walsheim-bold text-dark-blue" style="padding:0 16px;height:100%;font-size:22px;line-height:1;background:transparent;border:none;cursor:pointer">−</button>
        <span class="plaay-sticky-qty font-walsheim-bold text-dark-blue" style="padding:0 14px;font-size:15px;border-left:1px solid rgba(2,29,73,0.2);border-right:1px solid rgba(2,29,73,0.2);height:100%;display:flex;align-items:center;min-width:44px;justify-content:center">1</span>
        <button type="button" class="plaay-sticky-plus font-walsheim-bold text-dark-blue" style="padding:0 16px;height:100%;font-size:22px;line-height:1;background:transparent;border:none;cursor:pointer">+</button>
      </div>
      {% comment %} ATC button {% endcomment %}
      <button type="button" class="btn blue font-walsheim-bold uppercase plaay-sticky-submit" style="padding:13px 32px;font-size:14px;white-space:nowrap;letter-spacing:0.05em">
        {{ 'product.add_to_cart.add_to_bag' | t }}
      </button>
    </div>
  </div>
</div>

<script>
(function() {
  function initStickyBars() {
    var inlineAtc = document.querySelector('.product_page_atc');
    var desktopBar = document.getElementById('plaay-sticky-atc');
    var mobileBar  = document.getElementById('plaay-sticky-mobile');
    if (!inlineAtc) return;

    var isMobile = function() { return window.innerWidth < 1024; };

    var baseStyle = 'position:fixed;bottom:0;left:0;right:0;z-index:9998;' +
                    'background:#fff;border-top:1px solid rgba(2,29,73,0.12);' +
                    'box-shadow:0 -4px 24px rgba(2,29,73,0.1);' +
                    'transition:transform 0.3s ease;transform:translateY(110%);pointer-events:none;';

    if (desktopBar) {
      desktopBar.setAttribute('style', baseStyle + 'padding:16px 0;display:none;');
    }
    if (mobileBar) {
      mobileBar.setAttribute('style', baseStyle + 'display:none;');
    }

    function showBar(bar) {
      if (!bar) return;
      bar.style.display = 'block';
      bar.offsetHeight;
      bar.style.transform = 'translateY(0)';
      bar.style.pointerEvents = 'auto';
    }
    function hideBar(bar) {
      if (!bar) return;
      bar.style.transform = 'translateY(110%)';
      bar.style.pointerEvents = 'none';
    }

    var observer = new IntersectionObserver(function(entries) {
      var notVisible = !entries[0].isIntersecting;
      if (isMobile()) {
        if (notVisible) { showBar(mobileBar); hideBar(desktopBar); }
        else             { hideBar(mobileBar); }
      } else {
        if (notVisible) { showBar(desktopBar); hideBar(mobileBar); }
        else             { hideBar(desktopBar); }
      }
    }, { threshold: 0 });
    observer.observe(inlineAtc);

    // ── Price sync ──
    var getPriceEl = function() {
      return document.querySelector('.product_page_atc .product_discount_price') ||
             document.querySelector('.product_page_atc .product_price') ||
             document.querySelector('.product_discount_price') ||
             document.querySelector('.product_price');
    };
    var syncPrice = function() {
      var el = getPriceEl();
      var txt = el ? el.textContent.trim() : '';
      if (!txt) return;
      var dp  = desktopBar && desktopBar.querySelector('.plaay-sticky-price');
      var mp  = mobileBar  && mobileBar.querySelector('.plaay-sticky-mobile-price');
      var mcp = mobileBar  && mobileBar.querySelector('.plaay-sticky-compare');
      if (dp) dp.textContent = txt;
      if (mp) mp.textContent = txt;
      var compareEl = document.querySelector('.discount_price_exists');
      var compareTxt = compareEl ? compareEl.textContent.trim() : '';
      if (mcp && compareTxt) {
        mcp.textContent = compareTxt;
        mcp.style.display = 'inline';
      }
      var sc = desktopBar && desktopBar.querySelector('.plaay-sticky-compare');
      if (sc && compareTxt) {
        sc.textContent = compareTxt;
        sc.style.display = '';
      }
    };
    syncPrice();
    document.querySelectorAll('.product_discount_price,.product_price').forEach(function(el) {
      new MutationObserver(syncPrice).observe(el, { childList: true, subtree: true, characterData: true });
    });

    // ── Desktop qty +/- ──
    var qty = 1;
    var qtyDisplay = desktopBar && desktopBar.querySelector('.plaay-sticky-qty');
    var inlineQtyInput = document.querySelector('quick-add input[name="quantity"],input[name="quantity"]');
    if (desktopBar) {
      desktopBar.querySelector('.plaay-sticky-minus').addEventListener('click', function() {
        if (qty > 1) { qty--; if (qtyDisplay) qtyDisplay.textContent = qty; if (inlineQtyInput) inlineQtyInput.value = qty; }
      });
      desktopBar.querySelector('.plaay-sticky-plus').addEventListener('click', function() {
        qty++; if (qtyDisplay) qtyDisplay.textContent = qty; if (inlineQtyInput) inlineQtyInput.value = qty;
      });
      desktopBar.querySelector('.plaay-sticky-submit').addEventListener('click', function() {
        if (inlineQtyInput) inlineQtyInput.value = qty;
        inlineAtc.click();
      });
    }

    // ── Mobile qty +/- ──
    var mobileQty = 1;
    var mobileQtyDisplay = mobileBar && mobileBar.querySelector('.plaay-mobile-qty');
    if (mobileBar) {
      mobileBar.querySelector('.plaay-mobile-minus').addEventListener('click', function() {
        if (mobileQty > 1) { mobileQty--; if (mobileQtyDisplay) mobileQtyDisplay.textContent = mobileQty; if (inlineQtyInput) inlineQtyInput.value = mobileQty; }
      });
      mobileBar.querySelector('.plaay-mobile-plus').addEventListener('click', function() {
        mobileQty++; if (mobileQtyDisplay) mobileQtyDisplay.textContent = mobileQty; if (inlineQtyInput) inlineQtyInput.value = mobileQty;
      });
      mobileBar.querySelector('.plaay-mobile-submit').addEventListener('click', function() {
        if (inlineQtyInput) inlineQtyInput.value = mobileQty;
        inlineAtc.click();
      });
    }

    // ── Sync variant label in mobile bar ──
    var mobileVariantEl = mobileBar && mobileBar.querySelector('.plaay-sticky-mobile-variant');
    if (mobileVariantEl) {
      var variantSel = document.querySelector('select#productSelect,select[name="id"]');
      if (variantSel) {
        variantSel.addEventListener('change', function() {
          var opt = variantSel.options[variantSel.selectedIndex];
          if (opt) mobileVariantEl.textContent = opt.text.split(' - ')[0].trim();
        });
      }
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initStickyBars);
  } else {
    initStickyBars();
  }
})();
</script>

{% if product_images_size > 1 %}
  <script type="module">
    document.addEventListener("DOMContentLoaded", () => {
      const productGallerySlider = new Glide("#product-gallery-{{ section.id }}", {
        type: 'carousel',
        perView: 1,
        startAt: 0,
        focusAt: 'center'
      });
      const productGalleryThumbnailsSlider = new Glide("#product-gallery-thumbnails-{{ section.id }}", {
        type: 'carousel',
        perView: 4,
        startAt: 0
      });
      productGallerySlider.mount({ });
      productGalleryThumbnailsSlider.mount({ });

      productGallerySlider.on("run", (e) => {
        productGalleryThumbnailsSlider.go(e.direction);
      });
      productGalleryThumbnailsSlider.on("run", (e) => {
        productGallerySlider.go(e.direction);
      });
      document.querySelectorAll('.thumbnail_slide').forEach(el => {
        el.addEventListener('click', (e) => {
          productGallerySlider.go('=' + `${e.target.dataset.index}`);
          productGalleryThumbnailsSlider.go('=' + `${e.target.dataset.index}`);
        });
      });
    });
  </script>
{% endif %}

{% render 'rebuy-templates-fbt' %}

{% schema %}
{
  "name": "Gifting Product Page",
  "settings": [
    {
      "type": "color",
      "label": "Background color",
      "id": "background_color",
      "default": "#F4F4F4"
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Price Text Color",
      "default": "#000000"
    },
    {
      "type": "select",
      "id": "variant_selector_style",
      "label": "Flavour / Size selector style",
      "options": [
        { "value": "swatches", "label": "Image swatches" },
        { "value": "dropdown", "label": "Dropdown list" }
      ],
      "default": "swatches",
      "info": "Controls how 'Choose Your Flavour' and 'Choose Your Size' are displayed on the product page."
    },
    {
      "type": "checkbox",
      "id": "enable_subscribe_push",
      "label": "Show Subscribe & Save toggle",
      "default": true,
      "info": "Uncheck to hide the Subscribe & Save option on this product page template."
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show Description?",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_exact_ingredients",
      "label": "Show exact ingredients?",
      "default": true
    },
    {
      "type": "header",
      "content": "Product info tabs"
    },
    {
      "type": "text",
      "id": "tab_info_label",
      "label": "Tab 1 label",
      "default": "Product Info",
      "info": "Shown only when the product has a description."
    },
    {
      "type": "text",
      "id": "tab_ingredients_label",
      "label": "Tab 2 label",
      "default": "Ingredients",
      "info": "Shown only when the product has an ingredients metafield."
    },
    {
      "type": "text",
      "id": "tab_shipping_label",
      "label": "Tab 3 label",
      "default": "Shipping & Returns"
    },
    {
      "type": "richtext",
      "id": "shipping_returns_content",
      "label": "Shipping & Returns content",
      "default": "<p><strong>Free delivery</strong> on all orders over AED 75. Same-day delivery in Dubai (order before 2 PM). 1–2 business days across the UAE.</p><p><strong>Returns:</strong> We accept returns within 7 days for unopened, undamaged items. Email hello@shopplaay.com to initiate a return.</p>"
    }
  ],
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "discount",
      "name": "Discount Text",
      "settings": [
        {
          "type": "checkbox",
          "id": "show_discount_text",
          "label": "Show this text",
          "default": true
        },
        {
          "type": "richtext",
          "id": "discount_prefix",
          "label": "Discount Text",
          "default": "<p>Get 10% off on your</p>"
        },
        {
          "type": "richtext",
          "id": "discount_highlight",
          "label": "Highlighted Text",
          "default": "<p>first order</p>"
        },
        {
          "type": "color",
          "id": "highlight_color",
          "label": "Highlight Color",
          "default": "#FF0000"
        }
      ]
    },
    {
      "type": "offer_callout",
      "name": "Offer Callout Banner",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "coupon_code",
          "label": "Coupon Code",
          "default": "TRU35"
        },
        {
          "type": "text",
          "id": "coupon_text",
          "label": "Offer Text",
          "default": "Get Flat 35% Off on orders above AED 200"
        }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "Gifting Product Page",
      "category": "Product"
    }
  ]
}
{% endschema %}
