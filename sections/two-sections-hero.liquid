      "content": "General settings"
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Autoplay speed",
      "min": 0,
      "max": 1000,
      "default": 500,
      "step": 100,
      "info": "Set to 0 to disable autoplay"
    },
    {
      "type": "range",
      "id": "height_desktop_large",
      "label": "Height: desktop - large (1536px +)",
      "min": 200,
      "max": 1200,
      "default": 800,
      "step": 10,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "height_desktop",
      "label": "Height: desktop (1024px - 1535px)",
      "min": 200,
      "max": 1000,
      "default": 700,
      "step": 10,
      "unit": "px"
