{% comment %}
  PDP Nutrition — expandable nutrition facts panel.
  Styled as a branded toggle-card, not a plain table.
  Reads rows from blocks (name + value per row).
  Add to the product page template via the theme customiser.
{% endcomment %}

{% liquid
  assign bg         = section.settings.background_color
  assign heading    = section.settings.heading
  assign serving    = section.settings.serving_size
  assign calories   = section.settings.calories
  assign rows       = section.blocks | where: 'type', 'row'
  assign disclaimer = section.settings.disclaimer
%}

<div class="pdp-nutr" style="background:{{ bg }}">
  <div class="container">

    <details class="pdp-nutr__details" id="pdp-nutr-{{ section.id }}">
      <summary class="pdp-nutr__summary font-walsheim-bold">
        <span>{{ heading | default: 'Nutrition Facts' }}</span>
        <span class="pdp-nutr__chevron" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M5 7.5L10 12.5L15 7.5" stroke="#021D49" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </summary>

      <div class="pdp-nutr__panel">
        {%- comment -%} header strip {%- endcomment -%}
        <div class="pdp-nutr__panel-header">
          <span class="pdp-nutr__panel-title font-walsheim-black">Nutrition Facts</span>
          {% if serving != blank %}
            <span class="pdp-nutr__serving font-walsheim-regular">Serving size: {{ serving }}</span>
          {% endif %}
        </div>

        {%- comment -%} calorie row — big and bold {%- endcomment -%}
        {% if calories != blank %}
          <div class="pdp-nutr__calories-row">
            <span class="pdp-nutr__calories-label font-walsheim-bold">Calories</span>
            <span class="pdp-nutr__calories-val font-walsheim-black">{{ calories }}</span>
          </div>
        {% endif %}

        {%- comment -%} data rows {%- endcomment -%}
        {% if rows.size > 0 %}
          <ul class="pdp-nutr__rows">
            {% for block in rows %}
              <li class="pdp-nutr__row {% if block.settings.is_sub %}pdp-nutr__row--sub{% endif %}" {{ block.shopify_attributes }}>
                <span class="pdp-nutr__row-name font-walsheim-{% if block.settings.is_sub %}regular{% else %}bold{% endif %}">{{ block.settings.name }}</span>
                <span class="pdp-nutr__row-value font-walsheim-bold">{{ block.settings.value }}</span>
              </li>
            {% endfor %}
          </ul>
        {% endif %}

        {% if disclaimer != blank %}
          <p class="pdp-nutr__disclaimer font-walsheim-regular">{{ disclaimer }}</p>
        {% endif %}
      </div>
    </details>

  </div>
</div>

<style>
.pdp-nutr {
  padding: 0;
}
.pdp-nutr .container {
  max-width: 740px;
}
.pdp-nutr__details {
  border-top: 1px solid rgba(2,29,73,0.12);
  border-bottom: 1px solid rgba(2,29,73,0.12);
}
.pdp-nutr__summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20px 0;
  cursor: pointer;
  list-style: none;
  color: #021D49;
  font-size: 1rem;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  user-select: none;
}
.pdp-nutr__summary::-webkit-details-marker { display: none; }
.pdp-nutr__chevron {
  transition: transform 0.3s ease;
  display: flex;
}
.pdp-nutr__details[open] .pdp-nutr__chevron {
  transform: rotate(180deg);
}

.pdp-nutr__panel {
  padding-bottom: 24px;
  animation: pdpNutrSlideIn 0.25s ease;
}
@keyframes pdpNutrSlideIn {
  from { opacity: 0; transform: translateY(-6px); }
  to   { opacity: 1; transform: translateY(0); }
}

.pdp-nutr__panel-header {
  background: #021D49;
  border-radius: 12px 12px 0 0;
  padding: 16px 20px 12px;
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 8px;
  flex-wrap: wrap;
}
.pdp-nutr__panel-title {
  color: #fff;
  font-size: 1.3rem;
  text-transform: uppercase;
  letter-spacing: 0.02em;
}
.pdp-nutr__serving {
  color: rgba(255,255,255,0.65);
  font-size: 0.78rem;
}

.pdp-nutr__calories-row {
  background: #F9C61D;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 20px;
}
.pdp-nutr__calories-label {
  color: #021D49;
  font-size: 0.9rem;
  text-transform: uppercase;
  letter-spacing: 0.04em;
}
.pdp-nutr__calories-val {
  color: #021D49;
  font-size: 2rem;
  line-height: 1;
}

.pdp-nutr__rows {
  list-style: none;
  padding: 0;
  margin: 0;
  border: 1px solid rgba(2,29,73,0.1);
  border-top: none;
  border-radius: 0 0 12px 12px;
  overflow: hidden;
}
.pdp-nutr__row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 11px 20px;
  border-bottom: 1px solid rgba(2,29,73,0.07);
  background: #fff;
}
.pdp-nutr__row:last-child { border-bottom: none; }
.pdp-nutr__row--sub {
  padding-left: 36px;
  background: rgba(249,198,29,0.04);
}
.pdp-nutr__row-name {
  color: #021D49;
  font-size: 0.87rem;
}
.pdp-nutr__row--sub .pdp-nutr__row-name {
  font-size: 0.82rem;
  opacity: 0.8;
}
.pdp-nutr__row-value {
  color: #021D49;
  font-size: 0.87rem;
}

.pdp-nutr__disclaimer {
  color: #021D49;
  opacity: 0.45;
  font-size: 0.7rem;
  line-height: 1.5;
  margin-top: 12px;
  padding: 0 4px;
}

@media (max-width: 639px) {
  .pdp-nutr__summary { font-size: 0.88rem; }
  .pdp-nutr__calories-val { font-size: 1.6rem; }
  .pdp-nutr__row { padding: 10px 14px; }
  .pdp-nutr__row--sub { padding-left: 26px; }
}
</style>

{% schema %}
{
  "name": "PDP — Nutrition Facts",
  "class": "pdp-nutrition-section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background colour",
      "default": "#FFFFFF"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Toggle label",
      "default": "Nutrition Facts"
    },
    {
      "type": "text",
      "id": "serving_size",
      "label": "Serving size",
      "default": "1 bar (40g)"
    },
    {
      "type": "text",
      "id": "calories",
      "label": "Calories per serving",
      "default": "150"
    },
    {
      "type": "text",
      "id": "disclaimer",
      "label": "Disclaimer / footnote",
      "default": "* Percent Daily Values are based on a 2,000 calorie diet."
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Nutrition row",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Nutrient name",
          "default": "Protein"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "default": "10g"
        },
        {
          "type": "checkbox",
          "id": "is_sub",
          "label": "Sub-row (indented)",
          "default": false,
          "info": "Use for sub-items like Saturated Fat under Total Fat"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PDP — Nutrition Facts",
      "blocks": [
        { "type": "row", "settings": { "name": "Total Fat",         "value": "4g"   } },
        { "type": "row", "settings": { "name": "Saturated Fat",     "value": "1.5g", "is_sub": true } },
        { "type": "row", "settings": { "name": "Trans Fat",         "value": "0g",   "is_sub": true } },
        { "type": "row", "settings": { "name": "Cholesterol",       "value": "20mg" } },
        { "type": "row", "settings": { "name": "Sodium",            "value": "140mg"} },
        { "type": "row", "settings": { "name": "Total Carbohydrate","value": "12g"  } },
        { "type": "row", "settings": { "name": "Dietary Fibre",     "value": "1g",   "is_sub": true } },
        { "type": "row", "settings": { "name": "Total Sugars",      "value": "5g",   "is_sub": true } },
        { "type": "row", "settings": { "name": "Protein",           "value": "10g"  } }
      ]
    }
  ]
}
{% endschema %}
