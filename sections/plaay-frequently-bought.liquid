{% liquid
  assign heading = section.settings.heading
  assign description = section.settings.description
  assign background_color = section.settings.background_color
  assign source_collection = section.settings.source_collection
  assign product_limit = section.settings.product_limit
  assign see_all_text = section.settings.see_all_text
  assign compact_mobile_grid = section.settings.compact_mobile_grid
  assign hide_arrows_desktop = section.settings.hide_arrows_desktop
  assign hide_arrows_mobile = section.settings.hide_arrows_mobile
  assign hide_bullets = section.settings.hide_bullets
  assign hide_atc_on_tiles = section.settings.hide_atc_on_tiles
  assign column_size_desktop_extra_large = section.settings.column_size_desktop_extra_large
  assign column_size_desktop_large = section.settings.column_size_desktop_large
  assign column_size_desktop = section.settings.column_size_desktop
  assign column_size_tablet = section.settings.column_size_tablet
  assign column_size_mobile = section.settings.column_size_mobile
  assign column_size_mobile_small = section.settings.column_size_mobile_small
%}

{% if source_collection != blank %}
  {% assign see_all_link = source_collection.url %}
{% else %}
  {% assign see_all_link = blank %}
{% endif %}

<product-tile data-module="product-tile">
  {% if source_collection != blank and source_collection.products_count > 0 %}
    <div
      data-product-slider
      id="plaay-frequently-bought-{{ section.id }}"
      class="py-8 | md:py-12"
      data-section-id="{{ section.id }}"
      style="background-color: {{ background_color }};">
      <div class="container">
        <div {% if compact_mobile_grid %}class="compact-grid-wrapper"{% endif %}>
          <div id="plaay-frequently-bought-slider-{{ section.id }}" class="glide featured-main">
            <div class="view-all-flex glide__arrow-container w-auto block flex-col justify-center {% if description != blank %} flex-wrap {% endif %} | md:pb-10 md:flex-row">
              {% if heading != blank %}
                <h2 class="text-center text-dark-blue mr-4 mb-7 text-4xl uppercase | md:mb-0 md:text-9xl">{{ heading }}</h2>
              {% endif %}
              {% if description != blank %}
                <p class="text-center text-dark-blue mx-auto max-w-3xl py-2 text-sm | md:flex-100 md:order-1 md:text-base | lg:text-lg">{{ description }}</p>
              {% endif %}
              {% if see_all_link != blank %}
                <a href="{{ see_all_link }}" class="custom-view-aall block uppercase underline text-xl underline-offset-2 font-walsheim-bold mt-4 text-center transition-all duration-200 text-dark-blue | hover:no-underline">
                  {% if see_all_text != blank %}
                    {{ see_all_text }}
                  {% else %}
                    {{ 'action.see_all' | t }}
                  {% endif %}
                </a>
              {% endif %}
            </div>

            <div class="glide__arrows flex items-center justify-center w-full mt-3 {% if hide_arrows_mobile %} hidden {% unless hide_arrows_desktop %} md:block {% endunless %} {% endif %} | {% if hide_arrows_desktop %} md:hidden {% endif %} md:mb-0 md:mt-0 md:w-auto" data-glide-el="controls">
              <button data-glide-dir="<" class="glide__arrow glide__arrow--left text-0 mr-5 group">
                Slide left
                <span class="flex h-6 w-6 transform rotate-180 text-dark-blue opacity-30 transition-all duration-200 | group-hover:opacity-100">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" width="40" height="40" focusable="false"><path d="m15.5 0.932-4.3 4.38 14.5 14.6-14.5 14.5 4.3 4.4 14.6-14.6 4.4-4.3-4.4-4.4-14.6-14.6z"></path></svg>
                </span>
              </button>
              <button data-glide-dir=">" class="glide__arrow glide__arrow--right text-0 ml-5 group">
                Slide right
                <span class="flex h-6 w-6 text-dark-blue opacity-30 transition-all duration-200 | group-hover:opacity-100">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" width="40" height="40" focusable="false"><path d="m15.5 0.932-4.3 4.38 14.5 14.6-14.5 14.5 4.3 4.4 14.6-14.6 4.4-4.3-4.4-4.4-14.6-14.6z"></path></svg>
                </span>
              </button>
            </div>

            <div class="glide__track" data-glide-el="track">
              <ul class="glide__slides py-5 pb-5">
                {% for product in source_collection.products limit: product_limit %}
                  <li class="glide__slide h-auto px-2" data-product-tile>
                    {% render 'product-tile', grey_background: true, product: product, hide_atc: hide_atc_on_tiles %}
                  </li>
                {% endfor %}
              </ul>
            </div>

            {% unless hide_bullets %}
              {% if source_collection.products_count > 1 %}
                <div class="glide__bullets flex items-center justify-center my-5 | md:hidden" data-glide-el="controls[nav]">
                  {% for product in source_collection.products limit: product_limit %}
                    <button class="glide__bullet h-4 w-4 bg-dark-blue opacity-50 rounded-full transition-all duration-200 {% unless forloop.first %} ml-3 {% endunless %}" data-glide-dir="={{ forloop.index0 }}"></button>
                  {% endfor %}
                </div>
              {% endif %}
            {% endunless %}

            {% for product in source_collection.products limit: product_limit %}
              {% render 'product-quick-add-popup', product: product %}
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  {% elsif request.design_mode %}
    <section class="plaay-frequently-bought-empty" style="background-color: {{ background_color }};">
      <div class="container py-10 | md:py-14">
        <div class="plaay-frequently-bought-empty__box">
          <h2 class="font-walsheim-black text-dark-blue uppercase text-2xl | md:text-4xl">
            {{ heading | default: 'Frequently bought' }}
          </h2>
          <p class="font-walsheim text-dark-blue mt-3">
            Select a collection in this section to show a curated frequently bought product rail on collection pages.
          </p>
        </div>
      </div>
    </section>
  {% endif %}
</product-tile>

{% style %}
  .plaay-frequently-bought-empty__box {
    border: 1px dashed rgba(2,29,73,0.18);
    border-radius: 18px;
    background: rgba(255,255,255,0.72);
    padding: 24px;
  }
{% endstyle %}

<script>
  (function() {
    function mountFrequentlyBought{{ section.id }}() {
      var slider = document.getElementById('plaay-frequently-bought-slider-{{ section.id }}');
      if (!slider || typeof Glide === 'undefined' || slider.dataset.glideMounted === 'true') return;

      slider.dataset.glideMounted = 'true';

      new Glide('#plaay-frequently-bought-slider-{{ section.id }}', {
        type: 'carousel',
        perView: {{ column_size_desktop_extra_large }},
        autoplay: {{ section.settings.autoplay | times: 10 }},
        breakpoints: {
          1535: {
            perView: {{ column_size_desktop_large }}
          },
          1280: {
            perView: {{ column_size_desktop }}
          },
          1023: {
            perView: {{ column_size_tablet }}
          },
          640: {
            perView: {% if compact_mobile_grid %}2{% else %}{{ column_size_mobile }}{% endif %}
          },
          400: {
            perView: {% if compact_mobile_grid %}2{% else %}{{ column_size_mobile_small }}{% endif %}
          }
        }
      }).mount();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', mountFrequentlyBought{{ section.id }});
    } else {
      mountFrequentlyBought{{ section.id }}();
    }

    document.addEventListener('shopify:section:load', function(event) {
      if (event.detail && event.detail.sectionId === '{{ section.id }}') {
        mountFrequentlyBought{{ section.id }}();
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Frequently bought",
  "class": "featured-products",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Title",
      "default": "Frequently bought"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "Feature a hand-picked collection of products that shoppers often add alongside this category."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FFF"
    },
    {
      "type": "collection",
      "id": "source_collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "product_limit",
      "label": "Products to show",
      "default": 8,
      "min": 2,
      "max": 16,
      "step": 1
    },
    {
      "type": "range",
      "id": "autoplay",
      "label": "Autoplay",
      "min": 0,
      "max": 900,
      "default": 0,
      "step": 100,
      "info": "Values are in milliseconds. Example: 600 = 6 seconds."
    },
    {
      "type": "text",
      "id": "see_all_text",
      "label": "See all link text",
      "default": "Shop collection"
    },
    {
      "type": "range",
      "id": "column_size_desktop_extra_large",
      "label": "Column size (desktop extra large) - 1536px and above",
      "default": 4,
      "min": 1,
      "max": 6,
      "step": 0.2
    },
    {
      "type": "range",
      "id": "column_size_desktop_large",
      "label": "Column size (desktop large) - 1280px - 1535px",
      "default": 4,
      "min": 1,
      "max": 6,
      "step": 0.2
    },
    {
      "type": "range",
      "id": "column_size_desktop",
      "label": "Column size (desktop) - 1024px - 1279px",
      "default": 4,
      "min": 1,
      "max": 6,
      "step": 0.2
    },
    {
      "type": "range",
      "id": "column_size_tablet",
      "label": "Column size (tablet) - 641px to 1023px",
      "default": 3,
      "min": 1,
      "max": 6,
      "step": 0.2
    },
    {
      "type": "range",
      "id": "column_size_mobile",
      "label": "Column size (mobile) - 401px - 640px",
      "default": 1.2,
      "min": 1,
      "max": 3,
      "step": 0.2
    },
    {
      "type": "range",
      "id": "column_size_mobile_small",
      "label": "Column size (mobile small) - 400px and below",
      "default": 1.2,
      "min": 1,
      "max": 2,
      "step": 0.2
    },
    {
      "type": "checkbox",
      "id": "hide_arrows_desktop",
      "label": "Hide arrows on desktop?",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_arrows_mobile",
      "label": "Hide arrows on mobile?",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_bullets",
      "label": "Hide bullets?",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "compact_mobile_grid",
      "label": "Compact 2-column grid on mobile",
      "default": true,
      "info": "Shows 2 smaller product cards side by side on mobile instead of 1 full-width."
    },
    {
      "type": "checkbox",
      "id": "hide_atc_on_tiles",
      "label": "Hide Add to Bag button on product cards",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Frequently bought"
    }
  ]
}
{% endschema %}
