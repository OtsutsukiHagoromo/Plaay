{%- comment -%}
  Plaay - New Bars flavour tiles
  Clean white quick-nav tiles for each bar in the collection. The pack render
  (which already carries its own packaging colour) fills the tile edge-to-edge.
  The claim chip reads each product's own sugar claim (arena.aplus_badge_1).
{%- endcomment -%}

{%- liquid
  assign heading = section.settings.heading
  assign limit = section.settings.product_limit | default: 8
-%}

<section class="nlb-tiles" style="--nlb-tiles-bg: {{ section.settings.background_color }};">
  <div class="nlb-tiles__inner">
    {%- if heading != blank -%}
      <h2 class="nlb-tiles__heading font-walsheim-black">{{ heading }}</h2>
    {%- endif -%}
    <div class="nlb-tiles__grid">
      {%- for product in collection.products limit: limit -%}
        {%- liquid
          assign tile_img = product.metafields.arena.aplus_hero_pack.value | default: product.featured_image
          assign tile_claim = product.metafields.arena.aplus_badge_1 | default: '0g Refined Sugar'
        -%}
        <a href="{{ product.url }}" class="nlb-tile">
          <div class="nlb-tile__media">
            {%- if tile_img != blank -%}
              <img class="nlb-tile__img"
                src="{{ tile_img | image_url: width: 700 }}"
                srcset="{{ tile_img | image_url: width: 400 }} 400w, {{ tile_img | image_url: width: 700 }} 700w"
                sizes="(max-width: 767px) 48vw, 300px"
                alt="{{ product.title | escape }}"
                loading="lazy" decoding="async">
            {%- endif -%}
          </div>
          <div class="nlb-tile__body">
            <span class="nlb-tile__title font-walsheim-bold">{{ product.title | replace: 'Slab 6 x', '·' | replace: '6 x', '' }}</span>
            {%- if tile_claim != blank -%}<span class="nlb-tile__tag font-walsheim-bold">{{ tile_claim }}</span>{%- endif -%}
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .nlb-tiles { background: var(--nlb-tiles-bg, #FAF7F2); padding: 64px 24px; }
  .nlb-tiles__inner { max-width: 1200px; margin: 0 auto; }
  .nlb-tiles__heading {
    text-align: center;
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    text-transform: uppercase;
    color: #021D49;
    margin: 0 0 36px;
    letter-spacing: 0.02em;
  }
  .nlb-tiles__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }
  .nlb-tile {
    display: flex;
    flex-direction: column;
    border-radius: 16px;
    overflow: hidden;
    text-decoration: none;
    background: #fff;
    box-shadow: 0 4px 18px rgba(2,29,73,0.08);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .nlb-tile:hover { transform: translateY(-5px); box-shadow: 0 14px 34px rgba(2,29,73,0.16); }
  .nlb-tile__media {
    background: #fff;
    aspect-ratio: 1 / 1;
    overflow: hidden;
  }
  .nlb-tile__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .nlb-tile__body {
    padding: 14px 14px 18px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }
  .nlb-tile__title {
    display: block;
    color: #021D49;
    font-size: 0.9rem;
    line-height: 1.25;
    text-transform: uppercase;
    letter-spacing: 0.01em;
  }
  .nlb-tile__tag {
    display: inline-block;
    background: #021D49;
    color: #F9C61D;
    font-size: 0.62rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 100px;
  }
  @media (max-width: 1023px) { .nlb-tiles__grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 767px) { .nlb-tiles__grid { grid-template-columns: repeat(2, 1fr); gap: 14px; } }
</style>

{% schema %}
{
  "name": "NLB - Flavour Tiles",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Pick Your Flavour" },
    { "type": "range", "id": "product_limit", "label": "Max tiles", "min": 2, "max": 12, "step": 1, "default": 8 },
    { "type": "color", "id": "background_color", "label": "Background colour", "default": "#FAF7F2" }
  ],
  "presets": [ { "name": "NLB - Flavour Tiles" } ]
}
{% endschema %}
