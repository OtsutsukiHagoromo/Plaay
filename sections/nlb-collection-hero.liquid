{%- comment -%}
  Plaay - New Bars collection launch hero
  Two-column launch banner: copy + CTA on one side, the stopmotion loop on the other.
{%- endcomment -%}

{%- liquid
  assign eyebrow = section.settings.eyebrow
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign btn_label = section.settings.button_label
  assign btn_link = section.settings.button_link
-%}

<section class="nlb-chero{% if section.settings.media_left %} nlb-chero--media-left{% endif %}" style="--nlb-chero-bg: {{ section.settings.background_color }};">
  <div class="nlb-chero__inner">
    <div class="nlb-chero__copy">
      {%- if eyebrow != blank -%}<span class="nlb-chero__eyebrow font-walsheim-bold">{{ eyebrow }}</span>{%- endif -%}
      {%- if heading != blank -%}<h1 class="nlb-chero__title font-walsheim-black">{{ heading }}</h1>{%- endif -%}
      {%- if subheading != blank -%}<p class="nlb-chero__sub font-walsheim">{{ subheading }}</p>{%- endif -%}
      {%- if btn_label != blank -%}
        <a href="{{ btn_link | default: '#nlb-grid' }}" class="nlb-chero__btn font-walsheim-bold">{{ btn_label }}</a>
      {%- endif -%}
    </div>
    <div class="nlb-chero__media">
      {%- render 'nlb-stopmotion', fps: section.settings.fps, alt: heading, id: section.id -%}
    </div>
  </div>
</section>

<style>
  .nlb-chero {
    background: var(--nlb-chero-bg, #021D49);
    padding: 56px 24px;
  }
  .nlb-chero__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
    align-items: center;
  }
  .nlb-chero--media-left .nlb-chero__copy { order: 2; }
  .nlb-chero--media-left .nlb-chero__media { order: 1; }
  .nlb-chero__eyebrow {
    display: inline-block;
    background: #E85767;
    color: #fff;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 100px;
    margin-bottom: 20px;
  }
  .nlb-chero__title {
    font-size: clamp(2.4rem, 4.6vw, 4rem);
    line-height: 1.02;
    text-transform: uppercase;
    color: #fff;
    margin: 0 0 18px;
  }
  .nlb-chero__sub {
    font-size: 1.05rem;
    color: rgba(255,255,255,0.78);
    line-height: 1.6;
    max-width: 430px;
    margin: 0 0 28px;
  }
  .nlb-chero__btn {
    display: inline-block;
    background: #F9C61D;
    color: #021D49;
    font-size: 0.9rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 16px 36px;
    border-radius: 100px;
    transition: transform 0.2s, background 0.2s;
  }
  .nlb-chero__btn:hover { transform: translateY(-2px); background: #ffd84a; color: #021D49; text-decoration: none; }
  .nlb-chero__media {
    position: relative;
    aspect-ratio: 4 / 3;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 18px 48px rgba(0,0,0,0.4);
  }
  @media (max-width: 767px) {
    .nlb-chero { padding: 40px 20px; }
    .nlb-chero__inner { grid-template-columns: 1fr; gap: 28px; text-align: center; }
    .nlb-chero--media-left .nlb-chero__copy,
    .nlb-chero--media-left .nlb-chero__media { order: initial; }
    .nlb-chero__sub { margin-left: auto; margin-right: auto; }
    .nlb-chero__media { aspect-ratio: 1 / 1; order: -1; }
  }
</style>

{% schema %}
{
  "name": "NLB - Collection Hero",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "New Launch · Available Now" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Clean Chocolate Slabs. Just Dropped." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Seven new slabs. 70% dark and creamy milk chocolate. 100% clean ingredients, zero refined sugar." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop the launch" },
    { "type": "url", "id": "button_link", "label": "Button link (defaults to product grid)" },
    { "type": "range", "id": "fps", "label": "Stopmotion speed (fps)", "min": 4, "max": 16, "step": 1, "default": 10 },
    { "type": "checkbox", "id": "media_left", "label": "Put animation on the left", "default": false },
    { "type": "color", "id": "background_color", "label": "Background colour", "default": "#021D49" }
  ],
  "presets": [ { "name": "NLB - Collection Hero" } ]
}
{% endschema %}
