{% liquid 
  assign cart_total_background = section.settings.cart_total_background
  assign cart_total_text_color = section.settings.cart_total_text_color
  assign textarea_title = section.settings.textarea_title
%}
{% style %}
  .cart_total_container{
    background: {{ cart_total_background }};
    color: {{ cart_total_text_color }};
  }
  @media only screen and (min-width: 1023px){
    .cart_total_container{
      -webkit-box-shadow: 0px 0px 19px -1px rgba(0,0,0,0.6);
      -moz-box-shadow: 0px 0px 19px -1px rgba(0,0,0,0.6);
      box-shadow: 0px 0px 19px -1px rgba(0,0,0,0.6);
    }
  }
  @media only screen and (max-width: 1023px){
    .cart_total_container::before{
      content: '';
      background: {{ cart_total_background }};
      position: absolute;
      right: -100%;
      top: 0;
      width: 100%;
      height: 100%;
    }
    .cart_total_container::after{
      content: '';
      background: {{ cart_total_background }};
      position: absolute;
      left: -100%;
      top: 0;
      width: 100%;
      height: 100%;
    }
  }
  {% if textarea_title != blank %}
    .cart_total_container .textarea_container::before{
      content: '{{ textarea_title }}';
      font-size: 16px;
      color: #021D49;
      font-family: 'walsheim-regular';
      font-weight: 700;
      position: absolute;
      left: 12px;
      top: 8px;
    }
    @media only screen and (min-width: 1023px){
      .cart_total_container .textarea_container::before{
        font-size: 14px;
        top: 10px;
      }
    }
  {% endif %}
{% endstyle %}

{% comment %} for some reason, the product recommendations don't work without this, no idea why {% endcomment %}
<quick-add data-module="quick-add"></quick-add>
<div data-cart-page-root>
  {%- render 'cart-items' -%}
</div>

{% schema %}
  {
    "name": "Cart",
    "settings": [
      {
        "type": "color",
        "id": "cart_total_background",
        "label": "Cart total background",
        "default": "#7D3582"
      },
      {
        "type": "color",
        "id": "cart_total_text_color",
        "label": "Cart total text color",
        "default": "#FFF"
      },
      {
        "type": "text",
        "id": "textarea_placeholder",
        "label": "Textarea placeholder",
        "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elitsed do eiusmod tempor incididunt ut labore et"
      },
      {
        "type": "text",
        "id": "textarea_title",
        "label": "Textarea title",
        "default": "Order Notes"
      },
      {
        "type": "checkbox",
        "id": "hide_product_recommendations",
        "label": "Hide product recommendations?",
        "default": false
      },
      {
        "type": "text",
        "id": "product_recommendations_title",
        "label": "Product recommendations title",
        "default": "New"
      },
      {
        "type": "checkbox",
        "id": "hide_taxes",
        "label": "Hide taxes?",
        "default": false
      },
      {
        "type": "checkbox",
        "id": "hide_fixed_checkout",
        "label": "Hide fixed checkout",
        "info": "This will hide the fixed checkout feature that appears on mobile to allow users to checkout from anywhere on the page.",
        "default": false
      },
      {
        "type": "header",
        "content": "Empty cart state"
      },
      {
        "type": "url",
        "id": "continue_shopping_link",
        "label": "Continue shopping link",
        "default": "/"
      },
      {
        "id": "continue_shopping_text",
        "type": "text",
        "label": "Continue shopping text",
        "default": "Continue shopping"
      },
      {
        "type": "text",
        "id": "empty_cart_text",
        "label": "Empty cart text",
        "default": "Looks like your cart is empty..."
      }
    ]
  }
{% endschema %}
