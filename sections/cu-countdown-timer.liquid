{% schema %}
{
  "name": "Countdown Timer",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "SALE ENDS IN:"
    },
    {
      "type": "text",
      "id": "end_time",
      "label": "End Time (YYYY-MM-DDTHH:MM:SS)",
      "default": "2025-12-31T23:59:59",
      "info": "Enter end time in ISO format, e.g. 2025-09-15T23:59:59"
    }
  ],
  "presets": [
    {
      "name": "Countdown Timer"
    }
  ]
}
{% endschema %}

<div class="main">
  <div class="title-main">
    <div class="timer-title">{{ section.settings.title }}</div>
  </div>
  <div class="timer-container">
    <div class="timer" id="countdown-{{ section.id }}">
      <div class="time-block">
        <div class="time-label">Days</div>
        <div class="time-value" id="days-{{ section.id }}">
          <span class="digit">0</span>
          <span class="digit">0</span>
        </div>
      </div>
      <div class="time-block">
        <div class="time-label">Hours</div>
        <div class="time-value" id="hours-{{ section.id }}">
          <span class="digit">0</span>
          <span class="digit">0</span>
        </div>
      </div>
      <div class="time-block">
        <div class="time-label">Minutes</div>
        <div class="time-value" id="minutes-{{ section.id }}">
          <span class="digit">0</span>
          <span class="digit">0</span>
        </div>
      </div>
      <div class="time-block">
        <div class="time-label">Seconds</div>
        <div class="time-value" id="seconds-{{ section.id }}">
          <span class="digit">0</span>
          <span class="digit">0</span>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
.main {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 10px;
}
.title-main {
  padding: 10px 35px;
  background-color: #f9c61d;
  margin-bottom: -30px;
  z-index: 999;
  border-radius: 7px;
  box-shadow: 0px 4px 50px 4px rgba(0,0,0,0.1);
}
.timer-container {
  border: 1px solid darkgrey;
  background: #F5F5F5;
  padding: 20px 20px;
  border-radius: 15px;
  box-shadow: 5px 4px 0px 3px rgba(128,128,128,0.3);
  text-align: center;
  max-width: 500px;
  width: 100%;
  margin: auto;
}
.timer-title {
  font-weight: bold;
  font-size: 20px;
  letter-spacing: 2px;
  font-style: italic;
  color: #021D49;
}
.timer {
  display: flex;
  justify-content: center;
  gap: 20px;
  background: #021D49;
  padding: 20px;
  border-radius: 12px;
  color: #fff;
}
.time-block {
  text-align: center;
}
.time-label {
  font-size: 18px;
  margin-bottom: 5px;
}
.time-value {
  display: flex;
  gap: 3px;
}
.digit {
  background: #eee;
  color: #000;
  font-size: 28px;
  font-weight: bold;
  padding: 4px 14px;
  border-radius: 6px;
  box-shadow: inset 0 -2px 4px rgba(0,0,0,0.15);
  font-family: monospace;
  display: inline-block;
  text-align: center;
  min-width: 32px;
}
@media (max-width: 768px) {
 
  .timer {
    gap: 20px;
    padding: 12px;
  }

  .time-label {
    font-size: 14px;
  }

  .digit {
    font-size: 20px;
    padding: 3px 8px;
  }

  .timer-title {
    font-size: 16px;
    text-align: center;
  }

  .timer-container {
    padding: 15px;
  }
}

@media (max-width: 480px) {
   .main {
    max-width: 400px;
    margin: 20px auto;
}
  .timer {
    gap: 10px;
    padding: 20px 10px;
  }

  .time-label {
    font-size: 12px;
  }

  .digit {
    font-size: 28px;
    padding: 2px 12px;
  }

  .timer-title {
    font-size: 14px;
  }
}
@media (min-width: 300px){
  .digit {
    font-size: 28px;
    padding: 2px 10px;
  }
}

</style>

<script>
document.addEventListener("DOMContentLoaded", function () {
  var countdownElement = document.getElementById("countdown-{{ section.id }}");
  var endTime = new Date("{{ section.settings.end_time }}").getTime();

  function updateTimer() {
    var now = new Date().getTime();
    var distance = endTime - now;

    if (distance <= 0) {
      countdownElement.innerHTML = "<strong>SALE ENDED</strong>";
      clearInterval(interval);
      return;
    }

    var days = Math.floor(distance / (1000 * 60 * 60 * 24));
    var hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    var minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
    var seconds = Math.floor((distance % (1000 * 60)) / 1000);

    days = String(days).padStart(2, '0');
    hours = String(hours).padStart(2, '0');
    minutes = String(minutes).padStart(2, '0');
    seconds = String(seconds).padStart(2, '0');

    setDigits("days-{{ section.id }}", days);
    setDigits("hours-{{ section.id }}", hours);
    setDigits("minutes-{{ section.id }}", minutes);
    setDigits("seconds-{{ section.id }}", seconds);
  }

  function setDigits(id, value) {
    var container = document.getElementById(id);
    if (!container) return;
    var digits = container.querySelectorAll(".digit");
    digits[0].textContent = value[0];
    digits[1].textContent = value[1];
  }

  updateTimer();
  var interval = setInterval(updateTimer, 1000);
});
</script>
