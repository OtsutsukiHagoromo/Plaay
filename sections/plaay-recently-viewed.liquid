{% comment %}
  plaay-recently-viewed.liquid
  Tracks the last N products a visitor browsed (localStorage key: plaay_rv).
  On load, JS fetches each handle via /products/{handle}.js and renders cards.
  The section stays hidden until at least 1 card is ready.
{% endcomment %}

<section
  class="plaay-recently-viewed"
  id="plaay-rv-{{ section.id }}"
  data-section-id="{{ section.id }}"
  {% unless request.design_mode %}style="display:none"{% endunless %}
  aria-label="{{ section.settings.heading | default: 'Recently Viewed' }}">

  <div class="container py-10 | md:py-14">
    <h2 class="plaay-rv__heading font-walsheim-black text-dark-blue uppercase text-2xl mb-6">
      {{ section.settings.heading | default: 'Recently Viewed' }}
    </h2>
    <div class="plaay-rv__empty" id="plaay-rv-empty-{{ section.id }}"{% unless request.design_mode %} hidden{% endunless %}>
      <p class="font-walsheim text-dark-blue">
        This section fills automatically after shoppers browse a few products.
      </p>
    </div>
    <div class="plaay-rv__grid" id="plaay-rv-grid-{{ section.id }}">
      <!-- filled by JS -->
    </div>
  </div>
</section>

{% style %}
  .plaay-rv__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }
  .plaay-rv__empty {
    padding: 18px 20px;
    border: 1px dashed rgba(2,29,73,0.18);
    border-radius: 14px;
    background: rgba(2,29,73,0.03);
    margin-bottom: 16px;
  }
  @media (min-width: 640px)  { .plaay-rv__grid { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 1024px) { .plaay-rv__grid { grid-template-columns: repeat({{ section.settings.max_products | default: 6 | at_most: 6 }}, 1fr); } }

  .plaay-rv-card {
    display: block;
    text-decoration: none;
    border-radius: 14px;
    overflow: hidden;
    background: #fff;
    border: 1px solid rgba(2,29,73,0.08);
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .plaay-rv-card:hover {
    box-shadow: 0 6px 20px rgba(2,29,73,0.12);
    transform: translateY(-2px);
  }
  .plaay-rv-card__img {
    aspect-ratio: 1;
    overflow: hidden;
    background: #f5f5f5;
  }
  .plaay-rv-card__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .plaay-rv-card__info {
    padding: 10px 12px 12px;
  }
  .plaay-rv-card__title {
    font-size: 0.8rem;
    line-height: 1.3;
    color: #021D49;
    margin: 0 0 4px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .plaay-rv-card__price {
    font-size: 0.95rem;
    color: #021D49;
    margin: 0;
  }
{% endstyle %}

<script>
(function() {
  var STORAGE_KEY  = 'plaay_rv';
  var SECTION_ID   = '{{ section.id }}';
  var MAX          = {{ section.settings.max_products | default: 6 }};
  var CURRENT      = '{{ product.handle | default: '' }}';

  /* ── 1. Track current page ── */
  function trackCurrent() {
    if (!CURRENT) return;
    try {
      var list = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
      list = list.filter(function(h) { return h !== CURRENT; });
      list.unshift(CURRENT);
      localStorage.setItem(STORAGE_KEY, JSON.stringify(list.slice(0, 30)));
    } catch(e) {}
  }
  trackCurrent();

  /* ── 2. Render previously seen products ── */
  function render() {
    try {
      var list = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
      /* exclude the product currently being viewed */
      list = list.filter(function(h) { return h !== CURRENT; }).slice(0, MAX);
      var section = document.getElementById('plaay-rv-' + SECTION_ID);
      var grid    = document.getElementById('plaay-rv-grid-' + SECTION_ID);
      var empty   = document.getElementById('plaay-rv-empty-' + SECTION_ID);
      if (!section || !grid) return;
      if (!list.length) {
        if (empty) empty.hidden = false;
        return;
      }

      var pending = list.length;
      var results = {};

      list.forEach(function(handle) {
        fetch('/products/' + handle + '.js')
          .then(function(r) { return r.ok ? r.json() : null; })
          .then(function(p) {
            if (p) results[handle] = p;
          })
          .catch(function() {})
          .finally(function() {
            pending--;
            if (pending === 0) renderCards(list, results, section, grid, empty);
          });
      });
    } catch(e) {}
  }

  function formatMoney(cents) {
    var n = (cents / 100).toFixed(2);
    return 'AED ' + (n.endsWith('.00') ? n.slice(0, -3) : n);
  }

  function renderCards(order, data, section, grid, empty) {
    var html = '';
    order.forEach(function(handle) {
      var p = data[handle];
      if (!p) return;
      var imgSrc = p.featured_image
        ? p.featured_image.replace(/\.(jpg|jpeg|png|gif|webp)(\?.*)?$/i, '_400x400.$1')
        : '';
      var price = formatMoney(p.price_min);
      html +=
        '<a href="/products/' + handle + '" class="plaay-rv-card">' +
          (imgSrc
            ? '<div class="plaay-rv-card__img"><img src="' + imgSrc + '" alt="' + p.title.replace(/"/g,'&quot;') + '" loading="lazy" width="400" height="400"></div>'
            : '') +
          '<div class="plaay-rv-card__info">' +
            '<p class="plaay-rv-card__title font-walsheim-bold">' + p.title + '</p>' +
            '<p class="plaay-rv-card__price font-walsheim-black">' + price + '</p>' +
          '</div>' +
        '</a>';
    });
    if (!html) return;
    grid.innerHTML = html;
    if (empty) empty.hidden = true;
    section.style.display = '';
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', render);
  } else {
    render();
  }

  document.addEventListener('shopify:section:load', function(event) {
    if (event.detail && event.detail.sectionId === SECTION_ID) {
      render();
    }
  });
})();
</script>

{% schema %}
{
  "name": "Recently Viewed",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Recently Viewed"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Max products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6
    }
  ],
  "presets": [
    {
      "name": "Recently Viewed"
    }
  ]
}
{% endschema %}
