

{%- style -%}
  {% if section.settings.enable_style %}
    .section-{{ section.id }} {
      padding-top: {{ section.settings.spacing_top_desktop }}px;
      padding-bottom: {{ section.settings.spacing_bottom_desktop }}px;
    }
    @media(max-width: 767px) {
      .section-{{ section.id }} {
        padding-top: {{ section.settings.spacing_top_mobile }}px;
        padding-bottom: {{ section.settings.spacing_bottom_mobile }}px;
      }      
    }
  {% endif %}
  {% if section.settings.full_width == false %}
    .section-{{ section.id }} {
      max-width: 1536px;
      padding-inline: 20px;
      margin-inline:auto;
    }
  {% endif %}
{%- endstyle -%} 

<div class="isolate">
  <div class="rich-text rich-text-by-trellis content-container section-{{ section.id }} twcss-bg-center twcss-bg-no-repeat" style="background-color: {{ section.settings.bkg_color }};">
    <div class="rich-text__blocks">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'heading' -%}
          {% style %}
            .heading-{{ block.id }} {
              margin:0;
              font-size: {{ block.settings.font_size_desktop}}px;
                padding-top: {{ block.settings.spacing_top_desktop }}px;
                padding-bottom: {{ block.settings.spacing_bottom_desktop }}px;
              line-height: normal;
            }
            @media(max-width: 767px) {
              .heading-{{ block.id }} {
                font-size: {{ block.settings.font_size_mobile}}px;
                padding-top: {{ block.settings.spacing_top_mobile }}px;
                padding-bottom: {{ block.settings.spacing_bottom_mobile }}px;
              }            
            }
          {% endstyle %}
            <h2 class="{{ block.settings.heading_size }} heading-{{ block.id }} text-center text-center" {{ block.shopify_attributes }} style="color: {{ block.settings.color }}; text-transform: uppercase;">{{ block.settings.heading | escape }}</h2>
          {%- when 'text' -%}
           {% style %}
             .rte-{{ block.id }} {
                padding-top: {{ block.settings.spacing_top_desktop }}px;
                padding-bottom: {{ block.settings.spacing_bottom_desktop }}px;
             }
            .rte-{{ block.id }},
             .rte-{{ block.id }} * {
              margin:0;
              font-size: {{ block.settings.font_size_desktop}}px;
              line-height: normal;
            }
            @media(max-width: 767px) {
              .rte-{{ block.id }} {
                padding-top: {{ block.settings.spacing_top_mobile }}px;
                padding-bottom: {{ block.settings.spacing_bottom_mobile }}px;
             }
              .rte-{{ block.id }},
              .rte-{{ block.id }} * {
                font-size: {{ block.settings.font_size_mobile}}px;
              }            
            }
          {% endstyle %}
            <div class="rich-text__text rte rte-{{ block.id }} text-center" {{ block.shopify_attributes }} style="color: {{ block.settings.color }}">{{ block.settings.text }}</div>
          {%- when 'button' -%}
          {% style %}
            .button-{{ block.id }} {
              margin:0;
              font-size: {{ block.settings.font_size_desktop}}px;
                padding-top: {{ block.settings.spacing_top_desktop }}px;
                padding-bottom: {{ block.settings.spacing_bottom_desktop }}px;
            }
            @media(max-width: 767px) {
              .button-{{ block.id }} {
                font-size: {{ block.settings.font_size_mobile}}px;
                padding-top: {{ block.settings.spacing_top_mobile }}px;
                padding-bottom: {{ block.settings.spacing_bottom_mobile }}px;
              }            
            }
          {% endstyle %}
          <a {% if block.settings.button_link == blank %} role="link" aria-disabled="true"{% else %} href="{{ block.settings.button_link }}"{% endif %}  class="button-{{ block.id }} custom-view-aall block uppercase underline text-sm underline-offset-2 font-walsheim-bold mt-12 text-center transition-all duration-200 text-dark-blue | hover:no-underline">
               {{ block.settings.button_label | escape }}
              </a>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</div>

