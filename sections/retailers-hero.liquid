{% style %}
  .rh-wrap {
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
  }
  .rh-inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: flex-end;
    min-height: 320px;
    padding-top: 120px;
    padding-bottom: 56px;
  }
  @media (min-width: 768px) {
    .rh-inner { min-height: 380px; padding-top: 160px; padding-bottom: 72px; }
  }
  .rh-eyebrow {
    font-family: walsheim-bold, sans-serif;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.5;
    margin-bottom: 16px;
  }
  .rh-headline {
    font-family: walsheim-black, sans-serif;
    font-size: clamp(44px, 8vw, 96px);
    line-height: 0.95;
    margin-bottom: 20px;
    max-width: 800px;
  }
  .rh-sub {
    font-family: walsheim, sans-serif;
    font-size: 17px;
    line-height: 1.6;
    opacity: 0.7;
    max-width: 480px;
    margin-bottom: 32px;
  }
  .rh-cta {
    display: inline-block;
    background: {{ section.settings.cta_bg }};
    color: {{ section.settings.cta_color }};
    border-radius: 999px;
    padding: 14px 36px;
    font-family: walsheim-bold, sans-serif;
    font-size: 14px;
    text-decoration: none;
    transition: opacity 0.2s, transform 0.2s;
  }
  .rh-cta:hover { opacity: 0.85; transform: translateY(-2px); }
  .rh-stat-row {
    display: flex;
    flex-wrap: wrap;
    gap: 32px;
    margin-top: 40px;
    padding-top: 32px;
    border-top: 1.5px solid currentColor;
    opacity: 0.8;
    width: 100%;
    max-width: 600px;
  }
  .rh-stat-num {
    font-family: walsheim-black, sans-serif;
    font-size: 36px;
    line-height: 1;
    margin-bottom: 4px;
  }
  .rh-stat-label {
    font-family: walsheim, sans-serif;
    font-size: 13px;
    opacity: 0.7;
  }
{% endstyle %}

<div class="rh-wrap">
  <div class="container">
    <div class="rh-inner">
      {% if section.settings.eyebrow != blank %}
        <p class="rh-eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h1 class="rh-headline">{{ section.settings.headline }}</h1>
      {% if section.settings.subheadline != blank %}
        <p class="rh-sub">{{ section.settings.subheadline }}</p>
      {% endif %}
      {% if section.settings.cta_label != blank %}
        <a href="{{ section.settings.cta_url }}" class="rh-cta">{{ section.settings.cta_label }}</a>
      {% endif %}
      {% if section.settings.stat_1_num != blank or section.settings.stat_2_num != blank or section.settings.stat_3_num != blank %}
        <div class="rh-stat-row">
          {% if section.settings.stat_1_num != blank %}
            <div>
              <div class="rh-stat-num">{{ section.settings.stat_1_num }}</div>
              <div class="rh-stat-label">{{ section.settings.stat_1_label }}</div>
            </div>
          {% endif %}
          {% if section.settings.stat_2_num != blank %}
            <div>
              <div class="rh-stat-num">{{ section.settings.stat_2_num }}</div>
              <div class="rh-stat-label">{{ section.settings.stat_2_label }}</div>
            </div>
          {% endif %}
          {% if section.settings.stat_3_num != blank %}
            <div>
              <div class="rh-stat-num">{{ section.settings.stat_3_num }}</div>
              <div class="rh-stat-label">{{ section.settings.stat_3_label }}</div>
            </div>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Retailers Hero",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#F9C61D"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#021D49"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Find us near you"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Where we're Plaayin'"
    },
    {
      "type": "textarea",
      "id": "subheadline",
      "label": "Subheadline",
      "default": "Find Plaay at your favourite stores, delivery platforms, cafes, and hotels across the UAE."
    },
    {
      "type": "header",
      "content": "CTA Button"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    },
    {
      "type": "color",
      "id": "cta_bg",
      "label": "Button background",
      "default": "#021D49"
    },
    {
      "type": "color",
      "id": "cta_color",
      "label": "Button text color",
      "default": "#F9C61D"
    },
    {
      "type": "header",
      "content": "Stats (optional)"
    },
    {
      "type": "text",
      "id": "stat_1_num",
      "label": "Stat 1 number"
    },
    {
      "type": "text",
      "id": "stat_1_label",
      "label": "Stat 1 label"
    },
    {
      "type": "text",
      "id": "stat_2_num",
      "label": "Stat 2 number"
    },
    {
      "type": "text",
      "id": "stat_2_label",
      "label": "Stat 2 label"
    },
    {
      "type": "text",
      "id": "stat_3_num",
      "label": "Stat 3 number"
    },
    {
      "type": "text",
      "id": "stat_3_label",
      "label": "Stat 3 label"
    }
  ],
  "presets": [
    {
      "name": "Retailers Hero"
    }
  ]
}
{% endschema %}
