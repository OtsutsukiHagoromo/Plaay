        "type": "grid_articles_rounded",
        "name": "Grid articles (rounded)",
        "settings": [
          {
            "type": "color",
            "id": "background_color",
            "label": "Background color",
            "default": "#FFFFFF"
          },
          {
            "type": "range",
            "id": "padding_top_mobile",
            "label": "Padding top (mobile) - px",
            "min": 0,
            "max": 120,
            "step": 2,
            "default": 30
          },
