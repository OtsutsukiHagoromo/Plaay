{% liquid 
  assign title = section.settings.title
%}

<div class="pt-28 | lg:pt-36">
  {% if title != blank %}
    <h1 class="text-center text-dark-blue text-5xl | lg:text-7xl">{{ title }}</h1>
  {% endif %}
  <div class="pt-10 | lg:pt-14">
    {% for block in section.blocks %}
      {% if block.type == 'featured_article' %}
        {% render 'archive_featured_article', block: block %}
      {% elsif block.type == 'archive_grid_articles' %}
        {% render 'archive_grid_articles', block: block %}
      {% elsif block.type == 'grid_articles_rounded' %}
        {% render 'archive_grid_articles_rounded', block: block %}
      {% endif %}
    {% endfor %}
  </div>
</div>
{% schema %}
  {
    "name": "Blog archive template",
    "settings": [
      {
        "type": "text",
        "id": "title",
        "label": "Title",
        "default": "Blog archive"
      }
    ],
    "blocks": [
