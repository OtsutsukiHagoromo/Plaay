{% liquid
  assign background_color = section.settings.background_color
  assign background_color_mobile = section.settings.background_color_mobile
  assign announcement_blocks = section.blocks | where: 'type', 'announcement_text'
  assign announcement_text_size = announcement_blocks | size

  assign total_chars = 0
  for block in announcement_blocks
    assign total_chars = total_chars | plus: block.settings.text.size
  endfor
  assign marquee_duration = total_chars | divided_by: 5
  if marquee_duration < 14
    assign marquee_duration = 14
  endif
  if marquee_duration > 40
    assign marquee_duration = 40
  endif
%}

{% style %}
  .announcement_bar {
    background-color: {{ background_color }};
    height: 40px;
    overflow: hidden;
  }
  .announcement_bar__track {
    display: flex;
    align-items: center;
    height: 40px;
    overflow: hidden;
  }
  .announcement_bar__marquee {
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
    animation: plaay-marquee {{ marquee_duration }}s linear infinite;
    will-change: transform;
  }
  .announcement_bar__marquee:hover {
    animation-play-state: paused;
  }
  .announcement_bar__item {
    display: inline-flex;
    align-items: center;
    font-size: 12px;
    font-weight: bold;
    letter-spacing: 0.07em;
    padding-right: 0;
  }
  .announcement_bar__sep {
    display: inline-block;
    margin: 0 24px;
    opacity: 0.45;
    font-size: 9px;
    line-height: 1;
  }
  @keyframes plaay-marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  @media only screen and (max-width: 768px) {
    .announcement_bar {
      background-color: {{ background_color_mobile }};
    }
    .announcement_bar__item {
      font-size: 11px;
    }
  }
{% endstyle %}

{% if announcement_text_size > 0 %}
  <announcement-bar data-module="announcement-bar">
    <div class="announcement_bar fixed top-0 w-full z-10">
      <div class="announcement_bar__track">
        <div class="announcement_bar__marquee">
          {%- comment -%} First copy {%- endcomment -%}
          {%- for block in announcement_blocks -%}
            {%- assign text = block.settings.text -%}
            {%- assign text_color = block.settings.text_color -%}
            {%- assign text_color_mobile = block.settings.text_color_mobile -%}
            {%- assign text_style = block.settings.text_style -%}
            {%- if text != blank -%}
              <span
                class="announcement_bar__item {{ text_style }}"
                style="color: {{ text_color }};"
                {{ block.shopify_attributes }}
              >{{ text }}</span><span class="announcement_bar__sep" aria-hidden="true">✦</span>
            {%- endif -%}
          {%- endfor -%}
          {%- comment -%} Duplicate for seamless loop {%- endcomment -%}
          {%- for block in announcement_blocks -%}
            {%- assign text = block.settings.text -%}
            {%- assign text_color = block.settings.text_color -%}
            {%- assign text_style = block.settings.text_style -%}
            {%- if text != blank -%}
              <span
                class="announcement_bar__item {{ text_style }}"
                style="color: {{ text_color }};"
                aria-hidden="true"
              >{{ text }}</span><span class="announcement_bar__sep" aria-hidden="true">✦</span>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  </announcement-bar>
{% endif %}


{% schema %}
  {
    "name": "Announcement Bar",
    "blocks": [
      {
        "type": "announcement_text",
        "name": "Announcement text",
        "settings": [
          {
            "type": "text",
            "id": "text",
            "label": "Text"
          },
          {
            "type": "color",
            "id": "text_color",
            "label": "Text color",
            "default": "#021D49"
          },
          {
            "type": "color",
            "id": "text_color_mobile",
            "label": "Text color (mobile)",
            "default": "#021D49"
          },
          {
            "type": "select",
            "id": "text_style",
            "label": "Text style",
            "options": [
              {
                "value": "uppercase",
                "label": "Uppercase"
              },
              {
                "value": "lowercase",
                "label": "Lowercase"
              },
              {
                "value": "capitalize",
                "label": "Capitalize"
              }
            ]
          }
        ]
      }
    ],
    "settings": [
      {
        "type": "color",
        "id": "background_color",
        "label": "Background color",
        "default": "#FFF"
      },
      {
        "type": "color",
        "id": "background_color_mobile",
        "label": "Background color (mobile)",
        "default": "#F9C61D"
      }
    ]
  }
{% endschema %}
