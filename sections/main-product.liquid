{% liquid 
  assign background_color = section.settings.background_color
  assign show_description = section.settings.show_description
  assign show_exact_ingredients = section.settings.show_exact_ingredients

  assign usp_images = product.metafields.custom.usp_image.value
  assign usp_text = product.metafields.arena.usp_text.value
  assign exact_ingredients = product.metafields.arena.exact_ingredients
  assign subtitle_text = product.metafields.arena.subtitle_text

  assign product_images_size = product.images | size

  assign allergens    = product.metafields.arena.allergens
  assign cal_val      = product.metafields.arena.calories
  assign protein_val  = product.metafields.arena.protein
  assign carbs_val    = product.metafields.arena.carbs
  assign fats_val     = product.metafields.arena.fats
  assign sugar_val    = product.metafields.arena.sugar
  assign fiber_val    = product.metafields.arena.fiber
  assign storage_tips = product.metafields.arena.storage_tips
  assign has_nutrition = false
  if cal_val != blank or protein_val != blank or carbs_val != blank or fats_val != blank or sugar_val != blank or fiber_val != blank
    assign has_nutrition = true
  endif
%}

{% style %}
  #product-gallery-thumbnails-{{ section.id }} .glide__slide--active img{
    border: 2px solid #FFF;
  } 
{% endstyle %}

<quantity-adjuster data-module="quantity-adjuster">
  <div class="hidden"></div>
</quantity-adjuster>
<quick-add data-module="quick-add"></quick-add>


<div style="background-color: {{ background_color }};">
  <div class="container flex flex-col py-14 | md:pb-16 md:pt-44 | lg:flex-row">
    {% comment %} main gallery {% endcomment %}
    <div class="w-full relative | lg:w-[55%]">
      {%- render 'plaay-badge', product: product -%}
      <div {% if product_images_size > 1 %} class="glide" {% endif %} id="product-gallery-{{ section.id }}">
        {% if product_images_size > 1 %}
          <div class="glide__arrows z-10 flex items-center justify-center w-full | lg:mb-0 lg:mt-0 lg:ml-10 lg:w-auto" data-glide-el="controls">
            <button data-glide-dir="<" class="glide__arrow glide__arrow--left text-0 group absolute z-1 left-0 top-1/2 transform -translate-y-1/2 mr-5 | lg:-left-8">
              slide left
              <span class="flex h-6 w-6 transform rotate-180 text-dark-blue transition-all duration-200 | group-hover:opacity-100">
                {% render 'icon-slider-arrow' %}
              </span>
            </button>
            <button data-glide-dir=">" class="glide__arrow glide__arrow--right text-0 group absolute right-0 z-1 top-1/2 transform -translate-y-1/2 ml-5 | lg:-right-8">
              slide right
              <span class="flex h-6 w-6 text-dark-blue transition-all duration-200 | group-hover:opacity-100">
                {% render 'icon-slider-arrow' %}
              </span>
            </button>
          </div>
        {% endif %}
        <div {% if product_images_size > 1 %} class="glide__track w-full max-w-[800px] mx-auto" data-glide-el="track" {% endif %}>
          <ul {% if product_images_size > 1 %} class="glide__slides" {% endif %}>
            {% for image in product.images %}
              <li {% if product_images_size > 1 %} class="glide__slide px-8 | md:px-0" {% endif %} data-index="{{ forloop.index0 }}">
                {% render 'img', type: 'img', img: image, eager: true, class: 'object-contain h-[420px] mx-auto lg:w-full lg:h-[600px] xl:object-cover', height: 420, width: 550, forloop_data: forloop.index %}
              </li>
            {% endfor %}
          </ul>
        </div>
        {% if product_images_size > 1 %}
          <div class="glide__bullets flex items-center justify-center my-5 | md:hidden" data-glide-el="controls[nav]">
            {% for image in product.images %}
              <button class="glide__bullet h-4 w-4 bg-dark-blue opacity-50 rounded-full transition-all duration-200 {% unless forloop.first %} ml-3 {% endunless %}" data-glide-dir="={{ forloop.index0 }}"></button>
            {% endfor %}
          </div>
        {% endif %}
      </div>
      {% comment %} thumbnail slider {% endcomment %}
      {% if product_images_size > 1 %}
        <div class="glide mt-2 max-w-md mx-auto hidden | md:block" id="product-gallery-thumbnails-{{ section.id }}">
          <div class="glide__arrows z-10 flex items-center justify-center w-full mt-8 mb-14 | md:mb-0 md:mt-0 md:ml-10 md:w-auto" data-glide-el="controls">
            <button data-glide-dir="<" class="glide__arrow glide__arrow--left text-0 group absolute -left-16 top-1/2 transform -translate-y-1/2 mr-5 | lg:-left-8 ">
              slide left
              <span class="flex h-6 w-6 transform rotate-180 text-dark-blue opacity-30 transition-all duration-200 | group-hover:opacity-100">
                {% render 'icon-slider-arrow' %}
              </span>
            </button>
            <button data-glide-dir=">" class="glide__arrow glide__arrow--right text-0 group absolute -right-16 top-1/2 transform -translate-y-1/2 ml-5 | lg:-right-8">
              slide right
              <span class="flex h-6 w-6 text-dark-blue opacity-30 transition-all duration-200 | group-hover:opacity-100">
                {% render 'icon-slider-arrow' %}
              </span>
            </button>
          </div> 
          <div class="glide__track max-w-[380px] mx-auto" data-glide-el="track">
            <ul class="glide__slides">
              {% for image in product.images %}
                <li class="glide__slide thumbnail_slide">
                  <div class="block h-20 w-20 border-0.5 border-opacity-20 border-black">
                    {% render 'img', type: 'img', img: image, eager: true, class: 'object-contain mx-auto h-full cursor-pointer w-full', forloop_data: forloop.index0 %}
                  </div>
                </li>
              {% endfor %}
            </ul>
          </div>
        </div>
      {% endif %}
    </div>
    {% comment %} product information {% endcomment %}
    <div class="w-full mt-5 | lg:mt-0 lg:w-1/2 lg:flex lg:flex-col lg:justify-center lg:max-w-md lg:ml-10 | xl:ml-14 | 2xl:ml-20">
      {% comment %} title {% endcomment %}
      <h1 class="text-5xl leading-none uppercase text-dark-blue font-walsheim-bold pdp-title"> {{ product.title }} </h1>

      
             <!-- Add Offer Callout Block Here -->
{% for block in section.blocks %}
  {% if block.type == 'offer_callout' %}
    <div class="product-block-offer-callout" {{ block.shopify_attributes }}>
      <svg class="clip-left" width="27" height="62" viewBox="0 0 27 62" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M5 1H26V61H20H3L11.5 52L2 48.4C4.66667 46 9.9 41.2 9.5 41.2C9.1 41.2 5.33333 37.6 3.5 35.8L11 28L4.5 23.8L9.5 17.2L5 12.4L10.5 7.6L5 1Z" fill="#FECE55" stroke="#404040" stroke-width="2"></path>
        <rect x="24" y="2" width="6" height="58" fill="#FECE55"></rect>
      </svg>

      <div class="larg">
        {% comment %} <div class="lightning">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M5 1.07244V10.7244C5 11.3142 5.48604 11.7968 6.08009 11.7968H8.24026V19.4647C8.24026 20.0117 8.96392 20.2047 9.24474 19.7329L14.8504 10.1882C15.2716 9.46963 14.7532 8.5795 13.9215 8.5795H11.4805L14.1699 1.44779C14.44 0.750707 13.9215 0 13.1655 0H6.08009C5.48604 0 5 0.482597 5 1.07244Z" fill="#404040"></path>
          </svg>
        </div> {% endcomment %}
        <div class="bloc">
          {% comment %} <p>Use code: <span class="oc-copy">{{ block.settings.coupon_code }}</span></p> {% endcomment %}
          <p><span class="oc-copy">{{ block.settings.coupon_text }}</span></p>
          {% comment %} <h6>{{ block.settings.coupon_text }}</h6> {% endcomment %}
        </div>
      </div>

      <svg class="clip-right" width="27" height="62" viewBox="0 0 27 62" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M22 61H1L1 0.999996H7H24L15.5 10L25 13.6C22.3333 16 17.1 20.8 17.5 20.8C17.9 20.8 21.6667 24.4 23.5 26.2L16 34L22.5 38.2L17.5 44.8L22 49.6L16.5 54.4L22 61Z" fill="#FECE55" stroke="#404040" stroke-width="2"></path>
        <rect y="2" width="3" height="58" fill="#FECE55"></rect>
      </svg>
    </div>
  {% endif %}
{% endfor %}

<style>
.product-block-offer-callout {
  display: flex;
  align-items: center;
  justify-content: center;
  max-width: 600px;
  margin: 15px auto;
  height: 62px;
  background: #FECE55;
  border-top: 2px solid #404040;
  border-bottom: 2px solid #404040;
  position: relative;
  font-family: inherit;
}

.product-block-offer-callout .larg {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 0 15px;
  flex: 1;
  height: 100%;
}

.product-block-offer-callout .lightning svg {
  width: 20px;
  height: 20px;
  flex-shrink: 0;
}

.product-block-offer-callout .bloc p,
.product-block-offer-callout .bloc h6 {
  margin: 0;
  line-height: 1.3;
  color: #404040;
}

.product-block-offer-callout .bloc p {
  font-weight: bold;
  font-size: 1.1em;
}

.product-block-offer-callout .bloc h6 {
  font-size: 0.9em;
  font-weight: normal;
}

.product-block-offer-callout .oc-copy {
  font-weight: bold;
}

  .product-block-offer-callout .clip-left {
    position: absolute;
    left: -15px;
  }
  .product-block-offer-callout .clip-right {
   position: absolute;
   right: -15px;
  }

/* Responsive */
@media (max-width: 768px) {
  .product-block-offer-callout {
    max-width: 90%;
    height: 62px;
    margin: 10px auto;
  }
  .product-block-offer-callout .larg { gap: 8px; padding: 0 10px; justify-content: center; }
  .product-block-offer-callout .bloc p { font-size: 1em; }
  .product-block-offer-callout .bloc h6 { font-size: 0.8em; }
  .product-block-offer-callout .lightning svg { width: 18px; height: 18px; }
}

@media (max-width: 480px) {
  .product-block-offer-callout {
    height: 62px;
    flex-wrap: wrap;
    padding: 4px 0;
  }
  .product-block-offer-callout .larg {
    flex-direction: column;
    text-align: center;
    gap: 1px;
    justify-content: center;
  }
  .product-block-offer-callout .clip-left {
    position: absolute;
    left: -15px;
  }
  .product-block-offer-callout .clip-right {
   position: absolute;
   right: -15px;
  }
  .product-block-offer-callout .bloc p { font-size: 0.9em; }
  .product-block-offer-callout .bloc h6 { font-size: 0.75em; }
}
</style>

<!-- End Offer Callout Block Here -->



