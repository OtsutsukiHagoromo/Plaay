  {%- comment -%}── PDP Info Tabs ──{%- endcomment -%}
{%- liquid
  assign _first_tab = 'shipping'
  if storage_tips != blank
    assign _first_tab = 'storage'
  endif
  if has_nutrition
    assign _first_tab = 'nutrition'
  endif
  if exact_ingredients != blank or allergens != blank
    assign _first_tab = 'ingredients'
  endif
  if product.description != blank
    assign _first_tab = 'info'
  endif
  assign sid = section.id
-%}
<div class="plaay-pdp-tabs-wrap" id="plaay-pdp-tabs-{{ sid }}">
  <div class="plaay-pdp-tabs__nav container">
    {%- if product.description != blank -%}
      <button class="plaay-pdp-tabs__tab{% if _first_tab == 'info' %} is-active{% endif %}" data-tab="info-{{ sid }}">{{ section.settings.tab_info_label | default: 'Product Info' }}</button>
    {%- endif -%}
    {%- if exact_ingredients != blank or allergens != blank -%}
      <button class="plaay-pdp-tabs__tab{% if _first_tab == 'ingredients' %} is-active{% endif %}" data-tab="ingredients-{{ sid }}">{{ section.settings.tab_ingredients_label | default: 'Ingredients' }}</button>
    {%- endif -%}
    {%- if has_nutrition -%}
      <button class="plaay-pdp-tabs__tab{% if _first_tab == 'nutrition' %} is-active{% endif %}" data-tab="nutrition-{{ sid }}">{{ section.settings.tab_nutrition_label | default: 'Nutrition' }}</button>
    {%- endif -%}
    {%- if storage_tips != blank -%}
      <button class="plaay-pdp-tabs__tab{% if _first_tab == 'storage' %} is-active{% endif %}" data-tab="storage-{{ sid }}">{{ section.settings.tab_storage_label | default: 'How to Enjoy' }}</button>
    {%- endif -%}
    <button class="plaay-pdp-tabs__tab{% if _first_tab == 'shipping' %} is-active{% endif %}" data-tab="shipping-{{ sid }}">{{ section.settings.tab_shipping_label | default: 'Shipping & Returns' }}</button>
  </div>

  {%- if product.description != blank -%}
    <div class="plaay-pdp-tabs__panel{% unless _first_tab == 'info' %} is-hidden{% endunless %}" id="tab-info-{{ sid }}">
      <div class="container py-8">{{ product.description }}</div>
    </div>
  {%- endif -%}

  {%- if exact_ingredients != blank or allergens != blank -%}
    <div class="plaay-pdp-tabs__panel{% unless _first_tab == 'ingredients' %} is-hidden{% endunless %}" id="tab-ingredients-{{ sid }}">
      <div class="container py-8">
        {%- if exact_ingredients != blank -%}
          {%- assign ingredient_list = exact_ingredients | split: ',' -%}
          <ul class="plaay-pdp-tab-ingredients-list">
            {%- for item in ingredient_list -%}
              <li>{{ item | strip }}</li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
        {%- if allergens != blank -%}
          <div class="plaay-pdp-tab-allergen-box">
            <strong>Allergens:</strong> {{ allergens }}
          </div>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

  {%- if has_nutrition -%}
    <div class="plaay-pdp-tabs__panel{% unless _first_tab == 'nutrition' %} is-hidden{% endunless %}" id="tab-nutrition-{{ sid }}">
      <div class="container py-8">
        <div class="plaay-pdp-tab-nutrition-grid">
          {%- if cal_val != blank -%}<div class="plaay-nutrition-tile"><span class="plaay-nutrition-icon">&#128293;</span><span class="plaay-nutrition-value">{{ cal_val }}</span><span class="plaay-nutrition-label">Calories</span></div>{%- endif -%}
          {%- if protein_val != blank -%}<div class="plaay-nutrition-tile"><span class="plaay-nutrition-icon">&#128170;</span><span class="plaay-nutrition-value">{{ protein_val }}</span><span class="plaay-nutrition-label">Protein</span></div>{%- endif -%}
          {%- if carbs_val != blank -%}<div class="plaay-nutrition-tile"><span class="plaay-nutrition-icon">&#127807;</span><span class="plaay-nutrition-value">{{ carbs_val }}</span><span class="plaay-nutrition-label">Carbs</span></div>{%- endif -%}
          {%- if fats_val != blank -%}<div class="plaay-nutrition-tile"><span class="plaay-nutrition-icon">&#129372;</span><span class="plaay-nutrition-value">{{ fats_val }}</span><span class="plaay-nutrition-label">Fats</span></div>{%- endif -%}
          {%- if sugar_val != blank -%}<div class="plaay-nutrition-tile"><span class="plaay-nutrition-icon">&#127855;</span><span class="plaay-nutrition-value">{{ sugar_val }}</span><span class="plaay-nutrition-label">Added Sugar</span></div>{%- endif -%}
          {%- if fiber_val != blank -%}<div class="plaay-nutrition-tile"><span class="plaay-nutrition-icon">&#127807;</span><span class="plaay-nutrition-value">{{ fiber_val }}</span><span class="plaay-nutrition-label">Fibre</span></div>{%- endif -%}
        </div>
      </div>
    </div>
  {%- endif -%}

  {%- if storage_tips != blank -%}
    <div class="plaay-pdp-tabs__panel{% unless _first_tab == 'storage' %} is-hidden{% endunless %}" id="tab-storage-{{ sid }}">
      <div class="container py-8">{{ storage_tips }}</div>
    </div>
  {%- endif -%}

  <div class="plaay-pdp-tabs__panel{% unless _first_tab == 'shipping' %} is-hidden{% endunless %}" id="tab-shipping-{{ sid }}">
    <div class="container py-8">
      {%- if section.settings.shipping_returns_content != blank -%}
        {{ section.settings.shipping_returns_content }}
      {%- else -%}
        <div class="plaay-pdp-tab-shipping-icons">
          <div><span>&#128666;</span><p><strong>Free Delivery</strong><br>On orders over AED 75</p></div>
          <div><span>&#9889;</span><p><strong>Same-Day Dubai</strong><br>Order before 2 PM</p></div>
          <div><span>&#128260;</span><p><strong>7-Day Returns</strong><br>Unopened items only</p></div>
        </div>
        <ul class="plaay-pdp-shipping-bullets">
          <li>1-2 business days delivery across the UAE</li>
          <li>Free delivery on all orders over AED 75</li>
          <li>Same-day delivery in Dubai for orders before 2 PM</li>
          <li>Returns accepted within 7 days for unopened, undamaged items</li>
          <li>Email <a href="mailto:hello@shopplaay.com">hello@shopplaay.com</a> to start a return</li>
        </ul>
      {%- endif -%}
    </div>
  </div>
</div>
</div>
<script>
(function() {
  var wrap = document.getElementById('plaay-pdp-tabs-{{ section.id }}');
  if (!wrap) return;
  var tabs = wrap.querySelectorAll('.plaay-pdp-tabs__tab');
  var panels = wrap.querySelectorAll('.plaay-pdp-tabs__panel');
  tabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      tabs.forEach(function(t) { t.classList.remove('is-active'); });
      panels.forEach(function(p) { p.classList.add('is-hidden'); });
      tab.classList.add('is-active');
      var target = document.getElementById('tab-' + tab.dataset.tab);
      if (target) target.classList.remove('is-hidden');
    });
  });
})();
</script>

{%- assign sticky_variant = product.selected_or_first_available_variant -%}

{% comment %} ── Mobile sticky ATC (shown on mobile when inline button scrolls out) ── {% endcomment %}
<div id="plaay-sticky-mobile" class="plaay-sticky-mobile" aria-hidden="true">
  <div class="plaay-sticky-mobile__inner" style="padding:10px 16px 14px">
    <div class="plaay-sticky-mobile__meta" style="display:flex;flex-direction:column;gap:2px;margin-bottom:10px">
      <span class="plaay-sticky-mode font-walsheim-bold text-dark-blue" style="font-size:11px;letter-spacing:0.12em;text-transform:uppercase;line-height:1.1">One-Time Purchase</span>
      <span class="plaay-sticky-plan font-walsheim-regular text-dark-blue" style="font-size:12px;opacity:0.65;line-height:1.2;display:none"></span>
    </div>
    {% comment %} Row 1 — price + qty {% endcomment %}
    <div class="plaay-sticky-mobile__row" style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px">
      <div class="plaay-sticky-mobile__price" style="display:flex;flex-direction:column;gap:1px">
        {%- if sticky_variant.compare_at_price > sticky_variant.price -%}
          <span class="plaay-sticky-compare font-walsheim-regular text-dark-blue" style="font-size:11px;text-decoration:line-through;opacity:0.45;line-height:1">{{ sticky_variant.compare_at_price | money }}</span>
        {%- else -%}
          <span class="plaay-sticky-compare font-walsheim-regular text-dark-blue" style="font-size:11px;text-decoration:line-through;opacity:0.45;line-height:1;display:none">{{ sticky_variant.compare_at_price | money }}</span>
        {%- endif -%}
        <span class="plaay-sticky-mobile-price font-walsheim-bold text-dark-blue" style="font-size:22px;line-height:1">{{ sticky_variant.price | money }}</span>
      </div>
      <div class="plaay-sticky-mobile__qty-wrap" style="display:flex;align-items:center;border:1.5px solid #021D49;border-radius:10px;overflow:hidden;height:40px">
        <button type="button" class="plaay-mobile-minus font-walsheim-bold text-dark-blue" style="padding:0 14px;height:100%;font-size:20px;line-height:1;background:transparent;border:none;cursor:pointer">−</button>
        <span class="plaay-mobile-qty plaay-sticky-mobile__qty font-walsheim-bold text-dark-blue" style="padding:0 12px;font-size:15px;border-left:1px solid rgba(2,29,73,0.2);border-right:1px solid rgba(2,29,73,0.2);height:100%;display:flex;align-items:center;min-width:40px;justify-content:center">1</span>
        <button type="button" class="plaay-mobile-plus font-walsheim-bold text-dark-blue" style="padding:0 14px;height:100%;font-size:20px;line-height:1;background:transparent;border:none;cursor:pointer">+</button>
      </div>
    </div>
    {% comment %} Row 2 — full-width ATC button {% endcomment %}
    <button type="button" class="btn blue font-walsheim-bold uppercase plaay-mobile-submit plaay-sticky-mobile__submit" style="width:100%;padding:16px;font-size:15px;letter-spacing:0.05em">
      {{ 'product.add_to_cart.add_to_bag' | t }}
    </button>
  </div>
</div>

{% comment %} ── Desktop sticky ATC bar ── {% endcomment %}
<div id="plaay-sticky-atc" class="plaay-sticky-atc" aria-hidden="true">
  <div class="container flex items-center justify-between">
    <p class="font-walsheim-black uppercase text-dark-blue leading-tight truncate flex-1 hidden xl:block" style="font-size:13px;margin-right:2rem">{{ product.title }}</p>
    <div style="display:flex;align-items:center;gap:20px;margin-left:auto;flex-shrink:0">
      {% comment %} Price block — always render both spans, JS shows/hides compare {% endcomment %}
      <div style="display:flex;flex-direction:column;align-items:flex-end;gap:3px">
        <span class="plaay-sticky-mode font-walsheim-bold text-dark-blue" style="font-size:10px;letter-spacing:0.14em;text-transform:uppercase;line-height:1.1">One-Time Purchase</span>
        <span class="plaay-sticky-plan font-walsheim-regular text-dark-blue" style="font-size:12px;opacity:0.65;line-height:1.2;display:none"></span>
        <span class="plaay-sticky-compare font-walsheim-regular text-dark-blue" style="font-size:11px;text-decoration:line-through;opacity:0.5;line-height:1;{% unless sticky_variant.compare_at_price > sticky_variant.price %}display:none{% endunless %}">{{ sticky_variant.compare_at_price | money }}</span>
        <span class="plaay-sticky-price font-walsheim-bold text-dark-blue" style="font-size:20px;line-height:1">{{ sticky_variant.price | money }}</span>
      </div>
      {% comment %} Quantity selector {% endcomment %}
      <div class="plaay-sticky-qty-wrap" style="display:flex;align-items:center;border:1.5px solid #021D49;border-radius:10px;overflow:hidden;height:44px">
        <button type="button" class="plaay-sticky-minus font-walsheim-bold text-dark-blue" style="padding:0 16px;height:100%;font-size:22px;line-height:1;background:transparent;border:none;cursor:pointer">−</button>
        <span class="plaay-sticky-qty font-walsheim-bold text-dark-blue" style="padding:0 14px;font-size:15px;border-left:1px solid rgba(2,29,73,0.2);border-right:1px solid rgba(2,29,73,0.2);height:100%;display:flex;align-items:center;min-width:44px;justify-content:center">1</span>
        <button type="button" class="plaay-sticky-plus font-walsheim-bold text-dark-blue" style="padding:0 16px;height:100%;font-size:22px;line-height:1;background:transparent;border:none;cursor:pointer">+</button>
      </div>
      {% comment %} ATC button {% endcomment %}
      <button type="button" class="btn blue font-walsheim-bold uppercase plaay-sticky-submit" style="padding:13px 32px;font-size:14px;white-space:nowrap;letter-spacing:0.05em">
        {{ 'product.add_to_cart.add_to_bag' | t }}
      </button>
    </div>
  </div>
</div>

<script>
(function() {
  function initStickyBars() {
    var inlineAtc = document.querySelector('.product_page_atc');
    var desktopBar = document.getElementById('plaay-sticky-atc');
    var mobileBar  = document.getElementById('plaay-sticky-mobile');
    var mobileMenu = document.querySelector('.mobile_menu');
    if (!inlineAtc) return;

    var isMobile = function() { return window.innerWidth < 1024; };

    // Force both bars into position:fixed regardless of stylesheet
    var baseStyle = 'position:fixed;bottom:0;left:0;right:0;z-index:9998;' +
                    'background:#fff;border-top:1px solid rgba(2,29,73,0.12);' +
                    'box-shadow:0 -4px 24px rgba(2,29,73,0.1);' +
                    'transition:transform 0.3s ease;transform:translateY(0);pointer-events:auto;';

    if (desktopBar) {
      desktopBar.setAttribute('style', baseStyle + 'padding:16px 0;display:none;');
    }
    if (mobileBar) {
      mobileBar.setAttribute('style', baseStyle + 'display:none;');
    }

    function showBar(bar) {
      if (!bar) return;
      bar.style.display = 'block';
      bar.style.transform = 'translateY(0)';
      bar.style.pointerEvents = 'auto';
    }
    function hideBar(bar) {
      if (!bar) return;
      bar.style.display = 'none';
      bar.style.transform = 'translateY(110%)';
      bar.style.pointerEvents = 'none';
    }

    function isMobileMenuOpen() {
      return !!(mobileMenu && !mobileMenu.classList.contains('-translate-x-full'));
    }

    function syncViewportBar() {
      if (isMobile() && isMobileMenuOpen()) {
        hideBar(mobileBar);
        hideBar(desktopBar);
        return;
      }
      if (isMobile()) {
        showBar(mobileBar); hideBar(desktopBar);
      } else {
        showBar(desktopBar); hideBar(mobileBar);
      }
    }
    syncViewportBar();
    window.addEventListener('resize', syncViewportBar);
    if (mobileMenu) {
      new MutationObserver(syncViewportBar).observe(mobileMenu, { attributes: true, attributeFilter: ['class'] });
    }
    document.querySelectorAll('.hamburger_icon, .mobile_menu_cross').forEach(function(trigger) {
      trigger.addEventListener('click', function() {
        setTimeout(syncViewportBar, 20);
      });
    });

    // ── Price sync ──
    var getPriceEl = function() {
      return document.querySelector('.product_page_atc .product_discount_price') ||
             document.querySelector('.product_page_atc .product_price') ||
             document.querySelector('.product_discount_price') ||
             document.querySelector('.product_price');
    };
    var syncPrice = function() {
      var el = getPriceEl();
      var txt = el ? el.textContent.trim() : '';
      if (!txt) return;
      var dp  = desktopBar && desktopBar.querySelector('.plaay-sticky-price');
      var mp  = mobileBar  && mobileBar.querySelector('.plaay-sticky-mobile-price');
      var mcp = mobileBar  && mobileBar.querySelector('.plaay-sticky-compare');
      if (dp) dp.textContent = txt;
      if (mp) mp.textContent = txt;
      // Compare-at sync (mobile + desktop)
      // Only override when a Bundle discount element exists;
      // for native compare_at_price products Liquid already renders correctly on load.
      var compareEl = document.querySelector('.discount_price_exists');
      var compareTxt = compareEl ? compareEl.textContent.trim() : '';
      if (mcp && compareTxt) {
        mcp.textContent = compareTxt;
        mcp.style.display = 'inline';
      }
      var sc = desktopBar && desktopBar.querySelector('.plaay-sticky-compare');
      if (sc && compareTxt) {
        sc.textContent = compareTxt;
        sc.style.display = '';
      }
    };
    syncPrice();
    document.querySelectorAll('.product_discount_price,.product_price').forEach(function(el) {
      new MutationObserver(syncPrice).observe(el, { childList: true, subtree: true, characterData: true });
    });

    function syncPurchaseState() {
      var subWrap = document.querySelector('.plaay-sub-wrap');
      var hasSubscriptionUi = !!(subWrap && document.getElementById('plaay-tab-onetime') && document.getElementById('plaay-tab-subscribe'));
      var isSubscription = !!document.querySelector('#plaay-tab-subscribe.plaay-sub-tab--active');
      var oneTimeText = (document.querySelector('.plaay-sub-tab__price') || {}).textContent || '';
      var subscribeText = (document.querySelector('.plaay-sub-tab__disc-price') || {}).textContent || '';
      var activePlan = document.querySelector('.plaay-sub-freq__opt.active');
      var currentPrice = (isSubscription ? subscribeText : oneTimeText).trim();
      var compareText = '';
      var planLabel = isSubscription && activePlan ? ('Delivery every ' + activePlan.textContent.trim()) : '';
      var modeText = isSubscription ? 'Subscribe & Save' : 'One-Time Purchase';
      var submitLabel = isSubscription ? 'Subscribe now' : '{{ "product.add_to_cart.add_to_bag" | t }}';

      if (!currentPrice) {
        currentPrice = (desktopBar && desktopBar.querySelector('.plaay-sticky-price') ? desktopBar.querySelector('.plaay-sticky-price').textContent : '').trim();
      }

      if (isSubscription && oneTimeText.trim() && oneTimeText.trim() !== currentPrice) {
        compareText = oneTimeText.trim();
      }

      [desktopBar, mobileBar].forEach(function(bar) {
        if (!bar) return;
        var modeEl = bar.querySelector('.plaay-sticky-mode');
        var planEl = bar.querySelector('.plaay-sticky-plan');
        var priceEl = bar.querySelector('.plaay-sticky-price, .plaay-sticky-mobile-price');
        var compareEl = bar.querySelector('.plaay-sticky-compare');
        var submitEl = bar.querySelector('.plaay-sticky-submit, .plaay-mobile-submit');

        if (modeEl) {
          if (hasSubscriptionUi) {
            modeEl.textContent = modeText;
            modeEl.style.display = '';
          } else {
            modeEl.style.display = 'none';
          }
        }
        if (planEl) {
          if (hasSubscriptionUi && planLabel) {
            planEl.textContent = planLabel;
            planEl.style.display = '';
          } else {
            planEl.style.display = 'none';
          }
        }
        if (priceEl && currentPrice) priceEl.textContent = currentPrice;
        if (compareEl && compareText) {
          compareEl.textContent = compareText;
          compareEl.style.display = '';
        }
        if (submitEl) submitEl.textContent = submitLabel;
      });
    }
    syncPurchaseState();
    document.addEventListener('plaay:purchase-state-changed', syncPurchaseState);
    document.addEventListener('plaay:variant-changed', function() {
      syncPrice();
      syncPurchaseState();
    });

    // ── Desktop qty +/- ──
    var qty = 1;
    var qtyDisplay = desktopBar && desktopBar.querySelector('.plaay-sticky-qty');
    var inlineQtyInput = document.querySelector('quick-add input[name="quantity"],input[name="quantity"]');
    if (desktopBar) {
      desktopBar.querySelector('.plaay-sticky-minus').addEventListener('click', function() {
        if (qty > 1) { qty--; if (qtyDisplay) qtyDisplay.textContent = qty; if (inlineQtyInput) inlineQtyInput.value = qty; }
      });
      desktopBar.querySelector('.plaay-sticky-plus').addEventListener('click', function() {
        qty++; if (qtyDisplay) qtyDisplay.textContent = qty; if (inlineQtyInput) inlineQtyInput.value = qty;
      });
      desktopBar.querySelector('.plaay-sticky-submit').addEventListener('click', function() {
        if (inlineQtyInput) inlineQtyInput.value = qty;
        inlineAtc.click();
      });
    }

    // ── Mobile qty +/- ──
    var mobileQty = 1;
    var mobileQtyDisplay = mobileBar && mobileBar.querySelector('.plaay-mobile-qty');
    if (mobileBar) {
      mobileBar.querySelector('.plaay-mobile-minus').addEventListener('click', function() {
        if (mobileQty > 1) { mobileQty--; if (mobileQtyDisplay) mobileQtyDisplay.textContent = mobileQty; if (inlineQtyInput) inlineQtyInput.value = mobileQty; }
      });
      mobileBar.querySelector('.plaay-mobile-plus').addEventListener('click', function() {
        mobileQty++; if (mobileQtyDisplay) mobileQtyDisplay.textContent = mobileQty; if (inlineQtyInput) inlineQtyInput.value = mobileQty;
      });
      mobileBar.querySelector('.plaay-mobile-submit').addEventListener('click', function() {
        if (inlineQtyInput) inlineQtyInput.value = mobileQty;
        inlineAtc.click();
      });
    }

    // ── Sync variant label in mobile bar ──
    var mobileVariantEl = mobileBar && mobileBar.querySelector('.plaay-sticky-mobile-variant');
    if (mobileVariantEl) {
      var variantSel = document.querySelector('select#productSelect,select[name="id"]');
      if (variantSel) {
        variantSel.addEventListener('change', function() {
          var opt = variantSel.options[variantSel.selectedIndex];
          if (opt) mobileVariantEl.textContent = opt.text.split(' - ')[0].trim();
        });
      }
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initStickyBars);
  } else {
    initStickyBars();
  }
})();
</script>

{% if product_images_size > 1 %}
  <script type="module">
    document.addEventListener("DOMContentLoaded", () => {
      const productGallerySlider = new Glide("#product-gallery-{{ section.id }}", {
        type: 'carousel',
        perView: 1,
        startAt: 0,
        focusAt: 'center'
      });
      const productGalleryThumbnailsSlider = new Glide("#product-gallery-thumbnails-{{ section.id }}", {
        type: 'carousel',
        perView: 4,
        startAt: 0
      }); 
      productGallerySlider.mount({ });
      productGalleryThumbnailsSlider.mount({ });

      productGallerySlider.on("run", (e) => {
        productGalleryThumbnailsSlider.go(e.direction);
      });
      productGalleryThumbnailsSlider.on("run", (e) => {
        productGallerySlider.go(e.direction);
      });
      document.querySelectorAll('.thumbnail_slide').forEach(el => {
        el.addEventListener('click', (e) => {
          productGallerySlider.go('=' + `${e.target.dataset.index}`);
          productGalleryThumbnailsSlider.go('=' + `${e.target.dataset.index}`);
        });
      });
    });
  </script>
{% endif %}
