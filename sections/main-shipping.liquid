      "default": "Fresh, clean chocolate — delivered to your door in perfect condition."
    },
    {
      "type": "header",
      "content": "Highlights"
    },
    {
      "type": "text",
      "id": "highlights_heading",
      "label": "Highlights heading",
      "default": "What to expect"
    },
    {
      "type": "header",
      "content": "How It Works"
    },
    {
      "type": "color",
      "id": "steps_bg",
