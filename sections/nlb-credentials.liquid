{%- comment -%}
  Plaay - New Bars credentials band
  A simple, on-brand row of "clean" credentials for the collection launch page.
  Text-only (no image dependencies); blocks are fully editable.
{%- endcomment -%}

<section class="nlb-cred" style="--nlb-cred-bg: {{ section.settings.background_color }}; --nlb-cred-fg: {{ section.settings.text_color }};">
  <div class="nlb-cred__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="nlb-cred__heading font-walsheim-black">{{ section.settings.heading }}</h2>
    {%- endif -%}
    <div class="nlb-cred__grid">
      {%- for block in section.blocks -%}
        <div class="nlb-cred__item" {{ block.shopify_attributes }}>
          {%- if block.settings.value != blank -%}<span class="nlb-cred__value font-walsheim-black">{{ block.settings.value }}</span>{%- endif -%}
          {%- if block.settings.label != blank -%}<span class="nlb-cred__label font-walsheim-bold">{{ block.settings.label }}</span>{%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .nlb-cred { background: var(--nlb-cred-bg, #021D49); padding: 56px 24px; }
  .nlb-cred__inner { max-width: 1100px; margin: 0 auto; }
  .nlb-cred__heading { text-align: center; color: var(--nlb-cred-fg, #fff); font-size: clamp(1.4rem, 2.8vw, 2.1rem); text-transform: uppercase; letter-spacing: 0.02em; margin: 0 0 36px; }
  .nlb-cred__grid { display: flex; flex-wrap: wrap; justify-content: center; gap: 18px; }
  .nlb-cred__item {
    flex: 1 1 180px; max-width: 240px;
    display: flex; flex-direction: column; align-items: center; text-align: center; gap: 6px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 16px; padding: 24px 16px;
  }
  .nlb-cred__value { color: #F9C61D; font-size: 1.5rem; line-height: 1; text-transform: uppercase; }
  .nlb-cred__label { color: var(--nlb-cred-fg, #fff); font-size: 0.72rem; letter-spacing: 0.06em; text-transform: uppercase; opacity: 0.85; line-height: 1.3; }
  @media (max-width: 639px) { .nlb-cred__item { flex-basis: 140px; } .nlb-cred__value { font-size: 1.25rem; } }
</style>

{% schema %}
{
  "name": "NLB - Credentials",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Why Plaay Slabs" },
    { "type": "color", "id": "background_color", "label": "Background colour", "default": "#021D49" },
    { "type": "color", "id": "text_color", "label": "Text colour", "default": "#ffffff" }
  ],
  "blocks": [
    {
      "type": "cred",
      "name": "Credential",
      "settings": [
        { "type": "text", "id": "value", "label": "Value", "default": "0g" },
        { "type": "text", "id": "label", "label": "Label", "default": "Refined Sugar" }
      ]
    }
  ],
  "presets": [
    {
      "name": "NLB - Credentials",
      "blocks": [
        { "type": "cred", "settings": { "value": "0g", "label": "Refined Sugar" } },
        { "type": "cred", "settings": { "value": "100%", "label": "Clean Ingredients" } },
        { "type": "cred", "settings": { "value": "Halal", "label": "Certified" } },
        { "type": "cred", "settings": { "value": "UAE", "label": "Made Local" } }
      ]
    }
  ]
}
{% endschema %}
