{% comment %}
  PDP Stats Bar — quick-glance key stats row (protein, sugar, calories, etc.)
  Inspired by Chomps "Snacking Made Simple" section.
  Add to the product page template via the theme customiser.
{% endcomment %}

{% liquid
  assign bg      = section.settings.background_color
  assign heading = section.settings.heading
  assign stats   = section.blocks | where: 'type', 'stat'
%}

<div class="pdp-stats-bar" style="background:{{ bg }}">
  <div class="container">
    {% if heading != blank %}
      <h2 class="pdp-stats-bar__heading font-walsheim-bold">{{ heading }}</h2>
    {% endif %}
    <div class="pdp-stats-bar__grid">
      {% for block in stats %}
        <div class="pdp-stats-bar__item" {{ block.shopify_attributes }}>
          {% if block.settings.icon != blank %}
            <div class="pdp-stats-bar__icon-wrap">
              {% render 'img', type: 'img', img: block.settings.icon, lazy: true, class: 'pdp-stats-bar__icon' %}
            </div>
          {% endif %}
          {% if block.settings.value != blank %}
            <span class="pdp-stats-bar__value font-walsheim-black">{{ block.settings.value }}</span>
          {% endif %}
          {% if block.settings.label != blank %}
            <span class="pdp-stats-bar__label font-walsheim-bold">{{ block.settings.label }}</span>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

<style>
.pdp-stats-bar {
  padding: 48px 0;
}
.pdp-stats-bar__heading {
  text-align: center;
  text-transform: uppercase;
  color: #021D49;
  font-size: clamp(1.5rem, 3.5vw, 2.4rem);
  letter-spacing: 0.02em;
  margin-bottom: 36px;
}
.pdp-stats-bar__grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16px;
}
@media (min-width: 640px) {
  .pdp-stats-bar__grid {
    grid-template-columns: repeat(3, 1fr);
  }
}
@media (min-width: 1024px) {
  .pdp-stats-bar__grid {
    grid-template-columns: repeat(6, 1fr);
    gap: 12px;
  }
}
.pdp-stats-bar__item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  background: #fff;
  border-radius: 16px;
  padding: 20px 12px 18px;
  box-shadow: 0 2px 12px rgba(2,29,73,0.07);
  gap: 6px;
  transition: transform 0.2s, box-shadow 0.2s;
}
.pdp-stats-bar__item:hover {
  transform: translateY(-3px);
  box-shadow: 0 8px 24px rgba(2,29,73,0.13);
}
.pdp-stats-bar__icon-wrap {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: #F9C61D;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 4px;
}
.pdp-stats-bar__icon {
  width: 28px;
  height: 28px;
  object-fit: contain;
}
.pdp-stats-bar__value {
  font-size: 1.5rem;
  line-height: 1;
  color: #021D49;
  text-transform: uppercase;
}
.pdp-stats-bar__label {
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: #021D49;
  opacity: 0.7;
  line-height: 1.3;
}
@media (max-width: 639px) {
  .pdp-stats-bar { padding: 32px 0; }
  .pdp-stats-bar__value { font-size: 1.25rem; }
}
</style>

{% schema %}
{
  "name": "PDP — Stats Bar",
  "class": "pdp-stats-bar-section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background colour",
      "default": "#F4F4F4"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (optional)",
      "default": "Snacking Made Simple"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon image"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "default": "10g",
          "info": "e.g. 10g, 0g, 100 cal"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Protein",
          "info": "e.g. Protein, Sugar, Calories"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PDP — Stats Bar",
      "blocks": [
        { "type": "stat", "settings": { "value": "10g", "label": "Protein" } },
        { "type": "stat", "settings": { "value": "0g", "label": "Sugar" } },
        { "type": "stat", "settings": { "value": "100", "label": "Calories" } },
        { "type": "stat", "settings": { "value": "Keto", "label": "Friendly" } },
        { "type": "stat", "settings": { "value": "Clean", "label": "Ingredients" } },
        { "type": "stat", "settings": { "value": "Halal", "label": "Certified" } }
      ]
    }
  ]
}
{% endschema %}
