{%- comment -%}
  Plaay - New Launch Bars: A+ "Clean Breakdown" panel gallery
  The v3/v4/v5 images are fully-designed square panels (Clean Flavour story /
  Nutrition Facts / Ingredients), so they're shown large and self-contained -
  no extra title/description overlay.

  Each panel resolves: block image setting -> arena metafield (by position) -> hidden.
    aplus_why_1_img / aplus_why_2_img / aplus_why_3_img   file_reference
    aplus_why_heading   single_line_text  (fallback: "The Clean Breakdown")
{%- endcomment -%}

{%- liquid
  assign mf = product.metafields.arena
  assign heading = section.settings.heading | default: mf.aplus_why_heading
  if heading == blank
    assign heading = "The Clean Breakdown"
  endif
-%}

<section class="nlb-cb" style="--nlb-cb-bg: {{ section.settings.background_color }};">
  <div class="nlb-cb__inner">
    {%- if heading != blank -%}
      <h2 class="nlb-cb__heading font-walsheim-black">{{ heading }}</h2>
      <span class="nlb-cb__divider"></span>
    {%- endif -%}

    <div class="nlb-cb__grid">
      {%- for block in section.blocks -%}
        {%- liquid
          assign n = forloop.index
          assign key_img = 'aplus_why_' | append: n | append: '_img'
          assign mf_img_obj = mf[key_img]
          assign mf_img = mf_img_obj.value
          assign panel_img = block.settings.image | default: mf_img
        -%}
        {%- if panel_img != blank -%}
          <div class="nlb-cb__panel" {{ block.shopify_attributes }}>
            <img
              class="nlb-cb__img"
              src="{{ panel_img | image_url: width: 800 }}"
              srcset="{{ panel_img | image_url: width: 480 }} 480w, {{ panel_img | image_url: width: 800 }} 800w, {{ panel_img | image_url: width: 1000 }} 1000w"
              sizes="(max-width: 767px) 82vw, 360px"
              alt="{{ product.title | escape }} - {{ heading | escape }}"
              loading="lazy"
              decoding="async">
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .nlb-cb {
    background: var(--nlb-cb-bg, #FAF7F2);
    padding: 72px 24px;
  }
  .nlb-cb__inner {
    max-width: 1140px;
    margin: 0 auto;
  }
  .nlb-cb__heading {
    text-align: center;
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    text-transform: uppercase;
    color: #021D49;
    margin: 0 0 12px;
    letter-spacing: 0.02em;
  }
  .nlb-cb__divider {
    display: block;
    width: 56px;
    height: 4px;
    background: #E85767;
    border-radius: 2px;
    margin: 0 auto 52px;
  }
  .nlb-cb__grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 24px;
  }
  .nlb-cb__panel {
    flex: 0 1 340px;
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 6px 24px rgba(2,29,73,0.10);
    background: #fff;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .nlb-cb__panel:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 36px rgba(2,29,73,0.16);
  }
  .nlb-cb__img {
    display: block;
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
  }
  @media (max-width: 767px) {
    .nlb-cb { padding: 56px 0; }
    .nlb-cb__heading, .nlb-cb__divider { padding-left: 24px; padding-right: 24px; }
    .nlb-cb__divider { margin-bottom: 32px; }
    /* horizontal swipe gallery on mobile */
    .nlb-cb__grid {
      flex-wrap: nowrap;
      justify-content: flex-start;
      gap: 16px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      padding: 4px 24px 12px;
    }
    .nlb-cb__grid::-webkit-scrollbar { display: none; }
    .nlb-cb__panel { flex: 0 0 80%; scroll-snap-align: center; }
  }
</style>

{% schema %}
{
  "name": "NLB - A+ Clean Breakdown",
  "tag": "section",
  "max_blocks": 3,
  "settings": [
    {
      "type": "paragraph",
      "content": "Shows the product's three designed panels (Clean Flavour / Nutrition Facts / Ingredients) as a gallery. Leave card images blank to auto-pull from arena.aplus_why_1/2/3_img by position. Heading falls back to arena.aplus_why_heading."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background colour",
      "default": "#FAF7F2"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading override (optional)"
    }
  ],
  "blocks": [
    {
      "type": "why_card",
      "name": "Panel",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image override (optional)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "NLB - A+ Clean Breakdown",
      "blocks": [ { "type": "why_card" }, { "type": "why_card" }, { "type": "why_card" } ]
    }
  ]
}
{% endschema %}
