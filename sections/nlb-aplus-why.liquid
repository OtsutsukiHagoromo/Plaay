{%- comment -%}
  Plaay — New Launch Bars: A+ "Why You'll Love It"
  3-card grid. Each card resolves: block setting -> arena metafield (by card position) -> hidden.

  Metafields (namespace: arena), per card N (1..3):
    aplus_why_N_img    file_reference   — card image (macro/texture shot)
    aplus_why_N_title  single_line_text — card title
    aplus_why_N_desc   multi_line_text  — card description
    aplus_why_heading  single_line_text — grid heading (fallback: "Why You'll Love It")
{%- endcomment -%}

{%- liquid
  assign mf = product.metafields.arena
  assign heading = section.settings.heading | default: mf.aplus_why_heading
  if heading == blank
    assign heading = 'Why You''ll Love It'
  endif
-%}

<section class="nlb-why" style="--nlb-why-bg: {{ section.settings.background_color }};">
  <div class="nlb-why__inner">
    {%- if heading != blank -%}
      <h2 class="nlb-why__heading font-walsheim-black">{{ heading }}</h2>
      <span class="nlb-why__divider"></span>
    {%- endif -%}

    <div class="nlb-why__grid">
      {%- for block in section.blocks -%}
        {%- liquid
          assign n = forloop.index
          assign key_title = 'aplus_why_' | append: n | append: '_title'
          assign key_desc = 'aplus_why_' | append: n | append: '_desc'
          assign key_img = 'aplus_why_' | append: n | append: '_img'
          assign mf_title = mf[key_title]
          assign mf_desc = mf[key_desc]
          assign mf_img_obj = mf[key_img]
          assign mf_img = mf_img_obj.value

          assign card_title = block.settings.title | default: mf_title
          assign card_desc = block.settings.desc | default: mf_desc
          assign card_img = block.settings.image | default: mf_img
        -%}
        {%- if card_title != blank or card_desc != blank or card_img != blank -%}
          <div class="nlb-why__card" {{ block.shopify_attributes }}>
            {%- if card_img != blank -%}
              <img
                class="nlb-why__card-img"
                src="{{ card_img | image_url: width: 600 }}"
                srcset="{{ card_img | image_url: width: 360 }} 360w, {{ card_img | image_url: width: 600 }} 600w"
                sizes="(max-width: 767px) 100vw, 340px"
                alt="{{ card_title | escape }}"
                loading="lazy"
                decoding="async">
            {%- endif -%}
            <div class="nlb-why__card-body">
              {%- if card_title != blank -%}<p class="nlb-why__card-title font-walsheim-bold">{{ card_title }}</p>{%- endif -%}
              {%- if card_desc != blank -%}<p class="nlb-why__card-desc font-walsheim">{{ card_desc }}</p>{%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .nlb-why {
    background: var(--nlb-why-bg, #FAF7F2);
    padding: 72px 24px;
  }
  .nlb-why__inner {
    max-width: 1100px;
    margin: 0 auto;
  }
  .nlb-why__heading {
    text-align: center;
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    text-transform: uppercase;
    color: #021D49;
    margin: 0 0 12px;
    letter-spacing: 0.02em;
  }
  .nlb-why__divider {
    display: block;
    width: 56px;
    height: 4px;
    background: #E85767;
    border-radius: 2px;
    margin: 0 auto 52px;
  }
  .nlb-why__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }
  .nlb-why__card {
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 2px 16px rgba(2,29,73,0.07);
    text-align: center;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .nlb-why__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(2,29,73,0.13);
  }
  .nlb-why__card-img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    display: block;
  }
  .nlb-why__card-body {
    padding: 24px 20px 28px;
  }
  .nlb-why__card-title {
    font-size: 1.1rem;
    color: #021D49;
    text-transform: uppercase;
    margin: 0 0 8px;
    letter-spacing: 0.02em;
  }
  .nlb-why__card-desc {
    font-size: 0.875rem;
    color: #444;
    line-height: 1.55;
    margin: 0;
  }
  @media (max-width: 767px) {
    .nlb-why__grid { grid-template-columns: 1fr; gap: 20px; }
  }
</style>

{% schema %}
{
  "name": "NLB — A+ Why",
  "tag": "section",
  "max_blocks": 3,
  "settings": [
    {
      "type": "paragraph",
      "content": "3-card grid. Leave card fields blank to auto-pull from the product's **arena** metafields by position: card 1 → aplus_why_1_img/title/desc, card 2 → aplus_why_2_*, card 3 → aplus_why_3_*. Heading falls back to arena.aplus_why_heading."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background colour",
      "default": "#FAF7F2"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading override (optional)"
    }
  ],
  "blocks": [
    {
      "type": "why_card",
      "name": "Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image override (optional)" },
        { "type": "text", "id": "title", "label": "Title override (optional)" },
        { "type": "textarea", "id": "desc", "label": "Description override (optional)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "NLB — A+ Why",
      "blocks": [
        { "type": "why_card" },
        { "type": "why_card" },
        { "type": "why_card" }
      ]
    }
  ]
}
{% endschema %}
