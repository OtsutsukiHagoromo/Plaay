{% liquid
  assign title = section.settings.title
  assign copy = section.settings.copy
  assign eyebrow = section.settings.eyebrow
  assign status_label = section.settings.status_label
  assign update_one = section.settings.update_one
  assign update_two = section.settings.update_two
  assign update_three = section.settings.update_three
  assign support_label = section.settings.support_label
  assign support_url = section.settings.support_url
  assign instagram_label = section.settings.instagram_label
  assign instagram_url = section.settings.instagram_url
%}

<section class="plaay-password">
  <div class="container plaay-password__shell">
    <div class="plaay-password__hero">
      <div class="plaay-password__main">
        {% if eyebrow != blank %}
          <span class="plaay-password__eyebrow font-walsheim-bold">{{ eyebrow }}</span>
        {% endif %}

        {% if title != blank %}
          <h1 class="plaay-password__title font-walsheim-bold">{{ title }}</h1>
        {% endif %}

        {% if copy != blank %}
          <p class="plaay-password__copy font-walsheim-regular">{{ copy }}</p>
        {% endif %}

        <div class="plaay-password__status">
          <div class="plaay-password__status-head">
            <span class="plaay-password__status-dot" aria-hidden="true"></span>
            <span class="plaay-password__status-label font-walsheim-bold">{{ status_label }}</span>
          </div>

          <div class="plaay-password__progress" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </div>

          <div class="plaay-password__updates">
            <div class="plaay-password__update-card">
              <span class="plaay-password__update-kicker font-walsheim-bold">Now</span>
              <p class="plaay-password__update-copy font-walsheim-regular">{{ update_one }}</p>
            </div>
            <div class="plaay-password__update-card">
              <span class="plaay-password__update-kicker font-walsheim-bold">Next</span>
              <p class="plaay-password__update-copy font-walsheim-regular">{{ update_two }}</p>
            </div>
            <div class="plaay-password__update-card">
              <span class="plaay-password__update-kicker font-walsheim-bold">Then</span>
              <p class="plaay-password__update-copy font-walsheim-regular">{{ update_three }}</p>
            </div>
          </div>
        </div>

        <div class="plaay-password__quicklinks">
          {% if support_url != blank %}
            <a href="{{ support_url }}" class="plaay-password__quicklink plaay-password__quicklink--light font-walsheim-bold">{{ support_label }}</a>
          {% endif %}
          {% if instagram_url != blank %}
            <a href="{{ instagram_url }}" class="plaay-password__quicklink plaay-password__quicklink--dark font-walsheim-bold" target="_blank" rel="noopener">{{ instagram_label }}</a>
          {% endif %}
        </div>
      </div>

      <div class="plaay-password__access">
        <div class="plaay-password__access-card">
          <div class="plaay-password__access-head">
            <p class="plaay-password__access-eyebrow font-walsheim-bold">Private access</p>
            <h2 class="plaay-password__access-title font-walsheim-bold">Have the password?</h2>
            <p class="plaay-password__access-copy font-walsheim-regular">Enter it below to access the store while we finish polishing things up.</p>
          </div>

          {% form 'storefront_password', class: 'plaay-password__form' %}
            {% if form.errors %}
              <div class="plaay-password__message plaay-password__message--error font-walsheim-bold">
                {{ form.errors | default_errors }}
              </div>
            {% endif %}

            <label class="sr-only" for="Password-{{ section.id }}">Store password</label>
            <input
              id="Password-{{ section.id }}"
              type="password"
              name="password"
              placeholder="Enter store password"
              class="plaay-password__input">

            <button type="submit" class="plaay-password__submit font-walsheim-bold">Enter store</button>
          {% endform %}

          <div class="plaay-password__mini-grid">
            <div class="plaay-password__mini-card">
              <span class="plaay-password__mini-title font-walsheim-bold">Worth the wait</span>
              <p class="plaay-password__mini-copy font-walsheim-regular">We’re using this window to tighten performance, refresh sections, and make the storefront smoother.</p>
            </div>
            <div class="plaay-password__mini-card">
              <span class="plaay-password__mini-title font-walsheim-bold">Still Plaay</span>
              <p class="plaay-password__mini-copy font-walsheim-regular">Clean ingredients, playful energy, and a more polished shopping experience when the doors reopen.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .plaay-password {
    min-height: 100vh;
    background:
      radial-gradient(circle at top left, rgba(249, 198, 29, 0.28), transparent 28%),
      radial-gradient(circle at bottom right, rgba(240, 139, 52, 0.18), transparent 26%),
      linear-gradient(180deg, #fffdf7 0%, #fff 100%);
  }

  .plaay-password__shell {
    padding-top: 7.5rem;
    padding-bottom: 3rem;
  }

  .plaay-password__hero {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(360px, 0.9fr);
    gap: 1.5rem;
    align-items: stretch;
  }

  .plaay-password__main,
  .plaay-password__access-card {
    border-radius: 34px;
    box-shadow: 0 24px 54px rgba(2, 29, 73, 0.1);
  }

  .plaay-password__main {
    position: relative;
    overflow: hidden;
    padding: 2.1rem;
    background: #f9c61d;
    color: #021d49;
  }

  .plaay-password__main::after {
    content: "BRB";
    position: absolute;
    right: 1.25rem;
    bottom: 0.75rem;
    font-family: var(--font-walsheim-bold, "walsheim-bold", sans-serif);
    font-size: clamp(4rem, 11vw, 8rem);
    line-height: 1;
    color: rgba(2, 29, 73, 0.08);
    pointer-events: none;
  }

  .plaay-password__eyebrow {
    display: inline-flex;
    align-items: center;
    min-height: 34px;
    padding: 0 15px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.92);
    font-size: 11px;
    letter-spacing: 0.16em;
    line-height: 1;
    text-transform: uppercase;
  }

  .plaay-password__title {
    max-width: 11ch;
    margin: 1rem 0 0;
    color: #021d49;
    font-size: clamp(3rem, 7vw, 6.4rem);
    line-height: 0.92;
    text-transform: uppercase;
  }

  .plaay-password__copy {
    max-width: 42rem;
    margin: 1.1rem 0 0;
    color: rgba(2, 29, 73, 0.9);
    font-size: 1.05rem;
    line-height: 1.75;
  }

  .plaay-password__status {
    margin-top: 1.6rem;
    padding: 1.2rem;
    border-radius: 28px;
    background: rgba(255, 255, 255, 0.94);
    box-shadow: 0 14px 28px rgba(2, 29, 73, 0.08);
  }

  .plaay-password__status-head {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }

  .plaay-password__status-dot {
    width: 12px;
    height: 12px;
    border-radius: 999px;
    background: #021d49;
    animation: plaayPasswordPulse 1.8s ease-in-out infinite;
  }

  .plaay-password__status-label {
    color: #021d49;
    font-size: 12px;
    letter-spacing: 0.14em;
    line-height: 1;
    text-transform: uppercase;
  }

  .plaay-password__progress {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
    margin-top: 1rem;
  }

  .plaay-password__progress span {
    position: relative;
    display: block;
    height: 10px;
    overflow: hidden;
    border-radius: 999px;
    background: rgba(2, 29, 73, 0.09);
  }

  .plaay-password__progress span::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(90deg, #021d49 0%, #f08b34 100%);
    transform: translateX(-100%);
    animation: plaayPasswordSweep 3.6s ease-in-out infinite;
  }

  .plaay-password__progress span:nth-child(2)::after {
    animation-delay: 0.35s;
  }

  .plaay-password__progress span:nth-child(3)::after {
    animation-delay: 0.7s;
  }

  .plaay-password__updates {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
    margin-top: 1rem;
  }

  .plaay-password__update-card {
    padding: 0.95rem 1rem;
    border-radius: 22px;
    background: #fff;
    border: 1px solid rgba(2, 29, 73, 0.08);
  }

  .plaay-password__update-kicker {
    color: rgba(2, 29, 73, 0.55);
    font-size: 10px;
    letter-spacing: 0.16em;
    line-height: 1;
    text-transform: uppercase;
  }

  .plaay-password__update-copy {
    margin: 0.55rem 0 0;
    color: #021d49;
    font-size: 0.94rem;
    line-height: 1.55;
  }

  .plaay-password__quicklinks {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.2rem;
  }

  .plaay-password__quicklink {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 20px;
    border-radius: 999px;
    font-size: 12px;
    letter-spacing: 0.12em;
    line-height: 1;
    text-transform: uppercase;
    transition: transform 0.2s ease;
  }

  .plaay-password__quicklink:hover {
    transform: translateY(-1px);
  }

  .plaay-password__quicklink--light {
    background: rgba(255, 255, 255, 0.92);
    color: #021d49;
  }

  .plaay-password__quicklink--dark {
    background: #021d49;
    color: #fff;
  }

  .plaay-password__access-card {
    height: 100%;
    padding: 2rem;
    background: #ffffff;
  }

  .plaay-password__access-head {
    margin-bottom: 1.2rem;
  }

  .plaay-password__access-eyebrow {
    color: rgba(2, 29, 73, 0.55);
    font-size: 11px;
    letter-spacing: 0.16em;
    line-height: 1;
    text-transform: uppercase;
  }

  .plaay-password__access-title {
    margin: 0.7rem 0 0;
    color: #021d49;
    font-size: clamp(2rem, 3.4vw, 3rem);
    line-height: 0.95;
    text-transform: uppercase;
  }

  .plaay-password__access-copy {
    margin: 0.8rem 0 0;
    color: rgba(2, 29, 73, 0.74);
    font-size: 0.98rem;
    line-height: 1.7;
  }

  .plaay-password__form {
    display: grid;
    gap: 0.85rem;
  }

  .plaay-password__message {
    padding: 0.95rem 1rem;
    border-radius: 18px;
    font-size: 0.88rem;
    line-height: 1.5;
  }

  .plaay-password__message--error {
    background: rgba(225, 29, 36, 0.08);
    color: #b52228;
  }

  .plaay-password__message--error ul {
    margin: 0;
    padding-left: 1rem;
  }

  .plaay-password__input {
    width: 100%;
    height: 54px;
    padding: 0 18px;
    border: 1px solid rgba(2, 29, 73, 0.12);
    border-radius: 18px;
    background: #f9fafc;
    color: #021d49;
    font-size: 15px;
  }

  .plaay-password__input:focus {
    outline: none;
    border-color: #021d49;
    background: #fff;
  }

  .plaay-password__submit {
    width: 100%;
    height: 54px;
    border: none;
    border-radius: 18px;
    background: #021d49;
    color: #f9c61d;
    font-size: 12px;
    letter-spacing: 0.14em;
    line-height: 1;
    text-transform: uppercase;
  }

  .plaay-password__mini-grid {
    display: grid;
    gap: 12px;
    margin-top: 1rem;
  }

  .plaay-password__mini-card {
    padding: 1rem 1rem 1.05rem;
    border-radius: 22px;
    background: #f7f7f4;
    border: 1px solid rgba(2, 29, 73, 0.06);
  }

  .plaay-password__mini-title {
    color: #021d49;
    font-size: 12px;
    letter-spacing: 0.12em;
    line-height: 1;
    text-transform: uppercase;
  }

  .plaay-password__mini-copy {
    margin: 0.65rem 0 0;
    color: rgba(2, 29, 73, 0.72);
    font-size: 0.92rem;
    line-height: 1.6;
  }

  @keyframes plaayPasswordPulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(0.72); opacity: 0.55; }
  }

  @keyframes plaayPasswordSweep {
    0%, 15% { transform: translateX(-100%); }
    45%, 70% { transform: translateX(0%); }
    100% { transform: translateX(100%); }
  }

  @media (max-width: 989px) {
    .plaay-password__hero {
      grid-template-columns: minmax(0, 1fr);
    }
  }

  @media (max-width: 749px) {
    .plaay-password__shell {
      padding-top: 6.5rem;
      padding-bottom: 2.5rem;
    }

    .plaay-password__main,
    .plaay-password__access-card {
      padding: 1.3rem;
      border-radius: 26px;
    }

    .plaay-password__title {
      font-size: 3rem;
      max-width: none;
    }

    .plaay-password__copy {
      font-size: 0.96rem;
    }

    .plaay-password__status {
      padding: 1rem;
      border-radius: 22px;
    }

    .plaay-password__updates {
      grid-template-columns: minmax(0, 1fr);
    }

    .plaay-password__quicklinks {
      flex-direction: column;
    }

    .plaay-password__quicklink {
      width: 100%;
    }
  }
</style>

{% schema %}
{
  "name": "Password page",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Temporary Maintenance Mode"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "We are giving Plaay a quick glow-up."
    },
    {
      "type": "textarea",
      "id": "copy",
      "label": "Copy",
      "default": "The storefront is temporarily locked while we tidy things up behind the scenes. We will be back shortly with a smoother, sharper, more delicious experience."
    },
    {
      "type": "text",
      "id": "status_label",
      "label": "Status label",
      "default": "Store refresh in progress"
    },
    {
      "type": "text",
      "id": "update_one",
      "label": "Update 1",
      "default": "Refining key pages and tightening the experience."
    },
    {
      "type": "text",
      "id": "update_two",
      "label": "Update 2",
      "default": "Testing everything across mobile and desktop."
    },
    {
      "type": "text",
      "id": "update_three",
      "label": "Update 3",
      "default": "Reopening once it all feels properly Plaay."
    },
    {
      "type": "text",
      "id": "support_label",
      "label": "Support button label",
      "default": "Need help?"
    },
    {
      "type": "url",
      "id": "support_url",
      "label": "Support button URL"
    },
    {
      "type": "text",
      "id": "instagram_label",
      "label": "Second button label",
      "default": "Follow updates"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Second button URL"
    }
  ]
}
{% endschema %}
