{% liquid
  assign original_total_price = cart.original_total_price | default: cart.total_price
  assign total_savings = original_total_price | minus: cart.total_price
  assign has_discounted_total = false

  if original_total_price > cart.total_price
    assign has_discounted_total = true
  endif
%}

{% if cart.cart_level_discount_applications.size > 0 or has_discounted_total %}
  <div class="plaay-applied-promo mb-3 rounded-2xl border border-dark-blue border-opacity-10 bg-[#f8f8f4] px-4 py-3">
    <div class="plaay-applied-promo__top flex items-start justify-between gap-3">
      <div class="flex min-w-0 flex-col gap-1">
        <span class="plaay-applied-promo__eyebrow text-[11px] font-walsheim-bold uppercase tracking-[0.14em] text-dark-blue opacity-70">Applied promo</span>
        {% if has_discounted_total %}
          <span class="plaay-applied-promo__saved text-xs font-walsheim-bold text-[#138a4a]">You saved {{ total_savings | money }}</span>
        {% endif %}
      </div>
      {% if cart.cart_level_discount_applications.size > 0 %}
        <button
          type="button"
          class="plaay-applied-promo__remove font-walsheim-bold"
          data-remove-discount>
          Remove
        </button>
      {% endif %}
    </div>

    {% if cart.cart_level_discount_applications.size > 0 %}
      <div class="mt-2 flex flex-col gap-2">
        {% for discount in cart.cart_level_discount_applications %}
          <div class="plaay-applied-promo__line flex items-center justify-between gap-3 rounded-xl bg-white px-3 py-2">
            <span class="plaay-applied-promo__code text-sm font-walsheim-bold text-dark-blue">{{ discount.title }}</span>
            <span class="plaay-applied-promo__amount text-sm font-walsheim-bold text-[#138a4a]">-{{ discount.total_allocated_amount | money }}</span>
          </div>
        {% endfor %}
      </div>
    {% elsif has_discounted_total %}
      <div class="plaay-applied-promo__line mt-2 rounded-xl bg-white px-3 py-2 text-sm font-walsheim-bold text-dark-blue">
        Discount applied at checkout
      </div>
    {% endif %}
  </div>
{% endif %}

{% comment %} Subtotal row - data-cart-total carries the raw fils value for JS tier bar updates {% endcomment %}
<div class="flex items-center justify-between py-3 border-t border-dark-blue border-opacity-10">
  <span class="text-dark-blue text-base font-walsheim-bold uppercase tracking-wide">{{ 'cart-drawer.total' | t }}</span>
  <div class="flex flex-col items-end" data-subtotal data-cart-total="{{ cart.total_price }}">
    <span class="text-dark-blue text-xl font-walsheim-black">{{ cart.total_price | money }}</span>
    {% if has_discounted_total %}
      <span class="text-xs font-walsheim-bold text-dark-blue opacity-45 line-through">{{ original_total_price | money }}</span>
    {% endif %}
  </div>
</div>
<p class="text-xs text-dark-blue opacity-40 font-walsheim text-right -mt-1 mb-3">
  {% if has_discounted_total %}
    Savings of {{ total_savings | money }} included. Taxes &amp; shipping calculated at checkout
  {% else %}
    Taxes &amp; shipping calculated at checkout
  {% endif %}
</p>

{% comment %} Discount code accordion {% endcomment %}
<div class="plaay-discount-wrap">
  <button
    type="button"
    class="plaay-discount-toggle font-walsheim-regular"
    aria-expanded="false"
    aria-controls="plaay-discount-body">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
    Have a promo code?
    <svg class="plaay-discount-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
  </button>

  <div class="plaay-discount-body" id="plaay-discount-body" aria-hidden="true">
    <div class="plaay-discount-row">
      <input
        type="text"
        id="plaay-discount-input"
        class="plaay-discount-input font-walsheim-regular"
        placeholder="Enter promo code"
        autocomplete="off"
        autocorrect="off"
        spellcheck="false">
      <button
        type="button"
        id="plaay-discount-apply"
        class="plaay-discount-apply-btn font-walsheim-bold">
        Apply
      </button>
    </div>
    <p class="plaay-discount-msg" id="plaay-discount-msg" aria-live="polite"></p>
  </div>
</div>

{% comment %} Discount accordion JS lives in drawer-cart.liquid (event-delegation) so it survives footer re-renders {% endcomment %}
