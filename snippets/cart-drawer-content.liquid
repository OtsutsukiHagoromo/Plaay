<div class="flex flex-1 min-h-0 flex-col overflow-hidden" data-cart-drawer-content data-cart-item-count="{{ cart.item_count }}">
  <div class="flex-shrink-0 px-5 pt-4 pb-2{% if cart.item_count == 0 %} hidden{% endif %}">
    {%- liquid
      assign fd_active = false
      if settings.fathers_day_sale_enabled
        assign fd_now = 'now' | date: '%s' | times: 1
        assign fd_start = '2026-06-21T00:00:00+04:00' | date: '%s' | times: 1
        assign fd_end = '2026-06-22T00:00:00+04:00' | date: '%s' | times: 1
        if fd_now >= fd_start and fd_now < fd_end
          assign fd_active = true
        endif
      endif
    -%}
    {%- unless fd_active -%}{%- render 'cart-tier-bar' -%}{%- endunless -%}
    {%- render 'plaay-eid-countdown' -%}
    {%- if fd_active -%}
      <div style="margin-top:6px;">
        <span class="font-walsheim-bold" style="display:block;font-size:11.5px;line-height:1.3;color:#021D49;margin-bottom:3px;">🎁 Father's Day &middot; 30% off applied at checkout</span>
        {%- render 'plaay-fd-countdown' -%}
      </div>
    {%- endif -%}
  </div>

  <div class="flex-1 min-h-0 overflow-y-auto overscroll-contain" data-cart-items>
    {% if cart.item_count > 0 %}
      <div class="cart_items_container px-4 pb-2">
        {%- render 'cart-drawer-items' -%}
      </div>
      {%- render 'cart-recommendations' -%}
    {% else %}
      <div class="hidden" aria-hidden="true">
        {%- render 'cart-drawer-items' -%}
      </div>
      {%- render 'plaay-cart-empty-state' -%}
    {% endif %}
  </div>

  <div class="sticky bottom-0 z-20 flex-shrink-0 border-t border-dark-blue border-opacity-10 bg-white px-5 pt-4 pb-5 shadow-[0_-8px_24px_rgba(2,29,73,0.08)]">
    {% if cart.item_count > 0 %}
      <div data-cart-drawer-footer>
        {%- render 'cart-drawer-footer' -%}
      </div>

      <a
        href="/checkout"
        class="plaay-cart-checkout-btn font-walsheim-bold uppercase">
        {{ 'cart-drawer.checkout' | t }}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>

      <button
        type="button"
        class="plaay-cart-continue-btn font-walsheim-regular"
        data-close>
        {{ 'cart-drawer.continue_shopping' | t }}
      </button>
    {% else %}
      <button
        type="button"
        class="plaay-cart-checkout-btn font-walsheim-bold uppercase"
        data-close>
        Keep Browsing
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </button>
    {% endif %}
  </div>
</div>
