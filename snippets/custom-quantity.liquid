<custom-quantity data-module="custom-quantity">
	{%- if quantity >= inventory_quantity and inventory_policy == 'deny' -%}
		{%- assign max = true -%}
	{%- endif -%}
	{% assign randomNumber = "now" | date: "%N" | modulo: 10000 %}

	{%- capture minus_btn -%}
		{%- if update -%}
			<a href="{{ routes.cart_change_url }}?line={{ line }}&quantity={{ quantity | minus: 1 }}" class="btn w-auto px-1 bg-transparent text-black font-roc-bold">
					-
			</a>
		{%- else -%}
			<button type="button" data-quantity-subtract class="w-auto bg-transparent text-black font-roc-bold text-2xl | md:text-lg">
					-
			</button>
		{%- endif -%}
	{%- endcapture -%}

	{%- capture add_btn -%}
		{%- if update -%}
			<a href="{{ routes.cart_change_url }}?line={{ line }}&quantity={{ quantity | plus: 1 }}" class="btn w-auto px-1 bg-transparent text-black font-roc-bold">
				+
			</a>
		{%- else -%}
			<button type="button" data-quantity-add class="w-auto bg-transparent text-black font-roc-bold text-2xl | md:text-lg">
				+
			</button>
		{%- endif -%}
	{%- endcapture -%}

	<div class="qtyBtn flex w-full rounded-lg {% if height %} {{ height }} {% else %} {% if product_quantity %} bg-white h-9 {% else %} border-dark-blue border font-walsheim-bold {% endif %} {% endif %}" data-quantity>
		<span class="flex-1 flex justify-center">
			{{- minus_btn -}}  
		</span>
		<div>
			<label for="quantity-{{ section.id }}-{{ product.id }}-{{ randomNumber }}" class="text-0"> Quantity </label>
			<input type="number" id="quantity-{{ section.id }}-{{ product.id }}-{{ randomNumber }}"
			class="text-center bg-transparent h-[90%] {% if height %} {{ height }} {% else %}{% if product_quantity %} h-9 text-xs font-walsheim-bold {% else %} text-lg {% endif %} {% endif %} w-10 border-none p-0" 
			name="quantity" value="1"
			readonly data-quantity-input min="1">
			{% if additional_text %}
				<span class="text-xs text-dark-blue font-walsheim-bold -ml-4">{{ additional_text }}</span>
			{% endif %}
		</div>
		<span class="flex-1 flex justify-center">
			{{- add_btn -}}
		</span>
	</div>

</custom-quantity>