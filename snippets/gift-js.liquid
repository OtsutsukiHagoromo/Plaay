<script>
(function() {
  if (window.plaayMysteryGiftReady) return;
  window.plaayMysteryGiftReady = true;

  var GIFT_VARIANT_ID = 48526560592089;
  var GIFT_THRESHOLD = {{ settings.cart_tier_1_spend | default: 250 | times: 100 }};
  var SYNC_DELAY = 350;
  var syncTimer = null;
  var syncing = false;
  var syncPromise = null;        // track active sync so checkout can await it
  var lastQualificationState = null;

  // ── Celebration / feedback animations ─────────────────────────────────────
  function animateTierBar(state) {
    var bar = document.getElementById('plaay-tier-bar');
    if (!bar) return;
    bar.classList.remove('plaay-tier-bar--gift-unlocked', 'plaay-tier-bar--gift-lost');
    void bar.offsetWidth;
    bar.classList.add(state === 'unlock' ? 'plaay-tier-bar--gift-unlocked' : 'plaay-tier-bar--gift-lost');
    setTimeout(function() {
      bar.classList.remove('plaay-tier-bar--gift-unlocked', 'plaay-tier-bar--gift-lost');
    }, 1200);
  }

  function spawnConfettiFallback() {
    var overlay = document.createElement('div');
    overlay.className = 'plaay-cart-confetti';
    var colors = ['#F9C61D', '#021D49', '#FFFFFF', '#FDBA24'];
    for (var i = 0; i < 26; i += 1) {
      var piece = document.createElement('span');
      piece.className = 'plaay-cart-confetti__piece';
      piece.style.left = (8 + Math.random() * 84) + '%';
      piece.style.background = colors[i % colors.length];
      piece.style.animationDelay = (Math.random() * 120) + 'ms';
      piece.style.setProperty('--confetti-x', ((Math.random() * 180) - 90) + 'px');
      piece.style.setProperty('--confetti-y', (150 + Math.random() * 170) + 'px');
      piece.style.setProperty('--confetti-rotate', ((Math.random() * 540) - 270) + 'deg');
      overlay.appendChild(piece);
    }
    document.body.appendChild(overlay);
    setTimeout(function() { overlay.remove(); }, 1400);
  }

  function celebrateMysteryGift() {
    animateTierBar('unlock');
    if (typeof window.confetti === 'function') {
      window.confetti({ particleCount: 85, spread: 72, startVelocity: 34, ticks: 180, origin: { x: 0.28, y: 0.2 }, colors: ['#F9C61D', '#021D49', '#FFFFFF'] });
      window.confetti({ particleCount: 85, spread: 72, startVelocity: 34, ticks: 180, origin: { x: 0.72, y: 0.2 }, colors: ['#F9C61D', '#021D49', '#FFFFFF'] });
      return;
    }
    spawnConfettiFallback();
  }

  function showMysteryGiftRemoved() { animateTierBar('lost'); }

  function syncRewardFeedback(qualifies) {
    if (lastQualificationState === null) { lastQualificationState = qualifies; return; }
    if (!lastQualificationState && qualifies) { celebrateMysteryGift(); }
    else if (lastQualificationState && !qualifies) { showMysteryGiftRemoved(); }
    lastQualificationState = qualifies;
  }
  // ──────────────────────────────────────────────────────────────────────────

  function isCartMutation(url) {
    return /\/cart\/(add|change|update|clear)(\.js)?(\?|$)/.test(String(url || ''));
  }

  function refreshCartUi(totalPrice) {
    if (window.plaayTierBar && typeof totalPrice === 'number') { window.plaayTierBar.update(totalPrice); }
    if (window.plaayRefreshCartDrawer) { window.plaayRefreshCartDrawer().catch(function() {}); }
    if (window.plaayRefreshCartPage)   { window.plaayRefreshCartPage().catch(function() {}); }
  }

  function fetchCart() {
    return fetch('/cart.js', { headers: { 'Accept': 'application/json' } })
      .then(function(r) { if (!r.ok) throw new Error('Failed to fetch cart'); return r.json(); });
  }

  function cartChange(payload) {
    return fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify(payload)
    }).then(function(r) { if (!r.ok) throw new Error('Failed to change cart'); return r.json(); });
  }

  function addGift() {
    return fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ items: [{ id: GIFT_VARIANT_ID, quantity: 1, properties: { '_plaay_reward': 'Mystery Gift' } }] })
    }).then(function(r) { if (!r.ok) throw new Error('Failed to add mystery gift'); return r.json(); });
  }

  function getGiftLines(cart) {
    return (cart.items || []).filter(function(item) { return Number(item.variant_id) === GIFT_VARIANT_ID; });
  }

  function getQualifyingSubtotal(cart) {
    return (cart.items || []).reduce(function(sum, item) {
      if (Number(item.variant_id) === GIFT_VARIANT_ID) return sum;
      return sum + Number(item.final_line_price || 0);
    }, 0);
  }

  function normalizeGiftQuantity(giftLines) {
    if (!giftLines.length) return Promise.resolve(null);
    var actions = [];
    giftLines.forEach(function(line, index) {
      var targetQty = index === 0 ? 1 : 0;
      if (Number(line.quantity) !== targetQty) { actions.push(cartChange({ id: line.key, quantity: targetQty })); }
    });
    return Promise.all(actions);
  }

  function removeGift(giftLines) {
    if (!giftLines.length) return Promise.resolve(null);
    return Promise.all(giftLines.map(function(line) { return cartChange({ id: line.key, quantity: 0 }); }));
  }

  // Returns a Promise — callers (e.g. checkout intercept) can await it
  function syncMysteryGift() {
    if (syncing) return syncPromise; // share in-flight promise

    syncing = true;
    syncPromise = fetchCart()
      .then(function(cart) {
        var qualifyingSubtotal = getQualifyingSubtotal(cart);
        var giftLines = getGiftLines(cart);
        var giftQty = giftLines.reduce(function(sum, l) { return sum + Number(l.quantity || 0); }, 0);
        var qualifies = qualifyingSubtotal >= GIFT_THRESHOLD;

        if (qualifies && giftQty === 0) {
          return addGift().then(fetchCart).then(function(next) {
            refreshCartUi(next.total_price);
            syncRewardFeedback(true);
          });
        }
        if (qualifies && giftQty > 1) {
          return normalizeGiftQuantity(giftLines).then(fetchCart).then(function(next) {
            refreshCartUi(next.total_price);
            syncRewardFeedback(true);
          });
        }
        if (!qualifies && giftQty > 0) {
          return removeGift(giftLines).then(fetchCart).then(function(next) {
            refreshCartUi(next.total_price);
            syncRewardFeedback(false);
          });
        }

        syncRewardFeedback(qualifies);
        refreshCartUi(cart.total_price);
        return null;
      })
      .catch(function(err) { console.error('Plaay mystery gift sync failed:', err); })
      .finally(function() { syncing = false; syncPromise = null; });

    return syncPromise;
  }

  function scheduleSync(delay) {
    clearTimeout(syncTimer);
    syncTimer = setTimeout(function() {
      syncTimer = null;
      syncMysteryGift();
    }, typeof delay === 'number' ? delay : SYNC_DELAY);
  }

  // ── Checkout race-condition guard ──────────────────────────────────────────
  // If a sync is debounced or running when checkout is tapped, block navigation,
  // flush the timer, await the sync, then navigate. Closes the window where a
  // user could buy qty > 1 gifts or a gift that should have been removed.
  document.addEventListener('click', function(e) {
    var link = e.target.closest('a[href*="/checkout"], [data-checkout-url]');
    if (!link) return;

    var pendingDebounce = syncTimer !== null;
    var pendingSync     = syncing;
    if (!pendingDebounce && !pendingSync) return; // nothing to wait for

    e.preventDefault();
    e.stopImmediatePropagation();

    // Show spinner on the button
    var originalHTML = link.innerHTML;
    link.setAttribute('aria-disabled', 'true');
    link.style.pointerEvents = 'none';
    link.style.opacity = '0.7';
    link.innerHTML = '<span style="display:inline-flex;align-items:center;gap:6px;">'
      + '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="animation:plaay-spin 0.7s linear infinite"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>'
      + 'Securing&hellip;</span>';

    // Cancel pending debounce, run sync immediately
    clearTimeout(syncTimer);
    syncTimer = null;

    var work = pendingSync ? syncPromise : syncMysteryGift();
    Promise.resolve(work).finally(function() {
      // Restore button (in case navigation fails)
      link.removeAttribute('aria-disabled');
      link.style.pointerEvents = '';
      link.style.opacity = '';
      link.innerHTML = originalHTML;
      window.location.href = link.getAttribute('href') || '/checkout';
    });
  }, true); // capture phase — fires before other click handlers

  // Inject spin keyframes once
  if (!document.getElementById('plaay-gift-spin-style')) {
    var s = document.createElement('style');
    s.id = 'plaay-gift-spin-style';
    s.textContent = '@keyframes plaay-spin{to{transform:rotate(360deg)}}';
    document.head.appendChild(s);
  }
  // ──────────────────────────────────────────────────────────────────────────

  // Patch fetch to detect cart mutations
  if (!window.plaayMysteryGiftFetchPatched) {
    window.plaayMysteryGiftFetchPatched = true;
    var originalFetch = window.fetch;
    window.fetch = function(input, init) {
      var url = typeof input === 'string' ? input : (input && input.url ? input.url : '');
      var req = originalFetch.apply(this, arguments);
      if (isCartMutation(url)) { req.then(function() { scheduleSync(); }).catch(function() {}); }
      return req;
    };
  }

  window.plaaySyncMysteryGift = scheduleSync;

  document.addEventListener('rebuy:cart.change', function() { scheduleSync(); });
  document.addEventListener('cart:refresh',       function() { scheduleSync(); });

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() { scheduleSync(600); }, { once: true });
  } else {
    scheduleSync(600);
  }
})();
</script>
