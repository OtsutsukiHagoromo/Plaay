{% liquid 
  assign article_one = block.settings.article_one 
  assign article_two = block.settings.article_two 
  assign article_three = block.settings.article_three 
  assign article_four = block.settings.article_four 
  
  assign cols_desktop_large = block.settings.number_of_columns_desktop_large 
  assign cols_desktop = block.settings.number_of_columns_desktop
  assign cols_tablet = block.settings.number_of_columns_tablet 
  assign cols_mobile = block.settings.number_of_columns_mobile

  assign background_color = block.settings.background_color
  assign padding_bottom_mobile = block.settings.padding_bottom_mobile
  assign padding_top_mobile = block.settings.padding_top_mobile
  assign padding_bottom_desktop = block.settings.padding_bottom_desktop 
  assign padding_top_desktop = block.settings.padding_top_desktop
%}

{% style %}
  @media only screen and (max-width: 1023px){
    #grid_articles-{{ block.id }}{
      padding-top: {{ padding_top_mobile }}px;
      padding-bottom: {{ padding_bottom_mobile }}px;
    }
  }
  @media only screen and (min-width: 1024px){
    #grid_articles-{{ block.id }}{
      padding-top: {{ padding_top_desktop }}px;
      padding-bottom: {{ padding_bottom_desktop }}px;
    }
  }
  .article_excerpt p:empty{
    height: 10px;
  }
{% endstyle %}

<div style="background-color: {{ background_color }};">
  <div id="grid_articles-{{ block.id }}" class="container grid grid-cols-{{ cols_mobile }} md:grid-cols-{{ cols_tablet }} | lg:grid-cols-{{ cols_desktop }} | xl:grid-cols-{{ cols_desktop_large }}">
    {% if article_one != blank %}
      <div class="mt-8 mr-2 | md:mt-4 md:mx-4 | lg:mx-5">
        {% render 'archive-article', article: article_one %}
      </div>
    {% endif %}
    {% if article_two != blank %} 
      <div class="mt-8 ml-2 | md:mt-4 md:mx-4 | lg:mx-5">
        {% render 'archive-article', article: article_two %}
      </div>
    {% endif %}
    {% if article_three != blank %}
      <div class="mt-8 mr-2 | md:mt-4 md:mx-4 | lg:mx-5">
        {% render 'archive-article', article: article_three %}
      </div>
    {% endif %}
    {% if article_four != blank %}
      <div class="mt-8 ml-2 | md:mt-4 md:mx-4 | lg:mx-5">
        {% render 'archive-article', article: article_four %}
      </div>
    {% endif %}
  </div>
</div>