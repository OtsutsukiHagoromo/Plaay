{% liquid 
  assign usp_images = product.metafields.custom.usp_image.value
  assign usp_text = product.metafields.arena.usp_text.value
  assign ingredients_image = product.metafields.arena.ingredients_image
  assign hover_state_image = product.metafields.arena.hover_state_image
%}

{% style %}
  .product_tile::after {
    content: '';
    width: 100%;
    height: 100%;
    position: absolute;
    top: 0;
    left: 0;
    border-radius: 12px;
    {% if grey_background %}
      background: rgba(128, 128, 128, 0.3);
    {% else %}
      background: #000;
      opacity: 0.1;
    {% endif %}
    left: 8px;
    top: 6px;
  }

  .product_flip_back {
    transform: rotateY(-180deg);
    transition: 0.1s opacity, 0.25s transform;
  }
  .product_flip_front {
    transition: 0.1s opacity, 0.25s transform;
  }
  .product_flip_back.flip {
    transform: rotateY(0deg);
    opacity: 1;
  }
  .product_flip_front.flip {
    transform: rotateY(180deg);
    opacity: 0;
  }
  .whats_inside_button.active .icon {
    color: #F9C61D;
  }
  {% if hover_state_image != blank %}
    @media only screen and (min-width: 1024px) {
      #product_tile-{{ product.id }} .product_flip_front:hover .product_tile_featured_image {
        opacity: 0;
      }
      #product_tile-{{ product.id }} .product_flip_front:hover .product_tile_hover_state_image {
        opacity: 1;
      }
      #product_tile-{{ product.id }} .product_flip_front:hover .btn {
        background: #9F2BB8;
        color: #FFF;
        border-color: #9F2BB8;
      }
      #product_tile-{{ product.id }} .product_flip_front:hover .btn:hover {
        border-color: #021D49;
        background: #021D49;
        color: #F9C61D;
      }
    }
  {% endif %}
{% endstyle %}
<div id="product_tile-{{ product.id }}" class="rounded-xl mx-auto z-1 product_tile relative h-full border border-black border-opacity-25 | sm:max-w-xs">
  {% comment %} flip button {% endcomment %}
  {% comment %}
  {% if ingredients_image != blank %}
    <div class="absolute flex items-center cursor-pointer whats_inside_button z-6 top-4 left-4">
      <span class="flex w-5 h-5 transition-all duration-200 text-dark-blue icon">
        {% render 'icon-flip' %}
      </span>
      <span class="w-8 ml-1 leading-none uppercase text-xxs text-dark-blue font-walsheim-bold">{{ 'product.whats_inside' | t }}</span>
    </div>
  {% endif %}
  {% endcomment %}
  {% comment %} main product form {% endcomment %}
  <form
    action="/cart/add"
    method="post"
    enctype="multipart/form-data"
    class="content_container flex flex-col items-center justify-between pt-9 p-4 px-5 h-full w-full rounded-xl z-5 relative {% if grey_background %} bg-grey-f5 {% else %} bg-white {% endif %} | md:justify-between"
    id="add-to-cart-{{ product.selected_or_first_available_variant.id }}-{{ section.id }}"
    data-title="{{ product.title }}">
    {%- render 'plaay-badge', product: product -%}
    {%- render 'plaay-wishlist-heart', product: product -%}
    <div class="relative flex flex-col justify-between w-full h-full product_flip_front z-5">
      {% comment %} hidden selects {% endcomment %}
      <select
        name="id"
        id="productSelect"
        class="hidden">
        {% for variant in product.variants %}
          {% if variant.available %}
            <option value="{{variant.id}}">
              {{ variant.title }} - {{ variant.price | money_with_currency }}
            </option>
          {% else %}
            <option disabled="disabled">
              {{ variant.title }} - Uitverkocht
            </option>
          {% endif %}
        {% endfor %}
      </select>
      {% comment %} product discount sticker {% endcomment %}
      {% unless settings.hide_product_discount %}
        {% if product.compare_at_price %}
          {% assign discount_divide = product.price | times: 100 | divided_by: product.compare_at_price | times: 100 %}
          {% assign discount_divide_again = discount_divide | divided_by: 100 %}
          {% assign discount = 100 | minus: discount_divide_again | round %}

          <div class="flex items-center justify-center p-2 ml-auto mr-0 -mt-16 text-sm leading-none text-center text-white uppercase transition-all duration-200 transform rounded-full bg-yellow h-14 w-14 font-walsheim-black translate-y-9">
            {{ discount }}% OFF
          </div>
        {% endif %}
      {% endunless %}
      {% for collection in product.collections %}
        {% if collection.title contains 'Limited Editions' %}
          
        {% endif %}
      {% endfor %}  
      {% comment %} product image {% endcomment %}
      {% if hover_state_image %}
        <a href="{{ product.url }}" class="text-0">
          {{ product.title }}
          {% render 'img', img: hover_state_image, lazy: true, class: 'product_tile_hover_state_image absolute left-0 opacity-0 transition-all duration-300 ease-in-out h-60 object-contain w-full', type: 'img' %}
        </a>
      {% endif %}
      {% comment %}
      <a href="{{ product.url }}" class="text-0">
        {{ product.title }}
        {% if eager_load == true %}
          {% render 'img', img: product.featured_image, eager: true, class: 'product_tile_featured_image transition-all duration-300 ease-in-out h-60 object-contain w-full', type: 'img' %}
        {% else %}
          {% render 'img', img: product.featured_image, lazy: true, class: 'product_tile_featured_image transition-all duration-300 ease-in-out h-60 object-contain w-full', type: 'img' %}
        {% endif %}
      </a>
      {% endcomment %}

      <a href="{{ product.url }}" class="text-0 product-tile">
      {{ product.title }}
      
      {%- assign second_image = product.media[1] -%} 
      {%- assign featured_image = product.featured_image -%}
      {%- assign second_image_preview = second_image.preview_image | default: second_image -%}
      {%- capture product_tile_sizes -%}(min-width: 1536px) 280px, (min-width: 1280px) 22vw, (min-width: 1024px) 28vw, (min-width: 640px) 30vw, 46vw{%- endcapture -%}
    
      {% if eager_load == true %}
        <img
          src="{{ featured_image | image_url: width: 533 }}"
          srcset="{{ featured_image | image_url: width: 320 }} 320w, {{ featured_image | image_url: width: 480 }} 480w, {{ featured_image | image_url: width: 640 }} 640w, {{ featured_image | image_url: width: 800 }} 800w"
          sizes="{{ product_tile_sizes }}"
          alt="{{ product.title }}"
          width="{{ featured_image.width }}"
          height="{{ featured_image.height }}"
          fetchpriority="high"
          decoding="async"
          class="product_tile_featured_image transition-all duration-300 ease-in-out h-60 object-contain w-full"
        >
      {% else %}
        <img
          src="{{ featured_image | image_url: width: 533 }}"
          srcset="{{ featured_image | image_url: width: 320 }} 320w, {{ featured_image | image_url: width: 480 }} 480w, {{ featured_image | image_url: width: 640 }} 640w, {{ featured_image | image_url: width: 800 }} 800w"
          sizes="{{ product_tile_sizes }}"
          alt="{{ product.title }}"
          loading="lazy"
          width="{{ featured_image.width }}"
          height="{{ featured_image.height }}"
          decoding="async"
          class="product_tile_featured_image transition-all duration-300 ease-in-out h-60 object-contain w-full"
        >
      {% endif %}
    
      {% if second_image != blank %}
        <img
          src="{{ second_image_preview | image_url: width: 533 }}"
          srcset="{{ second_image_preview | image_url: width: 320 }} 320w, {{ second_image_preview | image_url: width: 480 }} 480w, {{ second_image_preview | image_url: width: 640 }} 640w, {{ second_image_preview | image_url: width: 800 }} 800w"
          sizes="{{ product_tile_sizes }}"
          alt="{{ product.title }}"
          width="{{ second_image_preview.width }}"
          height="{{ second_image_preview.height }}"
          class="product_tile_secondary_image absolute inset-0 transition-opacity duration-300 ease-in-out opacity-0 h-60 object-contain w-full"
          loading="lazy"
          decoding="async"
        >
      {% endif %}
    </a>
    
    <style>
      .product-tile {
        position: relative;
      }
    {% if collection.title != 'Limited Editions' %}
      .product_tile:hover .product_tile_secondary_image {
        opacity: 1;
      }
    
      .product_tile:hover .product_tile_featured_image {
        opacity: 0;
      }
      {% endif %}
    </style>


      {% comment %} title / price {% endcomment %}
      <div class="flex gap-1 justify-between w-full pt-2 csutom-info">
        <p class="mr-3 uppercase text-dark-blue font-walsheim-black card-product-title">{{ product.title }}</p>
        <div class='yotpo bottomLine' style="display:none" data-product-id='{{ product.id }}' data-yotpo-show-bottomline='true'></div>
 {% if product.metafields.yotpo.reviews_count and product.metafields.yotpo.reviews_count != "0" %}
           <div class="yotpo bottomLine"
           data-product-id="{{ product.id }}"
           data-name="{{ product.title }}">
           </div>

     {% endif %}

        {% render 'product-price', product: product %}
      </div>
      {% comment %} USPs {% endcomment %}
      {% comment %}
      {% if usp_images != blank or usp_text != blank %}
        {% assign usp_text_size = usp_text | size %}
        <div class="{% if usp_text_size == 4 or usp_text_size == 2 or usp_text_size == 6 %} grid grid-cols-2 {% else %} flex items-center flex-wrap {% endif %} w-full my-5 ffff">
          {% for image in usp_images limit: 3 %}
            {% assign text = usp_text[forloop.index0] %}
            <div class="flex items-center w-1/3 | {% unless forloop.first %} pl-2 sm:pl-3 {% endunless %}">
              {% render 'img', type: 'img', img: image, lazy: true, class: 'h-7 w-7 object-contain mr-2' %}
              <span class="text-grey-80 text-[9px] uppercase font-walsheim-bold | sm:text-xxs">{{ text }}</span>
            </div>
          {% endfor %}
        </div>
      {% endif %}
      {% endcomment %}
    </div>
    {% comment %} add to cart button {% endcomment %}
    {% unless hide_atc %}
    <div class="flex justify flex-col w-full z-10 relative | lg:flex-row">
      {% comment %} quick add functionality {% endcomment %}
      {% if product.selling_plan_groups.size > 0 %}
        {% render 'btn', type: 'button', copy: 'action.quick-add', style: 'yellow', additional_class: 'mt-3 font-walsheim-bold activate_popup transition-all duration-300', is_add_to_cart: true, width: 'full', product: product %}
      {% else %}
        <quick-add
          data-module="quick-add"
          data-id="{{- product.first_available_variant.id -}}"
          class="w-full">
          <input
            type="hidden"
            name="quantity"
            value="1">

          {% render 'btn', type: 'button', copy: 'action.add-to-cart', style: 'yellow', additional_class: 'mt-3 font-walsheim-bold transition-all duration-300', width: 'full', is_add_to_cart: true, product: product %}
        </quick-add>
      {% endif %}
    </div>
    {% endunless %}
    {% if ingredients_image != blank %}
      <div class="product_flip_back mt-[6px] w-full absolute h-[calc(100%_-_70px)] {% if grey_background %} bg-grey-f5 {% else %} bg-white {% endif %} left-0 -top-[6px] z-3 rounded-xl px-5 pt-14 pb-4 transform opacity-0">
        <a href="{{ product.url }}">
          {% render 'img', type: 'img', img: ingredients_image, lazy: true, class: 'object-contain h-full w-full' %}
        </a>
      </div>
    {% endif %}
  </form>
</div>
