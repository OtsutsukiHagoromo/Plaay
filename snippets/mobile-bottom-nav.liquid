{% liquid
  assign left_links  = linklists['navigation-menu-left'].links
  assign right_links = linklists['navigation-menu-right'].links
%}

{%- comment -%} ── Full Menu Bottom Sheet ── {%- endcomment -%}
<div class="pbn-sheet-backdrop" id="pbn-sheet-backdrop"></div>

<div class="pbn-sheet" id="pbn-shop-sheet" role="dialog" aria-modal="true" aria-label="Site menu">

  <div class="pbn-sheet__handle-wrap">
    <span class="pbn-sheet__handle"></span>
  </div>

  <div class="pbn-sheet__head">
    <h2 class="pbn-sheet__title">Menu</h2>
    <button class="pbn-sheet__close" id="pbn-sheet-close" aria-label="Close menu">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
        <path d="M2 2l12 12M14 2L2 14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <div class="pbn-sheet__body">

    {%- comment -%} ── Primary nav (left) — shop-style links ── {%- endcomment -%}
    {%- assign is_first_accordion = true -%}
    {%- for link in left_links -%}
      {%- if link.links != blank -%}
        <div class="pbn-nav__group{% if is_first_accordion %} pbn-nav__group--open{% endif %}" data-pbn-accordion>
          <button type="button" class="pbn-nav__parent" aria-expanded="{% if is_first_accordion %}true{% else %}false{% endif %}">
            <span>{{ link.title }}</span>
            <span class="pbn-nav__chevron" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </button>
          <div class="pbn-nav__children{% if is_first_accordion %} is-open{% endif %}">
            <div class="pbn-sub__scroll">
              {%- for child in link.links -%}
                {%- assign col_handle = child.url | remove: '/collections/' | split: '?' | first -%}
                {%- assign col = collections[col_handle] -%}
                {%- assign sub_img_url = nil -%}
                {%- assign child_title_lc = child.title | downcase -%}
                {%- if col_handle == 'all' or child_title_lc == 'shop all' or child_title_lc == 'all' or child.url == '/collections' -%}
                  {%- assign sub_img_url = 'https://cdn.shopify.com/s/files/1/0662/4722/9657/files/2._DSC00491.png?v=1775537600' -%}
                {%- elsif col.featured_image -%}
                  {%- assign sub_img_url = col.featured_image | img_url: '160x160', crop: 'center' -%}
                {%- endif -%}
                <a href="{{ child.url }}" class="pbn-sub__card">
                  <span class="pbn-sub__img">
                    {%- if sub_img_url -%}
                      <img
                        src="{{ sub_img_url }}"
                        alt="{{ child.title }}"
                        loading="lazy"
                        width="80"
                        height="80"
                      >
                    {%- else -%}
                      <span class="pbn-sub__img-fallback">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                          <rect x="3" y="3" width="18" height="18" rx="4" stroke="currentColor" stroke-width="1.5"/>
                          <circle cx="8.5" cy="8.5" r="1.5" fill="currentColor"/>
                          <path d="M3 15l5-5 4 4 3-3 6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </span>
                    {%- endif -%}
                  </span>
                  <span class="pbn-sub__name">{{ child.title }}</span>
                </a>
              {%- endfor -%}
            </div>
          </div>
        </div>
        {%- assign is_first_accordion = false -%}
      {%- else -%}
        <a href="{{ link.url }}" class="pbn-nav__item">
          <span>{{ link.title }}</span>
          <span class="pbn-nav__arrow" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M3 11L11 3M11 3H6M11 3v5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </a>
      {%- endif -%}
    {%- endfor -%}

    {%- comment -%} ── Secondary nav (right) — info links at bottom ── {%- endcomment -%}
    {%- if right_links != blank -%}
      <div class="pbn-nav__section-label">More</div>
      <div class="pbn-nav__secondary">
        {%- for link in right_links -%}
          {%- if link.links != blank -%}
            <div class="pbn-nav__group" data-pbn-accordion>
              <button type="button" class="pbn-nav__parent pbn-nav__parent--sm" aria-expanded="false">
                <span>{{ link.title }}</span>
                <span class="pbn-nav__chevron" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                    <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </button>
              <div class="pbn-nav__children">
                <div class="pbn-nav__children-list">
                  {%- for child in link.links -%}
                    <a href="{{ child.url }}" class="pbn-nav__child">{{ child.title }}</a>
                  {%- endfor -%}
                </div>
              </div>
            </div>
          {%- else -%}
            <a href="{{ link.url }}" class="pbn-nav__item pbn-nav__item--sm">
              <span>{{ link.title }}</span>
              <span class="pbn-nav__arrow" aria-hidden="true">
                <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
                  <path d="M3 11L11 3M11 3H6M11 3v5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} ── Utility row ── {%- endcomment -%}
    <div class="pbn-nav__utils">
      <a href="{% if customer %}/account{% else %}/account/login{% endif %}" class="pbn-nav__util">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none">
          <circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="1.75"/>
          <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
        </svg>
        <span>{% if customer %}{{ customer.first_name | default: 'Account' }}{% else %}Sign in{% endif %}</span>
      </a>
      <a href="/pages/wishlist" class="pbn-nav__util">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none">
          <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" stroke="currentColor" stroke-width="1.75" fill="none"/>
        </svg>
        <span>Wishlist</span>
      </a>
    </div>

  </div>
</div>

{%- comment -%} ── Bottom Nav Bar ── {%- endcomment -%}
<nav class="pbn" id="plaay-bottom-nav" aria-label="Mobile navigation">

  <a href="/" class="pbn__tab" data-pbn-path="/">
    <span class="pbn__pill" aria-hidden="true">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
        <path d="M3 9.5L12 3l9 6.5V20a1 1 0 01-1 1H5a1 1 0 01-1-1V9.5z" stroke="currentColor" stroke-width="1.75" stroke-linejoin="round"/>
        <path d="M9 21V12h6v9" stroke="currentColor" stroke-width="1.75" stroke-linejoin="round"/>
      </svg>
    </span>
    <span class="pbn__label">Home</span>
  </a>

  <button type="button" class="pbn__tab" id="pbn-shop-btn" aria-label="Open menu" aria-haspopup="dialog">
    <span class="pbn__pill" aria-hidden="true">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
        <path d="M4 6h16M4 12h16M4 18h10" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
      </svg>
    </span>
    <span class="pbn__label">Menu</span>
  </button>

  <button type="button" class="pbn__tab" id="pbn-cart-btn" aria-label="Open cart">
    <span class="pbn__pill" aria-hidden="true">
      <span class="pbn__cart-wrap">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
          <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" stroke="currentColor" stroke-width="1.75" stroke-linejoin="round"/>
          <path d="M3 6h18" stroke="currentColor" stroke-width="1.75"/>
          <path d="M16 10a4 4 0 01-8 0" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
        </svg>
        {%- if cart.item_count > 0 -%}
          <span class="pbn__badge" id="pbn-cart-badge">{{ cart.item_count }}</span>
        {%- else -%}
          <span class="pbn__badge pbn__badge--hidden" id="pbn-cart-badge">0</span>
        {%- endif -%}
      </span>
    </span>
    <span class="pbn__label">Cart</span>
  </button>

  <a href="{% if customer %}/account{% else %}/account/login{% endif %}" class="pbn__tab" data-pbn-path="/account">
    <span class="pbn__pill" aria-hidden="true">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
        <circle cx="12" cy="8" r="3.75" stroke="currentColor" stroke-width="1.75"/>
        <path d="M4 20c0-3.87 3.58-7 8-7s8 3.13 8 7" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
      </svg>
    </span>
    <span class="pbn__label">Account</span>
  </a>

</nav>

<style>
  .pbn { display: none; }
  .pbn-sheet,
  .pbn-sheet-backdrop { display: none; }

  @media (max-width: 1023px) {
    /* ── Hide hamburger (Menu now lives in bottom nav) ── */
    .hamburger_icon { display: none !important; }
    /* ── Hide header cart (Cart now lives in bottom nav) ── */
    .header__icon--cart { display: none !important; }

    /* ── True-centre header layout: 3-col grid, equal gutters ── */
    header .inner_container {
      display: grid !important;
      grid-template-columns: 1fr auto 1fr !important;
      padding-left: 16px !important;
      padding-right: 16px !important;
    }
    /* Left column (was w-2/5 with hamburger) — reset width, collapse padding */
    header .inner_container > div:first-child {
      width: auto !important;
      padding: 0 !important;
      display: flex;
      align-items: center;
    }
    /* Center column — logo */
    header .inner_container > div:nth-child(2) {
      width: auto !important;
    }
    /* Right column — search icon, flush right */
    header .inner_container > div:last-child {
      width: auto !important;
      padding: 0 !important;
      display: flex !important;
      align-items: center !important;
      justify-content: flex-end !important;
    }

    /* ── Backdrop ── */
    .pbn-sheet-backdrop {
      display: block;
      position: fixed;
      inset: 0;
      background: rgba(2, 29, 73, 0.55);
      z-index: 9010;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s ease;
    }
    .pbn-sheet-backdrop.is-open { opacity: 1; pointer-events: auto; }

    /* ── Sheet ── */
    .pbn-sheet {
      display: block;
      position: fixed;
      left: 0;
      right: 0;
      bottom: calc(60px + env(safe-area-inset-bottom));
      max-height: 82vh;
      background: #fff;
      border-radius: 22px 22px 0 0;
      z-index: 9020;
      overflow-y: auto;
      overscroll-behavior: contain;
      transform: translateY(110%);
      transition: transform 0.38s cubic-bezier(0.32, 0.72, 0, 1);
      box-shadow: 0 -8px 48px rgba(2, 29, 73, 0.2);
    }
    .pbn-sheet.is-open { transform: translateY(0); }

    /* ── Handle ── */
    .pbn-sheet__handle-wrap {
      display: flex;
      justify-content: center;
      padding: 12px 0 4px;
      position: sticky;
      top: 0;
      background: #fff;
      z-index: 2;
    }
    .pbn-sheet__handle {
      width: 36px;
      height: 4px;
      border-radius: 99px;
      background: rgba(2, 29, 73, 0.13);
    }

    /* ── Sheet header ── */
    .pbn-sheet__head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 10px 20px 12px;
      position: sticky;
      top: 28px;
      background: #fff;
      z-index: 2;
      border-bottom: 1px solid rgba(2, 29, 73, 0.07);
    }
    .pbn-sheet__title {
      font-family: walsheim-black, sans-serif;
      font-size: 24px;
      color: #021d49;
      line-height: 1;
      margin: 0;
    }
    .pbn-sheet__close {
      background: rgba(2, 29, 73, 0.07);
      border: none;
      width: 32px;
      height: 32px;
      border-radius: 99px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #021d49;
      cursor: pointer;
      -webkit-tap-highlight-color: transparent;
    }

    /* ── Sheet body ── */
    .pbn-sheet__body {
      padding-bottom: calc(16px + env(safe-area-inset-bottom));
    }

    /* ── Primary nav item (no children) ── */
    .pbn-nav__item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 15px 20px;
      font-family: walsheim-bold, sans-serif;
      font-size: 16px;
      color: #021d49;
      text-decoration: none;
      border-bottom: 1px solid rgba(2, 29, 73, 0.06);
      -webkit-tap-highlight-color: transparent;
    }
    .pbn-nav__item:active { background: #F5F3EE; }
    .pbn-nav__item--sm {
      font-size: 14px;
      padding: 13px 20px;
      color: rgba(2, 29, 73, 0.7);
    }
    .pbn-nav__arrow { opacity: 0.3; flex-shrink: 0; }

    /* ── Accordion ── */
    .pbn-nav__group { border-bottom: 1px solid rgba(2, 29, 73, 0.06); }
    .pbn-nav__parent {
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      padding: 15px 20px;
      font-family: walsheim-bold, sans-serif;
      font-size: 16px;
      color: #021d49;
      background: transparent;
      border: none;
      text-align: left;
      cursor: pointer;
      -webkit-tap-highlight-color: transparent;
    }
    .pbn-nav__parent--sm {
      font-size: 14px;
      padding: 13px 20px;
      color: rgba(2, 29, 73, 0.7);
      font-family: walsheim-bold, sans-serif;
    }
    .pbn-nav__chevron {
      flex-shrink: 0;
      opacity: 0.35;
      transition: transform 0.22s ease;
    }
    .pbn-nav__parent[aria-expanded="true"] .pbn-nav__chevron {
      transform: rotate(180deg);
      opacity: 0.7;
    }

    /* ── Sub-links container ── */
    .pbn-nav__children {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.32s ease;
    }
    .pbn-nav__children.is-open { max-height: 800px; }

    /* ── Image scroll carousel (primary nav sub-items) ── */
    .pbn-sub__scroll {
      display: flex;
      gap: 10px;
      padding: 14px 20px 18px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    .pbn-sub__scroll::-webkit-scrollbar { display: none; }

    .pbn-sub__card {
      flex-shrink: 0;
      width: 90px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      text-decoration: none;
      scroll-snap-align: start;
      -webkit-tap-highlight-color: transparent;
    }

    .pbn-sub__img {
      width: 80px;
      height: 80px;
      border-radius: 16px;
      overflow: hidden;
      background: #F5F3EE;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      transition: transform 0.15s;
    }
    .pbn-sub__card:active .pbn-sub__img { transform: scale(0.94); }

    .pbn-sub__img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .pbn-sub__img-fallback {
      color: rgba(2, 29, 73, 0.2);
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      height: 100%;
    }

    .pbn-sub__name {
      font-family: walsheim-bold, sans-serif;
      font-size: 11px;
      color: #021d49;
      text-align: center;
      line-height: 1.3;
      max-width: 84px;
    }

    /* ── Plain children list (secondary nav sub-items) ── */
    .pbn-nav__children-list {
      background: #F5F3EE;
    }
    .pbn-nav__child {
      display: block;
      padding: 11px 20px 11px 32px;
      font-family: walsheim, sans-serif;
      font-size: 13px;
      color: rgba(2, 29, 73, 0.7);
      text-decoration: none;
      border-top: 1px solid rgba(2, 29, 73, 0.06);
      -webkit-tap-highlight-color: transparent;
    }
    .pbn-nav__child:active { background: #ede9df; }

    /* ── Section label ── */
    .pbn-nav__section-label {
      font-family: walsheim-bold, sans-serif;
      font-size: 10px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(2, 29, 73, 0.35);
      padding: 20px 20px 8px;
    }

    /* ── Secondary nav container ── */
    .pbn-nav__secondary {
      border-top: 1px solid rgba(2, 29, 73, 0.06);
    }

    /* ── Utility row ── */
    .pbn-nav__utils {
      display: flex;
      gap: 10px;
      padding: 16px 20px 8px;
    }
    .pbn-nav__util {
      display: flex;
      align-items: center;
      gap: 8px;
      flex: 1;
      padding: 12px 14px;
      background: #F5F3EE;
      border-radius: 12px;
      font-family: walsheim-bold, sans-serif;
      font-size: 13px;
      color: #021d49;
      text-decoration: none;
      -webkit-tap-highlight-color: transparent;
    }
    .pbn-nav__util:active { background: #ede9df; }

    /* ── Bottom nav ── */
    .pbn {
      display: flex;
      position: fixed;
      bottom: 0; left: 0; right: 0;
      height: calc(60px + env(safe-area-inset-bottom));
      padding-bottom: env(safe-area-inset-bottom);
      background: rgba(255, 255, 255, 0.96);
      backdrop-filter: saturate(180%) blur(24px);
      -webkit-backdrop-filter: saturate(180%) blur(24px);
      border-top: 1px solid rgba(2, 29, 73, 0.08);
      z-index: 9030;
      align-items: stretch;
    }
    .pbn__tab {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 4px;
      color: rgba(2, 29, 73, 0.38);
      text-decoration: none;
      background: transparent;
      border: none;
      padding: 0;
      cursor: pointer;
      -webkit-tap-highlight-color: transparent;
      transition: color 0.18s;
    }
    .pbn__tab.is-active { color: #021d49; }
    .pbn__pill {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 44px;
      height: 28px;
      border-radius: 14px;
      transition: background 0.18s;
    }
    .pbn__tab.is-active .pbn__pill { background: #F9C61D; }
    .pbn__cart-wrap { position: relative; display: flex; align-items: center; justify-content: center; }
    .pbn__badge {
      position: absolute;
      top: -6px; right: -8px;
      background: #021d49;
      color: #F9C61D;
      font-family: walsheim-bold, sans-serif;
      font-size: 9px;
      line-height: 1;
      min-width: 16px;
      height: 16px;
      border-radius: 999px;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0 4px;
      border: 1.5px solid #fff;
    }
    .pbn__badge--hidden { display: none; }
    .pbn__label {
      font-family: walsheim, sans-serif;
      font-size: 10px;
      line-height: 1;
      letter-spacing: 0.01em;
    }
    .pbn__tab.is-active .pbn__label { font-family: walsheim-bold, sans-serif; }

    /* ── Clearance ── */
    #main { padding-bottom: calc(60px + env(safe-area-inset-bottom)); }
    #plaay-sticky-mobile { bottom: calc(60px + env(safe-area-inset-bottom)) !important; }
    .plaay-wa-float { bottom: calc(60px + env(safe-area-inset-bottom) + 12px) !important; }
  }
</style>

<script>
  (function() {
    var nav      = document.getElementById('plaay-bottom-nav');
    var sheet    = document.getElementById('pbn-shop-sheet');
    var backdrop = document.getElementById('pbn-sheet-backdrop');
    if (!nav) return;

    /* ── Active tab ── */
    var path = window.location.pathname;
    nav.querySelectorAll('[data-pbn-path]').forEach(function(tab) {
      var p = tab.getAttribute('data-pbn-path');
      if (p === '/' ? path === '/' : path.startsWith(p)) tab.classList.add('is-active');
    });

    /* ── Accordion ── */
    sheet.querySelectorAll('[data-pbn-accordion]').forEach(function(group) {
      var btn      = group.querySelector('.pbn-nav__parent');
      var children = group.querySelector('.pbn-nav__children');
      if (!btn || !children) return;
      btn.addEventListener('click', function() {
        var open = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', open ? 'false' : 'true');
        children.classList.toggle('is-open', !open);
      });
    });

    /* ── Sheet open / close ── */
    var shopBtn   = document.getElementById('pbn-shop-btn');
    var closeBtn  = document.getElementById('pbn-sheet-close');
    var sheetOpen = false;

    var stickyAtc = document.getElementById('plaay-sticky-mobile');

    function openSheet() {
      sheet.classList.add('is-open');
      backdrop.classList.add('is-open');
      document.body.style.overflow = 'hidden';
      shopBtn.classList.add('is-active');
      if (stickyAtc) stickyAtc.style.display = 'none';
      sheetOpen = true;
    }
    function closeSheet() {
      sheet.classList.remove('is-open');
      backdrop.classList.remove('is-open');
      document.body.style.overflow = '';
      shopBtn.classList.remove('is-active');
      if (stickyAtc) stickyAtc.style.display = '';
      sheetOpen = false;
    }

    shopBtn.addEventListener('click', function() { sheetOpen ? closeSheet() : openSheet(); });
    closeBtn.addEventListener('click', closeSheet);
    backdrop.addEventListener('click', closeSheet);
    document.addEventListener('keydown', function(e) { if (e.key === 'Escape' && sheetOpen) closeSheet(); });
    sheet.querySelectorAll('a').forEach(function(a) { a.addEventListener('click', closeSheet); });

    /* ── Cart ── */
    document.getElementById('pbn-cart-btn').addEventListener('click', function() {
      var sd = document.querySelector('site-drawers');
      if (sd) sd.activeDrawer = 'cart';
    });

    /* ── Badge sync ── */
    var badge       = document.getElementById('pbn-cart-badge');
    var headerCount = document.querySelector('[data-cart-count]');
    function syncBadge() {
      if (!badge) return;
      var countEl = headerCount ? headerCount.querySelector('span') : null;
      var count   = countEl ? (parseInt(countEl.textContent, 10) || 0) : {{ cart.item_count }};
      badge.textContent = count;
      badge.classList.toggle('pbn__badge--hidden', count === 0);
    }
    if (headerCount) new MutationObserver(syncBadge).observe(headerCount, { childList: true, subtree: true });
    document.addEventListener('cart:updated', syncBadge);
  })();
</script>
