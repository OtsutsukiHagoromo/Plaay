{%- liquid
  assign preset = preset | default: ''
  assign has_halal       = false
  assign has_gluten_free = false
  assign has_palm_free   = false
  assign has_vegan       = false
  assign has_clean       = false

  if preset != 'bars-truffles-icons'
    for tag in product.tags
      assign trust_tag = tag | downcase | strip
      case trust_tag
        when 'badge:halal', 'trust:halal', 'halal'
          assign has_halal = true
        when 'badge:gluten-free', 'badge:gluten_free', 'trust:gluten-free', 'trust:gluten_free', 'gluten-free', 'gluten free'
          assign has_gluten_free = true
        when 'badge:palm-free', 'badge:palm_free', 'trust:palm-free', 'trust:palm_free', 'palm-free', 'palm free'
          assign has_palm_free = true
        when 'badge:vegan', 'trust:vegan', 'vegan'
          assign has_vegan = true
        when 'badge:clean', 'badge:clean-ingredients', 'badge:clean_ingredients', 'trust:clean', 'trust:clean-ingredients', 'trust:clean_ingredients', 'clean ingredients'
          assign has_clean = true
      endcase
    endfor
  endif

  assign show_trust_badges = false
  if preset == 'bars-truffles-icons' or has_halal or has_gluten_free or has_palm_free or has_vegan or has_clean
    assign show_trust_badges = true
  endif
-%}

{%- if show_trust_badges -%}
<div class="plaay-trust-strip mt-5 mb-3{% if preset == 'bars-truffles-icons' %} plaay-trust-strip--compact-icons{% else %} plaay-trust-strip--tag-grid{% endif %}" aria-label="Product trust markers">
  {%- if preset == 'bars-truffles-icons' -%}
    <div class="plaay-trust-item">
      <img src="https://cdn.shopify.com/s/files/1/0662/4722/9657/files/No_Refined_Sugar_20efff8b-6fef-472c-84a6-77fe988d31a9.png?v=1778740942" alt="No refined sugar" class="plaay-trust-img" loading="lazy" decoding="async">
      <span class="plaay-trust-label font-walsheim-bold">No Refined Sugar</span>
    </div>
    <div class="plaay-trust-item">
      <img src="https://cdn.shopify.com/s/files/1/0662/4722/9657/files/No_Gluten_3a932bb1-9849-43e1-b9fe-da4f2981544d.png?v=1778740942" alt="No gluten" class="plaay-trust-img" loading="lazy" decoding="async">
      <span class="plaay-trust-label font-walsheim-bold">No Gluten</span>
    </div>
    <div class="plaay-trust-item">
      <img src="https://cdn.shopify.com/s/files/1/0662/4722/9657/files/No_Soy_373aadbd-6c20-404a-a45c-5a162160d99b.png?v=1778740942" alt="No soy" class="plaay-trust-img" loading="lazy" decoding="async">
      <span class="plaay-trust-label font-walsheim-bold">No Soy</span>
    </div>
    <div class="plaay-trust-item">
      <img src="https://cdn.shopify.com/s/files/1/0662/4722/9657/files/No_Palm_Oil_24629699-90ad-4220-a85e-4ef724704d9f.png?v=1778740942" alt="No palm oil" class="plaay-trust-img" loading="lazy" decoding="async">
      <span class="plaay-trust-label font-walsheim-bold">No Palm Oil</span>
    </div>
    <div class="plaay-trust-item">
      <img src="https://cdn.shopify.com/s/files/1/0662/4722/9657/files/Vegan_2f4377d1-67cf-434d-a4c9-0ca32d98637a.png?v=1778740943" alt="Vegan" class="plaay-trust-img" loading="lazy" decoding="async">
      <span class="plaay-trust-label font-walsheim-bold">Vegan</span>
    </div>
    <div class="plaay-trust-item">
      <img src="https://cdn.shopify.com/s/files/1/0662/4722/9657/files/Halal_1b346961-9291-44fc-a8b4-ddbc4c8f9660.png?v=1778740942" alt="Halal" class="plaay-trust-img" loading="lazy" decoding="async">
      <span class="plaay-trust-label font-walsheim-bold">Halal</span>
    </div>
  {%- else -%}
    {%- if has_halal -%}
    <div class="plaay-trust-item">
      <img
        src="{{ 'plaay-badge-halal.png' | asset_url }}"
        alt="Halal certified"
        class="plaay-trust-img"
        loading="lazy"
        decoding="async"
        onerror="this.style.display='none'">
      <span class="plaay-trust-label font-walsheim-bold">Halal</span>
    </div>
    {%- endif -%}

    {%- if has_gluten_free -%}
    <div class="plaay-trust-item">
      <img
        src="{{ 'plaay-badge-gluten-free.png' | asset_url }}"
        alt="Gluten free"
        class="plaay-trust-img"
        loading="lazy"
        decoding="async"
        onerror="this.style.display='none'">
      <span class="plaay-trust-label font-walsheim-bold">Gluten Free</span>
    </div>
    {%- endif -%}

    {%- if has_vegan -%}
    <div class="plaay-trust-item">
      <img
        src="{{ 'plaay-badge-vegan.png' | asset_url }}"
        alt="Vegan"
        class="plaay-trust-img"
        loading="lazy"
        decoding="async"
        onerror="this.style.display='none'">
      <span class="plaay-trust-label font-walsheim-bold">Vegan</span>
    </div>
    {%- endif -%}

    {%- if has_palm_free -%}
    <div class="plaay-trust-item">
      <img
        src="{{ 'plaay-badge-palm-free.png' | asset_url }}"
        alt="Palm oil free"
        class="plaay-trust-img"
        loading="lazy"
        decoding="async"
        onerror="this.style.display='none'">
      <span class="plaay-trust-label font-walsheim-bold">Palm Free</span>
    </div>
    {%- endif -%}

    {%- if has_clean -%}
    <div class="plaay-trust-item">
      <img
        src="{{ 'plaay-badge-clean.png' | asset_url }}"
        alt="Clean ingredients"
        class="plaay-trust-img"
        loading="lazy"
        decoding="async"
        onerror="this.style.display='none'">
      <span class="plaay-trust-label font-walsheim-bold">Clean Ingredients</span>
    </div>
    {%- endif -%}
  {%- endif -%}
</div>
{%- endif -%}
