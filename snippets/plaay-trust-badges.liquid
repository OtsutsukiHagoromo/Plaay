{%- liquid
  assign preset = preset | default: ''
  assign has_halal       = false
  assign has_gluten_free = false
  assign has_palm_free   = false
  assign has_vegan       = false
  assign has_clean       = false

  if preset != 'bars-truffles-icons'
    for tag in product.tags
      assign trust_tag = tag | downcase | strip
      case trust_tag
        when 'badge:halal', 'trust:halal', 'halal'
          assign has_halal = true
        when 'badge:gluten-free', 'badge:gluten_free', 'trust:gluten-free', 'trust:gluten_free', 'gluten-free', 'gluten free'
          assign has_gluten_free = true
        when 'badge:palm-free', 'badge:palm_free', 'trust:palm-free', 'trust:palm_free', 'palm-free', 'palm free'
          assign has_palm_free = true
        when 'badge:vegan', 'trust:vegan', 'vegan'
          assign has_vegan = true
        when 'badge:clean', 'badge:clean-ingredients', 'badge:clean_ingredients', 'trust:clean', 'trust:clean-ingredients', 'trust:clean_ingredients', 'clean ingredients'
          assign has_clean = true
      endcase
    endfor
  endif

  assign show_trust_badges = false
  if preset == 'bars-truffles-icons' or has_halal or has_gluten_free or has_palm_free or has_vegan or has_clean
    assign show_trust_badges = true
  endif
-%}

{%- if show_trust_badges -%}
<div class="plaay-trust-strip mt-5 mb-3{% if preset == 'bars-truffles-icons' %} plaay-trust-strip--compact-icons{% else %} plaay-trust-strip--tag-grid{% endif %}" aria-label="Product trust markers">
  {%- if preset == 'bars-truffles-icons' -%}
    <div class="plaay-trust-item">
      <img
        src="https://cdn.shopify.com/s/files/1/0662/4722/9657/files/No_Refined_Sugar_a4ac9eb7-cf82-4ad5-8d9d-adb7da76d30a.png?v=1776069357"
        alt="No refined sugar"
        class="plaay-trust-img"
        loading="lazy"
        decoding="async">
      <span class="plaay-trust-label font-walsheim-bold">No Refined Sugar</span>
    </div>
    <div class="plaay-trust-item">
      <img
        src="https://cdn.shopify.com/s/files/1/0662/4722/9657/files/100_Clean_Ingredient.png?v=1776069357"
        alt="100% clean ingredients"
        class="plaay-trust-img"
        loading="lazy"
        decoding="async">
      <span class="plaay-trust-label font-walsheim-bold">100% Clean Ingredients</span>
    </div>
    <div class="plaay-trust-item">
      <img
        src="https://cdn.shopify.com/s/files/1/0662/4722/9657/files/Everyday_Indulgence.png?v=1776069360"
        alt="Everyday indulgence"
        class="plaay-trust-img"
        loading="lazy"
        decoding="async">
      <span class="plaay-trust-label font-walsheim-bold">Everyday Indulgence</span>
    </div>
    <div class="plaay-trust-item">
      <img
        src="https://cdn.shopify.com/s/files/1/0662/4722/9657/files/Nutriotionist_Founded.png?v=1776069357"
        alt="Nutritionist founded"
        class="plaay-trust-img"
        loading="lazy"
        decoding="async">
      <span class="plaay-trust-label font-walsheim-bold">Nutritionist Founded</span>
    </div>
    <div class="plaay-trust-item">
      <img
        src="https://cdn.shopify.com/s/files/1/0662/4722/9657/files/Made_in_UAE.png?v=1776069356"
        alt="Made in UAE"
        class="plaay-trust-img"
        loading="lazy"
        decoding="async">
      <span class="plaay-trust-label font-walsheim-bold">Made in UAE</span>
    </div>
  {%- else -%}
    {%- if has_halal -%}
    <div class="plaay-trust-item">
      <img
        src="{{ 'plaay-badge-halal.png' | asset_url }}"
        alt="Halal certified"
        class="plaay-trust-img"
        loading="lazy"
        decoding="async"
        onerror="this.style.display='none'">
      <span class="plaay-trust-label font-walsheim-bold">Halal</span>
    </div>
    {%- endif -%}

    {%- if has_gluten_free -%}
    <div class="plaay-trust-item">
      <img
        src="{{ 'plaay-badge-gluten-free.png' | asset_url }}"
        alt="Gluten free"
        class="plaay-trust-img"
        loading="lazy"
        decoding="async"
        onerror="this.style.display='none'">
      <span class="plaay-trust-label font-walsheim-bold">Gluten Free</span>
    </div>
    {%- endif -%}

    {%- if has_vegan -%}
    <div class="plaay-trust-item">
      <img
        src="{{ 'plaay-badge-vegan.png' | asset_url }}"
        alt="Vegan"
        class="plaay-trust-img"
        loading="lazy"
        decoding="async"
        onerror="this.style.display='none'">
      <span class="plaay-trust-label font-walsheim-bold">Vegan</span>
    </div>
    {%- endif -%}

    {%- if has_palm_free -%}
    <div class="plaay-trust-item">
      <img
        src="{{ 'plaay-badge-palm-free.png' | asset_url }}"
        alt="Palm oil free"
        class="plaay-trust-img"
        loading="lazy"
        decoding="async"
        onerror="this.style.display='none'">
      <span class="plaay-trust-label font-walsheim-bold">Palm Free</span>
    </div>
    {%- endif -%}

    {%- if has_clean -%}
    <div class="plaay-trust-item">
      <img
        src="{{ 'plaay-badge-clean.png' | asset_url }}"
        alt="Clean ingredients"
        class="plaay-trust-img"
        loading="lazy"
        decoding="async"
        onerror="this.style.display='none'">
      <span class="plaay-trust-label font-walsheim-bold">Clean Ingredients</span>
    </div>
    {%- endif -%}
  {%- endif -%}
</div>
{%- endif -%}
