<div
  class="plaay-upsell-card flex-shrink-0"
  data-cart-recommendation-item
  data-product-id="{{ product.id }}">
  <a href="{{ product.url }}" class="plaay-upsell-card__img-wrap block">
    {% render 'img', type: 'img', lazy: true, img: product.featured_image, class: 'plaay-upsell-card__img object-contain w-full h-full' %}
  </a>

  <div class="plaay-upsell-card__body">
    <a href="{{ product.url }}" class="plaay-upsell-card__title font-walsheim-bold text-dark-blue uppercase">
      {{ product.title }}
    </a>

    <div class="plaay-upsell-card__price-row">
      {% if product.compare_at_price > product.price %}
        <span class="plaay-upsell-card__compare font-walsheim-bold">{{ product.compare_at_price | money }}</span>
      {% endif %}
      <span class="plaay-upsell-card__price font-walsheim-bold text-dark-blue">{{ product.price | money }}</span>
    </div>

    <quick-add data-module="quick-add" data-id="{{ product.first_available_variant.id }}">
      <input type="hidden" name="quantity" value="1">
      <button
        type="button"
        class="plaay-upsell-card__btn font-walsheim-bold text-dark-blue text-xs uppercase w-full"
        data-add>
        + Add
      </button>
    </quick-add>
  </div>
</div>
